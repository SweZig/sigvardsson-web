---
interface Props {
  title?: string;
  titleSv?: string;
  titleEn?: string;
  description?: string;
  descriptionSv?: string;
  descriptionEn?: string;
  canonical?: string;
  ogImage?: string;
}

const {
  title,
  titleSv = title || 'Sigvardsson Consulting Group',
  titleEn = title || 'Sigvardsson Consulting Group',
  descriptionSv = 'Ledande konsultbyrå inom retail — vi hjälper detaljhandeln att öka lönsamhet och effektivitet.',
  descriptionEn = 'Leading retail consultancy — helping retailers increase profitability and efficiency.',
  canonical,
  ogImage = 'https://www.sigvardsson.org/images/og-image.jpg',
} = Astro.props;

const canonicalURL = canonical || `https://www.sigvardsson.org${Astro.url.pathname}`;

const schemaOrg = {
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "Organization",
      "@id": "https://www.sigvardsson.org/#organization",
      "name": "Sigvardsson Consulting Group",
      "alternateName": "SCG",
      "url": "https://www.sigvardsson.org/",
      "logo": {
        "@type": "ImageObject",
        "url": "https://www.sigvardsson.org/images/logos/S_blue.png"
      },
      "description": "Leading Nordic retail management consultancy with 30+ years of proven results. We help retailers increase profitability through advisory, technology and retail optimization.",
      "foundingDate": "2017",
      "areaServed": ["SE", "NO", "DK", "FI"],
      "knowsLanguage": ["sv", "en", "no", "da", "fi"],
      "address": {
        "@type": "PostalAddress",
        "streetAddress": "Beckholmen, hus 526",
        "addressLocality": "Stockholm",
        "postalCode": "115 21",
        "addressCountry": "SE"
      },
      "contactPoint": {
        "@type": "ContactPoint",
        "telephone": "+46790200300",
        "contactType": "customer service",
        "availableLanguage": ["Swedish", "English", "Norwegian"]
      },
      "sameAs": [
        "https://www.linkedin.com/company/sigvardsson-consulting-group"
      ]
    },
    {
      "@type": "WebSite",
      "@id": "https://www.sigvardsson.org/#website",
      "url": "https://www.sigvardsson.org/",
      "name": "Sigvardsson Consulting Group",
      "publisher": { "@id": "https://www.sigvardsson.org/#organization" },
      "inLanguage": ["sv", "en", "no", "da", "fi"]
    },
    {
      "@type": "WebPage",
      "@id": `${canonicalURL}#webpage`,
      "url": canonicalURL,
      "isPartOf": { "@id": "https://www.sigvardsson.org/#website" },
      "about": { "@id": "https://www.sigvardsson.org/#organization" },
      "name": titleSv,
      "description": descriptionSv,
      "inLanguage": ["sv", "en", "no", "da", "fi"]
    }
  ]
};
---
<!doctype html>
<html lang="sv">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />

  <!-- SEO - dynamically updated by JS -->
  <title id="page-title">{titleSv}</title>
  <meta name="description" id="page-description" content={descriptionSv} />
  <link rel="canonical" href={canonicalURL} />

  <!-- Hreflang — same URL serves all 5 languages via CSS+JS -->
  <link rel="alternate" hreflang="sv" href={canonicalURL} />
  <link rel="alternate" hreflang="en" href={canonicalURL} />
  <link rel="alternate" hreflang="no" href={canonicalURL} />
  <link rel="alternate" hreflang="da" href={canonicalURL} />
  <link rel="alternate" hreflang="fi" href={canonicalURL} />
  <link rel="alternate" hreflang="x-default" href={canonicalURL} />

  <!-- Open Graph -->
  <meta property="og:type" content="website" />
  <meta property="og:url" content={canonicalURL} />
  <meta property="og:title" id="og-title" content={titleSv} />
  <meta property="og:description" id="og-description" content={descriptionSv} />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />
  <meta property="og:locale" content="sv_SE" />
  <meta property="og:locale:alternate" content="en_GB" />
  <meta property="og:site_name" content="Sigvardsson Consulting Group" />

  <!-- Twitter / X Cards -->
  <meta name="twitter:card" content="summary_large_image" />
  <meta name="twitter:title" id="tw-title" content={titleSv} />
  <meta name="twitter:description" id="tw-description" content={descriptionSv} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Sitemap + Robots -->
  <link rel="sitemap" href="/sitemap.xml" />

  <!-- Favicon + App icons -->
  <link rel="icon" type="image/png" href="/images/logos/S_blue-trans.png" />
  <link rel="apple-touch-icon" href="/images/logos/S_blue.png" />
  <meta name="theme-color" content="#010D60" />

  <!-- Schema.org JSON-LD -->
  <script type="application/ld+json" set:html={JSON.stringify(schemaOrg)} />

  <!-- Google Fonts -->
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Chakra+Petch:wght@500;600&family=Nunito:wght@200;300;400&display=swap" rel="stylesheet" />

  <!-- Language init — runs before render to avoid flash -->
  <script is:inline>
    (function() {
      var valid = ['sv','en','no','da','fi'];
      var saved = localStorage.getItem('scg-lang') || 'sv';
      var lang = valid.indexOf(saved) >= 0 ? saved : 'sv';
      document.documentElement.setAttribute('data-lang', lang);
      document.documentElement.setAttribute('lang', lang);
    })();
  </script>

  <style is:global>
    /* ===== CSS VARIABLES ===== */
    :root {
      --color-navy:       #010D60;
      --color-navy-mid:   #1A277A;
      --color-navy-lite:  #3D4893;
      --color-blue:       #2A4EA9;
      --color-blue-mid:   #4867B6;
      --color-blue-lite:  #90A2CF;
      --color-off-white:  #F5F6FA;
      --color-gold:       #C9A84C;
      --color-white:      #FFFFFF;

      --color-lr-green:   #0E5C40;
      --color-lr-green-light: #2d8a6b;

      --font-heading: 'Chakra Petch', sans-serif;
      --font-body:    'Nunito', sans-serif;

      --radius:   8px;
      --max-w:    1200px;
      --section-pad: 5rem 2rem;
    }

    /* ===== LINK RETAIL PILL — canonical badge ===== */
    /* Use as: <span class="lr-pill">LR</span> for compact icon */
    /* Or: <span class="lr-pill-with-text"><span class="lr-pill">LR</span> Link Retail</span> for badge+text */
    .lr-pill {
      display: inline-block;
      background: var(--color-lr-green);
      color: #fff;
      font-family: var(--font-heading);
      font-size: 0.62rem;
      font-weight: 700;
      padding: 0.15rem 0.4rem;
      border-radius: 3px;
      letter-spacing: 0.06em;
      line-height: 1.2;
      vertical-align: middle;
    }
    .lr-pill-with-text {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: var(--font-heading);
      font-size: 0.82rem;
      letter-spacing: 0.03em;
    }

    @media (max-width: 480px) {
      :root { --section-pad: 3rem 1.25rem; }
      .container { padding: 0 1.25rem; }
      .btn { padding: 0.7rem 1.5rem; font-size: 0.88rem; }
    }

    /* ===== LANGUAGE TOGGLE — 5 languages ===== */
    /* Hide everything that doesn't match current lang */
    [data-lang="sv"] .en-text,
    [data-lang="sv"] .no-text,
    [data-lang="sv"] .da-text,
    [data-lang="sv"] .fi-text { display: none !important; }

    [data-lang="en"] .sv-text,
    [data-lang="en"] .no-text,
    [data-lang="en"] .da-text,
    [data-lang="en"] .fi-text { display: none !important; }

    /* NO/DA/FI: en-text hidden; sv-text stays visible (JS swaps its innerHTML) */
    [data-lang="no"] .en-text,
    [data-lang="no"] .da-text,
    [data-lang="no"] .fi-text { display: none !important; }

    [data-lang="da"] .en-text,
    [data-lang="da"] .no-text,
    [data-lang="da"] .fi-text { display: none !important; }

    [data-lang="fi"] .en-text,
    [data-lang="fi"] .no-text,
    [data-lang="fi"] .da-text { display: none !important; }

    /* ===== RESET & BASE ===== */
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    html { scroll-behavior: smooth; }

    body {
      font-family: var(--font-body);
      font-weight: 200;
      color: var(--color-navy);
      background: var(--color-white);
      line-height: 1.7;
      overflow-x: hidden;
    }

    h1, h2, h3, h4, h5, nav a, .btn {
      font-family: var(--font-heading);
      font-weight: 500;
    }

    a { color: inherit; text-decoration: none; }

    img { max-width: 100%; display: block; }

    .container {
      max-width: var(--max-w);
      margin: 0 auto;
      padding: 0 2rem;
    }

    /* ===== BUTTONS ===== */
    .btn {
      display: inline-block;
      padding: 0.75rem 2rem;
      border-radius: var(--radius);
      font-size: 0.95rem;
      letter-spacing: 0.04em;
      transition: all 0.25s ease;
      cursor: pointer;
      border: none;
    }

    .btn-primary {
      background: var(--color-navy);
      color: var(--color-white);
    }
    .btn-primary:hover {
      background: var(--color-blue);
      transform: translateY(-2px);
      box-shadow: 0 8px 24px rgba(1,13,96,0.25);
    }

    .btn-outline {
      background: transparent;
      color: var(--color-white);
      border: 2px solid rgba(255,255,255,0.6);
    }
    .btn-outline:hover {
      background: rgba(255,255,255,0.1);
      border-color: var(--color-white);
    }

    /* ===== SECTION LABELS ===== */
    .section-label {
      font-family: var(--font-heading);
      font-size: 0.75rem;
      letter-spacing: 0.15em;
      text-transform: uppercase;
      color: var(--color-blue-mid);
      margin-bottom: 0.75rem;
      display: block;
    }

    /* ===== SCROLL ANIMATION ===== */
    .fade-up {
      opacity: 0;
      transform: translateY(28px);
      transition: opacity 0.6s ease, transform 0.6s ease;
    }
    .fade-up.visible {
      opacity: 1;
      transform: none;
    }

    /* ===== WAVE DIVIDER ===== */
    .wave-divider svg { display: block; }

    /* ===== PAGE WRAPPER ===== */
    .page-wrapper {
      display: flex;
      flex-direction: column;
      min-height: 100vh;
    }
    main { flex: 1; }
  </style>
  <!-- Google Analytics GA4 -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-JNPFEESDFN" is:inline></script>
  <script is:inline>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', 'G-JNPFEESDFN');
  </script>

  <!-- UTM persistence + CTA click tracking -->
  <script is:inline>
    (function(){
      // 1. Capture UTM parameters on landing, store in sessionStorage
      try {
        var params = new URLSearchParams(window.location.search);
        var utmKeys = ['utm_source','utm_medium','utm_campaign','utm_content','utm_term'];
        var found = {};
        utmKeys.forEach(function(k){ if (params.has(k)) found[k] = params.get(k); });
        if (Object.keys(found).length > 0) {
          sessionStorage.setItem('scg_utm', JSON.stringify(found));
        }
      } catch(e) {}

      // 2. On click of any internal link, append stored UTM params (only if not already present)
      document.addEventListener('click', function(e){
        var a = e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href');
        if (!href || href.startsWith('#') || href.startsWith('mailto:') || href.startsWith('tel:')) return;
        // Skip external links
        try {
          var url = new URL(href, window.location.origin);
          if (url.host !== window.location.host) return;
          // Read stored UTM
          var stored = sessionStorage.getItem('scg_utm');
          if (!stored) return;
          var utm = JSON.parse(stored);
          var modified = false;
          Object.keys(utm).forEach(function(k){
            if (!url.searchParams.has(k)) { url.searchParams.set(k, utm[k]); modified = true; }
          });
          if (modified) a.setAttribute('href', url.pathname + url.search + url.hash);
        } catch(e) {}
      }, true);

      // 3. Fire GA4 event when any CTA (Boka demo / Kontakta oss / Book a demo / Contact us) is clicked
      document.addEventListener('click', function(e){
        var a = e.target.closest && e.target.closest('a[href]');
        if (!a) return;
        var href = a.getAttribute('href') || '';
        // Detect demo/contact CTAs by destination
        if (href.indexOf('/Contact') === -1 && href.indexOf('/contact') === -1) return;
        var label = (a.textContent || '').trim().toLowerCase();
        var cta = 'contact';
        if (label.indexOf('demo') !== -1 || label.indexOf('boka') !== -1) cta = 'book_demo';
        if (typeof gtag === 'function') {
          gtag('event', 'cta_click', {
            cta_label: label.slice(0, 60),
            cta_type: cta,
            page_path: window.location.pathname,
          });
        }
      }, true);
    })();
  </script>

</head>

<body>
  <div class="page-wrapper">
    <slot name="header" />
    <main>
      <slot />
    </main>
    <slot name="footer" />
  </div>

  <!-- Scroll animation observer -->
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function() {
      const observer = new IntersectionObserver(function(entries) {
        entries.forEach(function(entry) {
          if (entry.isIntersecting) {
            entry.target.classList.add('visible');
          }
        });
      }, { threshold: 0.1, rootMargin: '0px 0px -40px 0px' });

      document.querySelectorAll('.fade-up').forEach(function(el) {
        observer.observe(el);
      });
    });
  </script>
</body>
</html>
