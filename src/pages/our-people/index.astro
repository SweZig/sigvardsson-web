---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const team = [
  {
    name: 'Per Sigvardsson',
    title: 'CEO & Founder',
    bio: 'Per has over 30 years of experience within retail. He has worked in various leading positions in organizations as Elgiganten (Currys plc), Granngården & TOP-TOY.',
    linkedin: 'https://www.linkedin.com/in/sigvardsson/',
    specs: ['Retail Strategy'],
    initials: 'PS',
    photo: '/images/team/per-sigvardsson.jpg',
    photoPos: 'center 22%',
  },
  {
    name: 'Lars Lundqvist',
    title: 'Sales Director & Senior Consultant',
    bio: 'Lars has over 30 years of experience within retail. He has worked in various leading positions in organizations as Elgiganten (Currys plc), Media-Saturn (Ceconomy AG), XXL Sport & Villmark & TOP-TOY.',
    linkedin: 'https://www.linkedin.com/in/lars-lundqvist-9941793a/',
    specs: ['Retail Operations Excellence'],
    initials: 'LL',
    photo: '/images/team/lars-lundqvist.jpg',
    photoPos: 'center 8%',
  },
  {
    name: 'Sebastian Fauné',
    title: 'Senior Consultant',
    bio: 'Sebastian has over 25 years of experience within retail. He has worked in various leading positions in organizations as PC City (Currys plc) & Media-Saturn (Ceconomy AG).',
    linkedin: 'https://www.linkedin.com/in/sebastian-faun%C3%A9-8b76a263/',
    specs: ['Commercial Excellence'],
    initials: 'SF',
    photo: '/images/team/sebastian-faune.jpg',
    photoPos: 'center 14%',
  },
  {
    name: 'Peter Wilén',
    title: 'Senior Consultant',
    bio: 'Peter has over 25 years of experience within retail. He has worked in various leading positions in organizations as Stadium, Elgiganten (Currys plc) & Media-Saturn (Ceconomy AG).',
    linkedin: 'https://www.linkedin.com/in/peterwilen/',
    specs: ['People Development', 'Change Management'],
    initials: 'PW',
    photo: '/images/team/peter-wilen.jpg',
    photoPos: 'center 20%',
  },
  {
    name: 'Emil Sigvardsson',
    title: 'CIO',
    bio: 'Emil has been working within retail for 6 years with experience from XXL Sports & Marketing Platform.',
    linkedin: 'https://www.linkedin.com/in/emilsigvardsson/',
    specs: ['Tech'],
    initials: 'ES',
    photo: '/images/team/emil-sigvardsson.jpg',
    photoPos: 'center 2%',
  },
  {
    name: 'Felix Johansson',
    title: 'Head of Tech',
    bio: 'Felix has been working within retail for 4 years with experience from XXL Sports & Marketing Platform.',
    linkedin: 'https://www.linkedin.com/in/felix-johansson-788039135/',
    specs: ['Tech'],
    initials: 'FJ',
    photo: '/images/team/felix-johansson.jpg',
    photoPos: 'center 14%',
  },
];

const accents = ['#010D60','#1A277A','#2A4EA9','#3D4893','#4867B6','#010D60'];
---

<Layout
  titleSv="Vårt team — Sigvardsson Consulting Group"
  titleEn="Our Team — Sigvardsson Consulting Group"
  descriptionSv="Möt teamet bakom Sigvardsson Consulting Group — erfarna konsulter med sammanlagt över 150 års retail-erfarenhet."
  descriptionEn="Meet the team behind Sigvardsson Consulting Group — experienced consultants with collectively over 150 years of retail expertise."
  canonical="https://www.sigvardsson.org/our-people/"
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="hero-photo-bg"></div>
    <div class="container" style="position:relative;z-index:1">
      <span class="section-label sv-text" data-no="Vårt team" data-da="Vores team" data-fi="Tiimimme">Vårt team</span>
      <span class="section-label en-text">Our team</span>
      <h1>
        <span class="sv-text" data-no="Menneskene bak<br/>resultatene" data-da="Menneskene bag<br/>resultaterne" data-fi="Ihmiset tulosten<br/>takana">Människorna bakom<br/>resultaten</span>
        <span class="en-text">The people behind<br/>the results</span>
      </h1>
      <p class="hero-sub sv-text" data-no="Erfarne konsulenter med dyp spesialisering innen retail — til sammen over 150 år med bransjeerfaring fra ledende nordiske og europeiske kjeder." data-da="Erfarne konsulenter med dyb specialisering inden for detail — tilsammen over 150 år med brancheerfaring fra ledende nordiske og europæiske kæder." data-fi="Kokeneet konsultit syvällä vähittäiskaupan erikoistumisella — yhteensä yli 150 vuotta alakokemusta johtavista pohjoismaisista ja eurooppalaisista ketjuista.">Erfarna konsulter med djup specialisering inom retail — sammanlagt över 150 års branscherfarenhet från ledande nordiska och europeiska kedjor.</p>
      <p class="hero-sub en-text">Experienced consultants with deep retail specialization — collectively over 150 years of industry experience from leading Nordic and European chains.</p>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        {team.map((person, i) => (
          <article class="team-card fade-up" style={`animation-delay:${i*80}ms`}>

            <div class="team-avatar" style={`background:${accents[i]}`}>
              {person.photo
                ? <img src={person.photo} alt={person.name} class="avatar-photo" style={`object-position:${person.photoPos || 'center 8%'}`} />
                : <span class="avatar-initials">{person.initials}</span>
              }
            </div>

            <div class="team-info">
              <div class="team-header">
                <div class="team-header-text">
                  <h3 class="team-name">{person.name}</h3>
                  <p class="team-title">{person.title}</p>
                </div>
                <a
                  href={person.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="linkedin-btn"
                  aria-label={`LinkedIn — ${person.name}`}
                >
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </div>

              <p class="team-bio">{person.bio}</p>

              <div class="spec-tags">
                {person.specs.map(s => (
                  <span class="spec-tag" style={`color:${accents[i]};border-color:${accents[i]}40`}>{s}</span>
                ))}
              </div>
            </div>

          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FOUNDER BIO ===== -->
  <section class="founder-bio">
    <div class="container">
      <div class="founder-inner fade-up">

        <div class="founder-portrait">
          <div class="founder-img-frame">
            <img src="/images/team/per-sigvardsson.jpg" alt="Per Sigvardsson" loading="lazy" />
          </div>
          <div class="founder-tagline">
            <span class="sv-text" data-no="Natural Born Retailer" data-da="Natural Born Retailer" data-fi="Natural Born Retailer">Natural Born Retailer</span>
            <span class="en-text">Natural Born Retailer</span>
          </div>
          <div class="founder-awards">
            <div class="f-award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" /></div>
            <div class="f-award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" /></div>
            <div class="f-award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" /></div>
          </div>
          <p class="f-awards-label sv-text" data-no="Global 100 Winner 2024 · 2025 · 2026" data-da="Global 100 Winner 2024 · 2025 · 2026" data-fi="Global 100 Winner 2024 · 2025 · 2026">Global 100 Winner 2024 · 2025 · 2026</p>
          <p class="f-awards-label en-text">Global 100 Winner 2024 · 2025 · 2026</p>
        </div>

        <div class="founder-text">
          <span class="section-label sv-text" data-no="Grunnlegger & CEO" data-da="Grundlægger & CEO" data-fi="Perustaja & toimitusjohtaja">Grundare & VD</span>
          <span class="section-label en-text">Founder & CEO</span>

          <h2 class="sv-text" data-no="Per Sigvardsson" data-da="Per Sigvardsson" data-fi="Per Sigvardsson">Per Sigvardsson</h2>
          <h2 class="en-text">Per Sigvardsson</h2>

          <div class="bio-body sv-text">
            <p>Per Sigvardssons signatur är enkel: <em>"Get the job done."</em> Det är inte en slogan — det är ett löfte som backas upp av 30+ år i operativt ansvar i toppen av nordisk detaljhandel. Inte som konsult utifrån, utan som VD, COO och styrelseordförande med fullt ägarskap för resultat, organisation och förändring.</p>

            <p>Karriären byggdes inom CE-handel och kulminerade i rollen som COO på <strong>Elkjøp Nordic AS</strong> (del av Currys plc) — Nordens ledande CE-kedja med Elgiganten i Sverige, Norge, Danmark och Finland. Under nästan ett decennium ledde Per en av regionens mest komplexa retailorganisationer: omnikanalstrategi, storskaliga systemimplementationer och butiksexpansion. Som styrelseordförande i <strong>Elgiganten</strong> och <strong>PC City Sverige</strong> kombinerade han det strategiska med det operativa — han förstår hur styrelserumsbeslut landar på butiksgolvet, och vad det kostar när de inte gör det.</p>

            <p>Under hans ledning vann Elkjøp/Elgiganten ett tiotal branschpriser — bland annat <strong>Best Omnichannel Solution (RETA Europe 2015/16)</strong>, tre raka år som bästa e-handel i Sverige (Pricerunner), tre år i rad som bästa webshop i Sverige (Prisjakt 2014–15) och tre raka år med Nordens bästa kontaktcenter (Daymaker &amp; Confex CC 2010–12). Se fullständig lista nedan.</p>

            <p>Som <strong>VD för Granngården AB</strong> — 108 butiker, 550 anställda, 1,7 miljarder kronor i omsättning — ledde Per organisationen genom Felleskjøpets internationella förvärv med bibehållet affärsfokus och personalengagemang. Och som <strong>Group CEO för TOP-TOY A/S</strong>, Nordens ledande leksakskedja, visade han att förmågan att skapa resultat håller oavsett produktkategori.</p>

            <p>Under sju år parallellt med SCG fungerade Per som <strong>Senior Advisor åt POWER International AS</strong> i Norge — en av Nordens starkast växande CE-kedjor — med ansvar för strategisk rådgivning inom digital retail. Det är den typen av förtroendeuppdrag man bara får om man levererar.</p>

            <p>Per är inte enbart konsult. Han är aktiv <strong>investerare och serieentreprenör</strong> med ett portföljbolag som inkluderar Feedback | App — det egenutvecklade feedbackverktyg som SCG rullar ut hos retailkunder — samt flertalet övriga startups. Den kombinationen av operativt djup, strategisk höjd och entreprenöriellt sinne är ovanlig. Det är också exakt vad SCG:s kunder betalar för.</p>

            <p>2016 grundades Sigvardsson Consulting Group på en övertygelse: den bästa retailrådgivningen kommer från personer som har suttit i stolen. SCG är inte ett generalistkonsultbolag med en retailpraktik — det är ett specialistbolag byggt av retailledare, för retailledare. Idag leder Per ett team med sammanlagt 150+ års branscherfarenhet. Samtliga 250+ projekt har levererat positiv ROI. Det är inte en slump — det är ett metodval.</p>
          </div>

          <div class="bio-body en-text">
            <p>Per Sigvardsson's signature is simple: <em>"Get the job done."</em> That's not a slogan — it's a promise backed by 30+ years of operational leadership at the top of Nordic retail. Not as an outside consultant, but as CEO, COO and Chairman with full ownership of results, organization and change.</p>

            <p>His career was built in consumer electronics retail and culminated in the role of COO at <strong>Elkjøp Nordic AS</strong> (part of Currys plc) — the Nordic region's leading CE chain operating Elgiganten in Sweden, Norway, Denmark and Finland. For nearly a decade, Per led one of the region's most complex retail organizations: omnichannel strategy, large-scale system implementations and store expansion. As Chairman of <strong>Elgiganten</strong> and <strong>PC City Sverige</strong>, he combined the strategic with the operational — he understands how boardroom decisions land on the store floor, and what it costs when they don't.</p>

            <p>Under his leadership, Elkjøp/Elgiganten won over ten industry awards — including <strong>Best Omnichannel Solution (RETA Europe 2015/16)</strong>, three consecutive years as best e-commerce site in Sweden (Pricerunner), two years as Webshop of the Year in Sweden (Prisjakt 2014–15), and three straight years as Norway's best contact centre (Daymaker &amp; Confex CC 2010–12). Full list below.</p>

            <p>As <strong>CEO of Granngården AB</strong> — 108 stores, 550 employees, SEK 1.7 billion in revenue — Per led the organization through Felleskjøpet's international acquisition while maintaining business focus and staff engagement. And as <strong>Group CEO of TOP-TOY A/S</strong>, the Nordic region's leading toy retailer, he demonstrated that the ability to deliver results holds regardless of product category.</p>

            <p>For seven years alongside SCG, Per served as <strong>Senior Advisor to POWER International AS</strong> in Norway — one of the Nordic region's most rapidly growing CE chains — with responsibility for strategic advisory on digital retail. That kind of trust mandate only comes when you consistently deliver.</p>

            <p>Per is not only a consultant. He is an active <strong>investor and serial entrepreneur</strong> with a portfolio that includes Feedback | App — the in-house feedback tool SCG deploys with retail clients — as well as several other ventures. That combination of operational depth, strategic elevation and entrepreneurial thinking is rare. It is also exactly what SCG's clients pay for.</p>

            <p>Sigvardsson Consulting Group was founded in 2016 on a conviction: the best retail advisory comes from people who have sat in the chair. SCG is not a generalist consultancy with a retail practice — it is a specialist firm built by retail leaders, for retail leaders. Today Per leads a team with a combined 150+ years of industry experience. All 250+ projects have delivered positive ROI. That's not a coincidence — it's a methodology.</p>
          </div>

          <!-- LinkedIn recommendations as social proof -->
          <div class="founder-quotes">
            <blockquote class="f-quote">
              <p>"Per is probably one of the best retail leaders with multichannel skills out there. I have never seen a person with such skill in details within the entire business working as an executive leader."</p>
              <footer>— Patrik Skånberg, <span class="sv-text" data-no="direktrapport i 8 år" data-da="direkte rapport i 8 år" data-fi="suora alaiseni 8 vuotta">direktrapport under 8 år</span><span class="en-text">direct report for 8 years</span></footer>
            </blockquote>
            <blockquote class="f-quote">
              <p>"Per is a wise and inspiring leader that gets coworkers to perform to their outer limits. He has a clear idea of future plans which is communicated and adopted by the staff."</p>
              <footer>— Sverker Carnemark, <span class="sv-text" data-no="tidl. CFO Elgiganten AB" data-da="tidl. CFO Elgiganten AB" data-fi="entinen talousjohtaja Elgiganten AB">fd. CFO Elgiganten AB</span><span class="en-text">former CFO Elgiganten AB</span></footer>
            </blockquote>
          </div>

          <div class="founder-career">
            <p class="career-label sv-text" data-no="Karrierehøydepunkter" data-da="Karrierehøjdepunkter" data-fi="Uran kohokohdat">Karriärhöjdpunkter</p>
            <p class="career-label en-text">Career highlights</p>
            <div class="career-items">
              <div class="career-item">
                <span class="career-year">2016–</span>
                <div>
                  <strong class="sv-text" data-no="Grunnlegger & CEO, Sigvardsson Consulting Group" data-da="Grundlægger & CEO, Sigvardsson Consulting Group" data-fi="Perustaja & toimitusjohtaja, Sigvardsson Consulting Group">Grundare & VD, Sigvardsson Consulting Group</strong>
                  <strong class="en-text">Founder & CEO, Sigvardsson Consulting Group</strong>
                  <span class="sv-text" data-no="250+ prosjekter · 100% ROI-levering" data-da="250+ projekter · 100% ROI-levering" data-fi="250+ projektia · 100% ROI-toimitus">250+ projekt · 100% ROI-leverans</span>
                  <span class="en-text">250+ projects · 100% ROI delivery</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2017–23</span>
                <div>
                  <strong class="sv-text" data-no="Senior Advisor, POWER International AS (Norge)" data-da="Senior Advisor, POWER International AS (Norge)" data-fi="Senior Advisor, POWER International AS (Norja)">Senior Advisor, POWER International AS (Norge)</strong>
                  <strong class="en-text">Senior Advisor, POWER International AS (Norway)</strong>
                  <span class="sv-text" data-no="Strategisk rådgivning digital retail" data-da="Strategisk rådgivning digital detail" data-fi="Strateginen neuvonta digitaalinen kauppa">Strategisk rådgivning digital retail</span>
                  <span class="en-text">Strategic advisory on digital retail</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2018–19</span>
                <div>
                  <strong class="sv-text" data-no="Group CEO, TOP-TOY A/S" data-da="Group CEO, TOP-TOY A/S" data-fi="Group CEO, TOP-TOY A/S">Group CEO, TOP-TOY A/S</strong>
                  <strong class="en-text">Group CEO, TOP-TOY A/S</strong>
                  <span class="sv-text" data-no="Nordens ledende lekekjede" data-da="Nordens ledende legetøjskæde" data-fi="Pohjoismaiden johtava leluketju">Nordens ledande leksakskedja</span>
                  <span class="en-text">The Nordic region's leading toy retailer</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2015–18</span>
                <div>
                  <strong class="sv-text" data-no="CEO, Granngården AB" data-da="CEO, Granngården AB" data-fi="toimitusjohtaja, Granngården AB">VD, Granngården AB</strong>
                  <strong class="en-text">CEO, Granngården AB</strong>
                  <span class="sv-text" data-no="108 butikker · 550 ansatte · 1,7 mrd SEK" data-da="108 butikker · 550 ansatte · 1,7 mia. SEK" data-fi="108 kauppaa · 550 työntekijää · 1,7 mrd SEK">108 butiker · 550 anställda · 1,7 mdr SEK</span>
                  <span class="en-text">108 stores · 550 employees · SEK 1.7bn</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2006–15</span>
                <div>
                  <strong class="sv-text" data-no="COO & Styreleder, Elkjøp Nordic / Elgiganten (Currys plc)" data-da="COO & Bestyrelsesformand, Elkjøp Nordic / Elgiganten (Currys plc)" data-fi="COO & hallituksen puheenjohtaja, Elkjøp Nordic / Elgiganten (Currys plc)">COO & Styrelseordförande, Elkjøp Nordic / Elgiganten (Currys plc)</strong>
                  <strong class="en-text">COO & Chairman, Elkjøp Nordic / Elgiganten (Currys plc)</strong>
                  <span class="sv-text" data-no="Nordens ledende CE-kjede · 4 land · ~9 år" data-da="Nordens ledende CE-kæde · 4 lande · ~9 år" data-fi="Pohjoismaiden johtava CE-ketju · 4 maata · ~9 vuotta">Nordens ledande CE-kedja · 4 länder · ~9 år</span>
                  <span class="en-text">The Nordic region's leading CE chain · 4 countries · ~9 years</span>
                  <div class="career-awards">
                    <span class="ca-item">🏆 Best internet site Norway (2006) — Bring Awards</span>
                    <span class="ca-item">🏆 Best Contact Centre Norway (2010, 2011, 2012) — Daymaker & Confex CC</span>
                    <span class="ca-item">🏆 Best internet site Norway (2011) — Computer World</span>
                    <span class="ca-item">🏆 Best internet site Sweden (2011, 2012, 2013) — Pricerunner</span>
                    <span class="ca-item">🏆 Best internet site Denmark (2013, 2014, 2015) — Pricerunner</span>
                    <span class="ca-item">🏆 Webshop of the Year Sweden (2014, 2015) — Prisjakt</span>
                    <span class="ca-item">🏆 Best Customer Service Organisation Finland (2014)</span>
                    <span class="ca-item">🏆 Best CC Innovation of the Year (2014) — KANA Awards</span>
                    <span class="ca-item">🏆 Best Omnichannel Solution (2015/16) — RETA Europe</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ===== NETWORK ===== -->
    <div class="container">
      <div class="network-inner fade-up">
        <h2>
          <span class="sv-text" data-no="Vårt nettverk" data-da="Vores netværk" data-fi="Verkostomme">Vårt nätverk</span>
          <span class="en-text">Our network</span>
        </h2>
        <p class="sv-text" data-no="I tillegg til det faste teamet arbeider vi med et bredt nettverk av spesialister innen retail, teknologi og endringsledelse — noe som gjør at vi kan skalere opp og sette sammen nøyaktig riktig team for hvert oppdrag." data-da="Ud over det faste team arbejder vi med et bredt netværk af specialister inden for detail, teknologi og forandringsledelse — hvilket giver os mulighed for at skalere op og sammensætte præcis det rette team til hvert opdrag." data-fi="Vakituisen tiimin lisäksi työskentelemme laajan vähittäiskaupan, teknologian ja muutosjohtamisen asiantuntijaverkoston kanssa — mikä mahdollistaa juuri oikean tiimin kokoamisen kutakin toimeksiantoa varten.">Utöver det fasta teamet arbetar vi med ett brett nätverk av specialister inom retail, teknologi och förändringsledning — vilket gör att vi kan skala upp och sätta samman exakt rätt team för varje uppdrag.</p>
        <p class="en-text">Beyond the core team, we work with a broad network of specialists in retail, technology and change management — allowing us to scale quickly and assemble exactly the right team for every assignment.</p>
        <div class="competences">
          {[
            {sv:'Retail Analytics',       en:'Retail Analytics'},
            {sv:'Category Management',    en:'Category Management'},
            {sv:'Supply Chain',           en:'Supply Chain'},
            {sv:'Digital Transformation', en:'Digital Transformation'},
            {sv:'Förändringsledning',     en:'Change Management'},
            {sv:'Butiksdesign',           en:'Store Design'},
            {sv:'NPS & Kundinsikt',       en:'NPS & Customer Insight'},
            {sv:'Hållbarhet',             en:'Sustainability'},
          ].map(c => (
            <span class="competence-tag">
              <span class="sv-text">{c.sv}</span>
              <span class="en-text">{c.en}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container" style="text-align:center">
      <h2 class="fade-up">
        <span class="sv-text" data-no="Vil du jobbe med oss?" data-da="Vil du arbejde med os?" data-fi="Haluatko työskennellä kanssamme?">Vill du arbeta med oss?</span>
        <span class="en-text">Want to work with us?</span>
      </h2>
      <div class="cta-row fade-up">
        <a href="/Contact/" class="btn-cta sv-text" data-no="Kontakt oss" data-da="Kontakt os" data-fi="Ota yhteyttä">Kontakta oss</a>
        <a href="/Contact/" class="btn-cta en-text">Contact us</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-blue) 100%);
    color: var(--color-white);
    padding: 5rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-photo-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/retail/staff-tablet-shelf.jpg');
    background-size: cover;
    background-position: center 20%;
    opacity: 0.12;
    mix-blend-mode: luminosity;
  }
