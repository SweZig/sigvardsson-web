---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import SCGLogo from '../../components/SCGLogo.astro';
---
<Layout
  titleSv="Vårt team — Sigvardsson Consulting Group"
  titleEn="Our Team — Sigvardsson Consulting Group"
  descriptionSv="Möt teamet bakom Sigvardsson Consulting Group — erfarna konsulter med djup specialisering inom retail."
  descriptionEn="Meet the team behind Sigvardsson Consulting Group — experienced consultants with deep retail specialization."
  canonical="https://www.sigvardsson.org/our-people/"
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="container">
      <span class="section-label sv-text">Vårt team</span>
      <span class="section-label en-text">Our team</span>
      <h1>
        <span class="sv-text">Människorna bakom<br/>resultaten</span>
        <span class="en-text">The people behind<br/>the results</span>
      </h1>
      <p class="hero-sub sv-text">Vårt team kombinerar djup retailkompetens med analytisk skärpa och en passion för att skapa bestående förändring.</p>
      <p class="hero-sub en-text">Our team combines deep retail expertise with analytical sharpness and a passion for creating lasting change.</p>
    </div>
  </section>

  <!-- Team Grid -->
  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        <!-- Placeholder team cards - to be filled with real content -->
        {Array.from({length: 4}).map((_, i) => (
          <div class="team-card fade-up" style={`animation-delay:${i*80}ms`}>
            <div class="team-avatar">
              <SCGLogo size={56} color="navy" />
            </div>
            <div class="team-info">
              <h3 class="sv-text">Konsultnamn</h3>
              <h3 class="en-text">Consultant Name</h3>
              <p class="team-role sv-text">Roll / Titel</p>
              <p class="team-role en-text">Role / Title</p>
              <p class="team-bio sv-text">Kort beskrivning av erfarenhet och specialisering inom retail. Uppdatera med riktig biografi.</p>
              <p class="team-bio en-text">Brief description of experience and retail specialization. Update with real biography.</p>
            </div>
          </div>
        ))}
      </div>

      <div class="team-note fade-up">
        <p class="sv-text">ℹ️ <em>Teammedlemmars profilbilder och biografier uppdateras snart.</em></p>
        <p class="en-text">ℹ️ <em>Team member profile photos and biographies will be updated shortly.</em></p>
      </div>
    </div>
  </section>

  <!-- Network section -->
  <section class="network-section">
    <div class="container">
      <div class="network-inner fade-up">
        <h2>
          <span class="sv-text">Vårt nätverk</span>
          <span class="en-text">Our network</span>
        </h2>
        <p class="sv-text">Utöver det fasta teamet arbetar vi med ett brett nätverk av specialister och partners inom retail, teknologi och förändringsledning — vilket gör att vi kan skala upp snabbt och sätta samman exakt rätt team för varje uppdrag.</p>
        <p class="en-text">Beyond the core team, we work with a broad network of specialists and partners in retail, technology and change management — allowing us to scale quickly and assemble exactly the right team for every assignment.</p>

        <div class="competences">
          {[
            { sv: 'Retail Analytics', en: 'Retail Analytics' },
            { sv: 'Category Management', en: 'Category Management' },
            { sv: 'Supply Chain', en: 'Supply Chain' },
            { sv: 'Digital Transformation', en: 'Digital Transformation' },
            { sv: 'Förändringsledning', en: 'Change Management' },
            { sv: 'Butiksdesign', en: 'Store Design' },
            { sv: 'NPS & Kundinsikt', en: 'NPS & Customer Insight' },
            { sv: 'Hållbarhet', en: 'Sustainability' },
          ].map(c => (
            <span class="competence-tag">
              <span class="sv-text">{c.sv}</span>
              <span class="en-text">{c.en}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container" style="text-align:center">
      <h2 class="fade-up">
        <span class="sv-text">Vill du arbeta med oss?</span>
        <span class="en-text">Want to work with us?</span>
      </h2>
      <div class="cta-row fade-up">
        <a href="/Contact/" class="btn btn-light sv-text">Kontakta oss</a>
        <a href="/Contact/" class="btn btn-light en-text">Contact us</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
.page-hero { background:linear-gradient(135deg,var(--color-navy) 0%,var(--color-blue) 100%);color:var(--color-white);padding:5rem 2rem 4rem; }
.page-hero .section-label { color:var(--color-blue-lite); }
.page-hero h1 { font-size:clamp(2.2rem,5vw,3.5rem);line-height:1.1;margin:.75rem 0 1.25rem; }
.hero-sub { font-size:1.05rem;color:rgba(255,255,255,.75);max-width:600px;line-height:1.7; }

.team-section { padding:5rem 2rem; }
.team-grid { display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:2rem;margin-bottom:2rem; }

.team-card { background:var(--color-off-white);border-radius:16px;overflow:hidden;border:1px solid rgba(1,13,96,.08);transition:transform .25s,box-shadow .25s; }
.team-card:hover { transform:translateY(-4px);box-shadow:0 12px 32px rgba(1,13,96,.12); }

.team-avatar { background:var(--color-navy);height:180px;display:flex;align-items:center;justify-content:center; }
.avatar-placeholder { width:72px;height:72px;object-fit:contain;filter:brightness(0) invert(1);opacity:.3; }

.team-info { padding:1.5rem; }
.team-info h3 { font-size:1.05rem;color:var(--color-navy);margin-bottom:.3rem; }
.team-role { font-family:'Chakra Petch',sans-serif;font-size:.78rem;letter-spacing:.08em;color:var(--color-blue-mid);text-transform:uppercase;margin-bottom:.75rem; }
.team-bio { font-size:.875rem;color:rgba(1,13,96,.65);line-height:1.65; }

.team-note { text-align:center;padding:1rem;background:rgba(144,162,207,.12);border-radius:8px;font-size:.875rem;color:var(--color-blue-mid); }

.network-section { background:var(--color-off-white);padding:5rem 2rem; }
.network-inner { max-width:780px; }
.network-inner h2 { font-size:1.75rem;color:var(--color-navy);margin-bottom:1.25rem; }
.network-inner p { color:rgba(1,13,96,.7);line-height:1.75;margin-bottom:1.5rem; }

.competences { display:flex;flex-wrap:wrap;gap:.6rem; }
.competence-tag { background:var(--color-white);border:1px solid rgba(1,13,96,.12);border-radius:100px;padding:.35rem .9rem;font-family:'Chakra Petch',sans-serif;font-size:.78rem;font-weight:500;color:var(--color-navy-mid);letter-spacing:.04em; }

.cta-band { background:var(--color-navy);padding:4.5rem 2rem;color:var(--color-white); }
.cta-band h2 { font-size:clamp(1.5rem,3vw,2.25rem);margin-bottom:2rem; }
.cta-row { display:flex;gap:1rem;justify-content:center;flex-wrap:wrap; }
.btn-light { background:var(--color-white);color:var(--color-navy);font-family:'Chakra Petch',sans-serif;font-weight:500;padding:.75rem 2rem;border-radius:8px;font-size:.95rem;transition:all .2s;display:inline-block; }
.btn-light:hover { background:var(--color-off-white);transform:translateY(-2px); }
</style>
