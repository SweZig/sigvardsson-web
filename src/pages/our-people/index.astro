---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const team = [
  {
    name: 'Per Sigvardsson',
    title: 'CEO & Founder',
    bio: 'Per has over 30 years of experience within retail. He has worked in various leading positions in organizations as Elgiganten (Currys plc), Granngården & TOP-TOY.',
    linkedin: 'https://www.linkedin.com/in/sigvardsson/',
    specs: ['Retail Strategy'],
    initials: 'PS',
    photo: '/images/team/per-sigvardsson.jpg',
    photoPos: 'center 22%',
  },
  {
    name: 'Lars Lundqvist',
    title: 'Sales Director & Senior Consultant',
    bio: 'Lars has over 30 years of experience within retail. He has worked in various leading positions in organizations as Elgiganten (Currys plc), Media-Saturn (Ceconomy AG), XXL Sport & Villmark & TOP-TOY.',
    linkedin: 'https://www.linkedin.com/in/lars-lundqvist-9941793a/',
    specs: ['Retail Operations Excellence'],
    initials: 'LL',
    photo: '/images/team/lars-lundqvist.jpg',
    photoPos: 'center 8%',
  },
  {
    name: 'Sebastian Fauné',
    title: 'Senior Consultant',
    bio: 'Sebastian has over 25 years of experience within retail. He has worked in various leading positions in organizations as PC City (Currys plc) & Media-Saturn (Ceconomy AG).',
    linkedin: 'https://www.linkedin.com/in/sebastian-faun%C3%A9-8b76a263/',
    specs: ['Commercial Excellence'],
    initials: 'SF',
    photo: '/images/team/sebastian-faune.jpg',
    photoPos: 'center 14%',
  },
  {
    name: 'Peter Wilén',
    title: 'Senior Consultant',
    bio: 'Peter has over 25 years of experience within retail. He has worked in various leading positions in organizations as Stadium, Elgiganten (Currys plc) & Media-Saturn (Ceconomy AG).',
    linkedin: 'https://www.linkedin.com/in/peterwilen/',
    specs: ['People Development', 'Change Management'],
    initials: 'PW',
    photo: '/images/team/peter-wilen.jpg',
    photoPos: 'center 20%',
  },
  {
    name: 'Emil Sigvardsson',
    title: 'CIO',
    bio: 'Emil has been working within retail for 6 years with experience from XXL Sports & Marketing Platform.',
    linkedin: 'https://www.linkedin.com/in/emilsigvardsson/',
    specs: ['Tech'],
    initials: 'ES',
    photo: '/images/team/emil-sigvardsson.jpg',
    photoPos: 'center 2%',
  },
  {
    name: 'Felix Johansson',
    title: 'Head of Tech',
    bio: 'Felix has been working within retail for 4 years with experience from XXL Sports & Marketing Platform.',
    linkedin: 'https://www.linkedin.com/in/felix-johansson-788039135/',
    specs: ['Tech'],
    initials: 'FJ',
    photo: '/images/team/felix-johansson.jpg',
    photoPos: 'center 14%',
  },
];

const accents = ['#010D60','#1A277A','#2A4EA9','#3D4893','#4867B6','#010D60'];
---

<Layout
  titleSv="Vårt team — Sigvardsson Consulting Group"
  titleEn="Our Team — Sigvardsson Consulting Group"
  descriptionSv="Möt teamet bakom Sigvardsson Consulting Group — erfarna konsulter med sammanlagt över 150 års retail-erfarenhet."
  descriptionEn="Meet the team behind Sigvardsson Consulting Group — experienced consultants with collectively over 150 years of retail expertise."
  canonical="https://www.sigvardsson.org/our-people/"
>
  <Header slot="header" />

  <section class="page-hero">
    <div class="hero-photo-bg"></div>
    <div class="container" style="position:relative;z-index:1">
      <span class="section-label sv-text">Vårt team</span>
      <span class="section-label en-text">Our team</span>
      <h1>
        <span class="sv-text">Människorna bakom<br/>resultaten</span>
        <span class="en-text">The people behind<br/>the results</span>
      </h1>
      <p class="hero-sub sv-text">Erfarna konsulter med djup specialisering inom retail — sammanlagt över 150 års branscherfarenhet från ledande nordiska och europeiska kedjor.</p>
      <p class="hero-sub en-text">Experienced consultants with deep retail specialization — collectively over 150 years of industry experience from leading Nordic and European chains.</p>
    </div>
  </section>

  <section class="team-section">
    <div class="container">
      <div class="team-grid">
        {team.map((person, i) => (
          <article class="team-card fade-up" style={`animation-delay:${i*80}ms`}>

            <div class="team-avatar" style={`background:${accents[i]}`}>
              {person.photo
                ? <img src={person.photo} alt={person.name} class="avatar-photo" style={`object-position:${person.photoPos || 'center 8%'}`} />
                : <span class="avatar-initials">{person.initials}</span>
              }
            </div>

            <div class="team-info">
              <div class="team-header">
                <div class="team-header-text">
                  <h3 class="team-name">{person.name}</h3>
                  <p class="team-title">{person.title}</p>
                </div>
                <a
                  href={person.linkedin}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="linkedin-btn"
                  aria-label={`LinkedIn — ${person.name}`}
                >
                  <svg width="17" height="17" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                  </svg>
                </a>
              </div>

              <p class="team-bio">{person.bio}</p>

              <div class="spec-tags">
                {person.specs.map(s => (
                  <span class="spec-tag" style={`color:${accents[i]};border-color:${accents[i]}40`}>{s}</span>
                ))}
              </div>
            </div>

          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FOUNDER BIO ===== -->
  <section class="founder-bio">
    <div class="container">
      <div class="founder-inner fade-up">

        <div class="founder-portrait">
          <div class="founder-img-frame">
            <img src="/images/team/per-sigvardsson.jpg" alt="Per Sigvardsson" loading="lazy" />
          </div>
          <div class="founder-awards">
            <div class="f-award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" /></div>
            <div class="f-award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" /></div>
            <div class="f-award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" /></div>
          </div>
          <p class="f-awards-label sv-text">Global 100 Winner 2024 · 2025 · 2026</p>
          <p class="f-awards-label en-text">Global 100 Winner 2024 · 2025 · 2026</p>
        </div>

        <div class="founder-text">
          <span class="section-label sv-text">Grundare & VD</span>
          <span class="section-label en-text">Founder & CEO</span>

          <h2 class="sv-text">Per Sigvardsson</h2>
          <h2 class="en-text">Per Sigvardsson</h2>

          <div class="bio-body sv-text">
            <p>Per Sigvardsson har tillbringat mer än 30 år i toppen av nordisk detaljhandel — inte som konsult utifrån, utan som operativ ledare med fullt ansvar för resultat, organisation och förändring. Det är den erfarenheten som utgör grunden för allt Sigvardsson Consulting Group gör.</p>

            <p>Hans karriär startade inom elektronikhandeln och ledde honom till rollen som COO på <strong>Elkjøp Nordic AS</strong> (del av Currys plc) — Nordens ledande CE-kedja med verksamhet i Sverige (Elgiganten), Norge, Danmark och Finland. Under nästan ett decennium ledde Per den operativa transformationen av en av regionens mest komplexa retailorganisationer, inklusive omnikanalstrategi, systemimplementationer och butiksutveckling i stor skala.</p>

            <p>Som styrelseordförande i <strong>Elgiganten</strong> och <strong>PC City Sverige</strong> kombinerade Per det strategiska och det operativa på ett sätt som är sällsynt — han förstår hur beslut på styrelsenivå landar i butiksgolvet, och omvänt. Denna tvåvägsinblick är något han tar med sig i varje konsultuppdrag.</p>

            <p>Åren som <strong>VD för Granngården AB</strong> — en rikstäckande kedja med 108 butiker, 550 anställda och en omsättning på 1,7 miljarder kronor — adderade ytterligare ett lager: att leda en organisation genom ett internationellt ägarskifte (förvärvet av Felleskjøpet) och samtidigt hålla affärsfokus och personalengagemang intakt. Och som <strong>Group CEO för TOP-TOY A/S</strong>, Nordens ledande leksakskedja, fick Per inblick i en ny produktkategori och bevisade sin förmåga att skapa resultat i skiftande retail-kontexter.</p>

            <p>2016 grundade Per Sigvardsson Consulting Group med en tydlig övertygelse: att den bästa rådgivningen inom retail kommer från personer som har suttit i stolen själva. SCG är inte ett generellt managementkonsultbolag med en retailpraktik — det är ett specialistbolag byggt av retailledare, för retailledare.</p>

            <p>Idag leder Per ett team med sammanlagt över 150 års branscherfarenhet och en portfölj av beprövade verktyg som spänner från hylloptimering och kampanjanalys till RFID-implementation och digital prissättning. Samtliga 250+ genomförda projekt har levererat positiv ROI. Det är inte en slump — det är ett metodval.</p>
          </div>

          <div class="bio-body en-text">
            <p>Per Sigvardsson has spent more than 30 years at the top of Nordic retail — not as an outside consultant, but as an operational leader with full responsibility for results, organization and change. That experience is the foundation for everything Sigvardsson Consulting Group does.</p>

            <p>His career began in consumer electronics retail and led him to the role of COO at <strong>Elkjøp Nordic AS</strong> (part of Currys plc) — the Nordic region's leading CE chain operating in Sweden (Elgiganten), Norway, Denmark and Finland. For nearly a decade, Per led the operational transformation of one of the region's most complex retail organizations, including omnichannel strategy, system implementations and large-scale store development.</p>

            <p>As Chairman of the Board at <strong>Elgiganten</strong> and <strong>PC City Sverige</strong>, Per combined the strategic and operational in a way that is genuinely rare — he understands how board-level decisions land on the store floor, and vice versa. This two-way insight is something he brings to every consulting engagement.</p>

            <p>The years as <strong>CEO of Granngården AB</strong> — a nationwide chain with 108 stores, 550 employees and revenue of SEK 1.7 billion — added another layer: leading an organization through an international ownership change (the Felleskjøpet acquisition) while maintaining business focus and staff engagement. And as <strong>Group CEO of TOP-TOY A/S</strong>, the Nordic region's leading toy retailer, Per gained insight into a new product category and proved his ability to generate results across different retail contexts.</p>

            <p>In 2016, Per founded Sigvardsson Consulting Group with a clear conviction: that the best retail advisory comes from people who have sat in the chair themselves. SCG is not a general management consultancy with a retail practice — it is a specialist firm built by retail leaders, for retail leaders.</p>

            <p>Today Per leads a team with a combined 150+ years of industry experience and a portfolio of proven tools spanning shelf optimization, campaign analytics, RFID implementation and digital pricing. All 250+ completed projects have delivered positive ROI. That's not a coincidence — it's a methodology.</p>
          </div>

          <div class="founder-career">
            <p class="career-label sv-text">Karriärhöjdpunkter</p>
            <p class="career-label en-text">Career highlights</p>
            <div class="career-items">
              <div class="career-item">
                <span class="career-year">2016–</span>
                <div>
                  <strong class="sv-text">Grundare & VD, Sigvardsson Consulting Group</strong>
                  <strong class="en-text">Founder & CEO, Sigvardsson Consulting Group</strong>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2018–19</span>
                <div>
                  <strong class="sv-text">Group CEO, TOP-TOY A/S</strong>
                  <strong class="en-text">Group CEO, TOP-TOY A/S</strong>
                  <span class="sv-text">Nordens ledande leksakskedja</span>
                  <span class="en-text">The Nordic region's leading toy retailer</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2015–18</span>
                <div>
                  <strong class="sv-text">VD, Granngården AB</strong>
                  <strong class="en-text">CEO, Granngården AB</strong>
                  <span class="sv-text">108 butiker · 550 anställda · 1,7 mdr SEK</span>
                  <span class="en-text">108 stores · 550 employees · SEK 1.7bn</span>
                </div>
              </div>
              <div class="career-item">
                <span class="career-year">2006–15</span>
                <div>
                  <strong class="sv-text">COO & Styrelseordförande, Elkjøp Nordic / Elgiganten (Currys plc)</strong>
                  <strong class="en-text">COO & Chairman, Elkjøp Nordic / Elgiganten (Currys plc)</strong>
                  <span class="sv-text">Nordens ledande CE-kedja · 4 länder</span>
                  <span class="en-text">The Nordic region's leading CE chain · 4 countries</span>
                </div>
              </div>
            </div>
          </div>

        </div>
      </div>
    </div>
  </section>

  <!-- ===== NETWORK ===== -->
    <div class="container">
      <div class="network-inner fade-up">
        <h2>
          <span class="sv-text">Vårt nätverk</span>
          <span class="en-text">Our network</span>
        </h2>
        <p class="sv-text">Utöver det fasta teamet arbetar vi med ett brett nätverk av specialister inom retail, teknologi och förändringsledning — vilket gör att vi kan skala upp och sätta samman exakt rätt team för varje uppdrag.</p>
        <p class="en-text">Beyond the core team, we work with a broad network of specialists in retail, technology and change management — allowing us to scale quickly and assemble exactly the right team for every assignment.</p>
        <div class="competences">
          {[
            {sv:'Retail Analytics',       en:'Retail Analytics'},
            {sv:'Category Management',    en:'Category Management'},
            {sv:'Supply Chain',           en:'Supply Chain'},
            {sv:'Digital Transformation', en:'Digital Transformation'},
            {sv:'Förändringsledning',     en:'Change Management'},
            {sv:'Butiksdesign',           en:'Store Design'},
            {sv:'NPS & Kundinsikt',       en:'NPS & Customer Insight'},
            {sv:'Hållbarhet',             en:'Sustainability'},
          ].map(c => (
            <span class="competence-tag">
              <span class="sv-text">{c.sv}</span>
              <span class="en-text">{c.en}</span>
            </span>
          ))}
        </div>
      </div>
    </div>
  </section>

  <section class="cta-band">
    <div class="container" style="text-align:center">
      <h2 class="fade-up">
        <span class="sv-text">Vill du arbeta med oss?</span>
        <span class="en-text">Want to work with us?</span>
      </h2>
      <div class="cta-row fade-up">
        <a href="/Contact/" class="btn-cta sv-text">Kontakta oss</a>
        <a href="/Contact/" class="btn-cta en-text">Contact us</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  .page-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-blue) 100%);
    color: var(--color-white);
    padding: 5rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }
  .hero-photo-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/retail/staff-tablet-shelf.jpg');
    background-size: cover;
    background-position: center 20%;
    opacity: 0.12;
    mix-blend-mode: luminosity;
  }
  .page-hero .section-label { color: var(--color-blue-lite); }
  .page-hero h1 { font-size: clamp(2.2rem,5vw,3.5rem); line-height: 1.1; margin: .75rem 0 1.25rem; }
  .hero-sub { font-size: 1.05rem; color: rgba(255,255,255,.75); max-width: 620px; line-height: 1.7; }

  .team-section { padding: 5rem 2rem; }

  .team-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }

  .team-card {
    background: var(--color-white);
    border-radius: 16px;
    border: 1px solid rgba(1,13,96,.08);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform .25s ease, box-shadow .25s ease;
  }
  .team-card:hover {
    transform: translateY(-5px);
    box-shadow: 0 16px 40px rgba(1,13,96,.12);
  }

  .team-avatar {
    height: 260px;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
    position: relative;
  }

  .avatar-photo {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .avatar-initials {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 600;
    font-size: 2.5rem;
    color: rgba(255,255,255,0.85);
    letter-spacing: .06em;
    user-select: none;
  }

  .team-info {
    padding: 1.4rem;
    display: flex;
    flex-direction: column;
    gap: .85rem;
    flex: 1;
  }

  .team-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: .6rem;
  }

  .team-header-text { flex: 1; }

  .team-name {
    font-size: 1rem;
    color: var(--color-navy);
    line-height: 1.3;
    margin-bottom: .25rem;
  }

  .team-title {
    font-family: 'Chakra Petch', sans-serif;
    font-size: .72rem;
    letter-spacing: .07em;
    color: var(--color-blue-mid);
    text-transform: uppercase;
    line-height: 1.4;
  }

  .linkedin-btn {
    flex-shrink: 0;
    width: 32px;
    height: 32px;
    background: #0A66C2;
    color: white;
    border-radius: 7px;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: background .2s, transform .2s;
    margin-top: 1px;
  }
  .linkedin-btn:hover { background: #004182; transform: scale(1.1); }

  .team-bio {
    font-size: .85rem;
    color: rgba(1,13,96,.65);
    line-height: 1.7;
    flex: 1;
  }

  .spec-tags { display: flex; flex-wrap: wrap; gap: .35rem; margin-top: auto; }

  .spec-tag {
    font-family: 'Chakra Petch', sans-serif;
    font-size: .68rem;
    font-weight: 500;
    letter-spacing: .06em;
    padding: .22rem .65rem;
    border-radius: 100px;
    border: 1px solid;
    background: transparent;
  }

  /* ===== FOUNDER BIO ===== */
  .founder-bio {
    background: var(--color-off-white, #F5F6FA);
    padding: 5rem 2rem;
    border-top: 1px solid rgba(1,13,96,0.07);
  }

  .founder-inner {
    display: grid;
    grid-template-columns: 280px 1fr;
    gap: 4rem;
    align-items: flex-start;
  }

  .founder-portrait {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    position: sticky;
    top: 6rem;
  }

  .founder-img-frame {
    width: 240px;
    height: 300px;
    border-radius: 16px;
    overflow: hidden;
    box-shadow: 0 12px 40px rgba(1,13,96,0.15);
    flex-shrink: 0;
  }

  .founder-img-frame img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 15%;
    display: block;
  }

  .founder-awards {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
  }

  .f-award-wrap {
    width: 44px;
    height: 44px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .f-award-wrap img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .f-awards-label {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.65rem;
    letter-spacing: 0.08em;
    color: var(--color-blue-mid, #4867B6);
    text-align: center;
  }

  .founder-text h2 {
    font-size: clamp(1.6rem, 3vw, 2.1rem);
    color: var(--color-navy, #010D60);
    margin: 0.5rem 0 1.75rem;
  }

  .bio-body p {
    font-size: 0.93rem;
    color: rgba(1,13,96,0.72);
    line-height: 1.85;
    margin-bottom: 1.1rem;
  }

  .bio-body strong {
    font-weight: 600;
    color: var(--color-navy, #010D60);
  }

  /* Career timeline */
  .founder-career {
    margin-top: 2.5rem;
    padding-top: 2rem;
    border-top: 1px solid rgba(1,13,96,0.1);
  }

  .career-label {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-blue-lite, #90A2CF);
    margin-bottom: 1.25rem;
  }

  .career-items {
    display: flex;
    flex-direction: column;
    gap: 0;
    border-left: 2px solid rgba(42,78,169,0.2);
    padding-left: 1.5rem;
  }

  .career-item {
    display: flex;
    gap: 1rem;
    align-items: flex-start;
    padding-bottom: 1.1rem;
    position: relative;
  }

  .career-item::before {
    content: '';
    position: absolute;
    left: -1.6rem;
    top: 0.45rem;
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--color-blue, #2A4EA9);
    border: 2px solid var(--color-off-white, #F5F6FA);
    box-shadow: 0 0 0 1px var(--color-blue, #2A4EA9);
  }

  .career-year {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.72rem;
    color: var(--color-blue-mid, #4867B6);
    white-space: nowrap;
    padding-top: 0.1rem;
    min-width: 52px;
  }

  .career-item strong {
    display: block;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.82rem;
    font-weight: 500;
    color: var(--color-navy, #010D60);
    margin-bottom: 0.2rem;
  }

  .career-item span {
    font-size: 0.8rem;
    color: rgba(1,13,96,0.55);
  }

  @media (max-width: 900px) {
    .founder-inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }
    .founder-portrait {
      flex-direction: row;
      align-items: flex-start;
      flex-wrap: wrap;
      position: static;
    }
    .founder-img-frame { width: 180px; height: 220px; }
  }

  .network-section { background: var(--color-off-white); padding: 5rem 2rem; }
  .network-inner { max-width: 780px; }
  .network-inner h2 { font-size: 1.75rem; color: var(--color-navy); margin-bottom: 1.25rem; }
  .network-inner p { color: rgba(1,13,96,.7); line-height: 1.75; margin-bottom: 1.5rem; }
  .competences { display: flex; flex-wrap: wrap; gap: .6rem; }
