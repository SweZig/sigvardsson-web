---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

// Services for the dropdown
const servicesSv = [
  'Retail Optimering — Perfekt hylla',
  'Retail Optimering — Perfekt varuplacering',
  'Retail Optimering — Perfekt kampanj',
  'Retail Optimering — Perfekt kundflöde',
  'Retail Optimering — Perfekt kö',
  'Retail Optimering — Perfekt Feedback',
  'Retail Optimering — Minimera Matsvinnet',
  'Retail Optimering — Perfekt lager',
  'Teknologi — RFID & Scanning',
  'Teknologi — Digital prissättning',
  'Teknologi — Kiosk & Självbetjäning',
  'Teknologi — NPS & Kundanalys',
  'Rådgivning — Retail strategi',
  'Rådgivning — Processutveckling',
  'Rådgivning — Implementering & Förändring',
  'Rådgivning — Utbildning & Coaching',
  'Övrigt / Generell förfrågan',
];

const servicesEn = [
  'Retail Optimization — Perfect Shelf',
  'Retail Optimization — Perfect Product Placement',
  'Retail Optimization — Perfect Campaign',
  'Retail Optimization — Perfect Customer Flow',
  'Retail Optimization — Perfect Queue',
  'Retail Optimization — Perfect Feedback',
  'Retail Optimization — Minimize Food Waste',
  'Retail Optimization — Perfect Inventory',
  'Technology — RFID & Scanning',
  'Technology — Digital Pricing',
  'Technology — Kiosk & Self-Service',
  'Technology — NPS & Customer Analytics',
  'Advisory — Retail Strategy',
  'Advisory — Process Development',
  'Advisory — Implementation & Change',
  'Advisory — Training & Coaching',
  'Other / General inquiry',
];
---

<Layout
  titleSv="Kontakt — Sigvardsson Consulting Group"
  titleEn="Contact — Sigvardsson Consulting Group"
  descriptionSv="Kontakta Sigvardsson Consulting Group för att diskutera hur vi kan hjälpa er att öka lönsamheten i er retailverksamhet."
  descriptionEn="Contact Sigvardsson Consulting Group to discuss how we can help you increase profitability in your retail operation."
  canonical="https://www.sigvardsson.org/Contact/"
>
  <Header slot="header" />

  <section class="contact-hero">
    <div class="hero-photo-bg"></div>
    <div class="container" style="position:relative;z-index:1">
      <span class="section-label sv-text" data-no="Kontakt" data-da="Kontakt" data-fi="Yhteystiedot">Kontakt</span>
      <span class="section-label en-text">Contact</span>
      <h1>
        <span class="sv-text" data-no="La oss snakke<br/>retail" data-da="Lad os tale<br/>detail" data-fi="Puhutaan<br/>kaupasta">Låt oss prata<br/>retail</span>
        <span class="en-text">Let's talk<br/>retail</span>
      </h1>
      <p class="hero-sub sv-text" data-no="Alle prosjekter har umiddelbar effekt og ROI. Kontakt oss for å diskutere hvordan vi kan hjelpe nettopp dere." data-da="Alle projekter har øjeblikkelig effekt og ROI. Kontakt os for at diskutere, hvordan vi kan hjælpe netop jer." data-fi="Kaikilla projekteilla on välitön vaikutus ja ROI. Ota yhteyttä keskustellaksesi siitä, miten voimme auttaa juuri teitä.">Samtliga projekt har omedelbar effekt och ROI. Kontakta oss för att diskutera hur vi kan hjälpa just er.</p>
      <p class="hero-sub en-text">All projects have immediate impact and ROI. Contact us to discuss how we can help your specific situation.</p>
    </div>
  </section>

  <section class="contact-body">
    <div class="container contact-grid">

      <!-- Contact Form -->
      <div class="contact-form-wrap fade-up">
        <h2 class="sv-text" data-no="Send en melding" data-da="Send en besked" data-fi="Lähetä viesti">Skicka ett meddelande</h2>
        <h2 class="en-text">Send a message</h2>

        <div class="form-success" id="formSuccess">
          <div class="success-icon">✓</div>
          <h3 class="sv-text" data-no="Melding sendt!" data-da="Besked sendt!" data-fi="Viesti lähetetty!">Meddelande skickat!</h3>
          <h3 class="en-text">Message sent!</h3>
          <p class="sv-text" data-no="Takk for meldingen din. Vi svarer vanligvis innen 24 timer." data-da="Tak for din besked. Vi svarer normalt inden for 24 timer." data-fi="Kiitos viestistäsi. Vastaamme yleensä 24 tunnin kuluessa.">Tack för ditt meddelande. Vi återkommer vanligtvis inom 24 timmar.</p>
          <p class="en-text">Thank you for your message. We usually respond within 24 hours.</p>
        </div>

        <form class="contact-form" id="contactForm" action="https://formspree.io/f/mldnjqdv" method="POST">
          <input type="hidden" name="_subject" value="Ny kontaktförfrågan — sigvardsson.org" />
          <!-- Honeypot: hidden from humans, bots fill it in — submission rejected client-side -->
          <input type="text" id="website" name="_honey" style="display:none" tabindex="-1" autocomplete="off" />
          <!-- Tell Formspree to also filter spam server-side -->
          <input type="hidden" name="_captcha" value="false" />

          <div class="form-row">
            <div class="form-group">
              <label class="sv-text" for="name" data-no="Navn" data-da="Navn" data-fi="Nimi">Namn</label>
              <label class="en-text" for="name">Name</label>
              <input type="text" id="name" name="name" required placeholder="Anna Andersson" />
            </div>
            <div class="form-group">
              <label class="sv-text" for="company" data-no="Selskap" data-da="Virksomhed" data-fi="Yritys">Företag</label>
              <label class="en-text" for="company">Company</label>
              <input type="text" id="company" name="company" placeholder="Ditt företag" />
            </div>
          </div>

          <div class="form-group">
            <label for="email">Email</label>
            <input type="email" id="email" name="email" required placeholder="anna@foretag.se" />
          </div>

          <div class="form-group">
            <label class="sv-text" for="service" data-no="Tjeneste / Interesse" data-da="Ydelse / Interesse" data-fi="Palvelu / Kiinnostus">Tjänst / Intresse</label>
            <label class="en-text" for="service">Service / Interest</label>
            <select id="service" name="service">
              <option value="">Välj tjänst / Select service...</option>
              {servicesSv.map((svc) => (
                <option value={svc}>{svc}</option>
              ))}
            </select>
          </div>

          <div class="form-group">
            <label class="sv-text" for="message" data-no="Melding" data-da="Besked" data-fi="Viesti">Meddelande</label>
            <label class="en-text" for="message">Message</label>
            <textarea id="message" name="message" rows="5" placeholder="Berätta om era utmaningar och vad ni vill uppnå..."></textarea>
          </div>

          <button type="submit" class="btn btn-primary submit-btn" id="submitBtn">
            <span class="btn-text sv-text" data-no="Send melding" data-da="Send besked" data-fi="Lähetä viesti">Skicka meddelande</span>
            <span class="btn-text en-text">Send message</span>
            <span class="btn-loading" style="display:none">⟳</span>
          </button>
        </form>
      </div>

      <!-- Contact Info -->
      <div class="contact-info fade-up" style="animation-delay:120ms">
        <div class="info-card">
          <img src="/images/logos/S_blue.png" alt="SCG" class="info-logo" width="48" height="48" />
          <h3>Sigvardsson Consulting Group</h3>
          <p>Beckholmen 526</p>
          <p>115 21 Stockholm</p>
          <p class="sv-text" data-no="Sverige" data-da="Sverige" data-fi="Ruotsi">Sverige</p>
          <p class="en-text">Sweden</p>
          <!-- Email obfuscated — assembled by JS to prevent harvesting by bots -->
          <a href="#" class="info-email" id="contact-email-link">
            <span id="contact-email-display">&#x69;&#x6E;&#x66;&#x6F;&#x40;&#x73;&#x69;&#x67;&#x76;&#x61;&#x72;&#x64;&#x73;&#x73;&#x6F;&#x6E;&#x2E;&#x6F;&#x72;&#x67;</span>
          </a>
        </div>

        <div class="awards-info">
          <p class="awards-title sv-text" data-no="Utmerkelser" data-da="Udmærkelser" data-fi="Palkinnot">Utmärkelser</p>
          <p class="awards-title en-text">Awards</p>
          <div class="awards-row">
            <div class="contact-award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" class="info-award" /></div>
            <div class="contact-award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" class="info-award" /></div>
            <div class="contact-award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" class="info-award" /></div>
          </div>
          <p class="awards-desc sv-text" data-no="Global 100 Winner 2024, 2025 & 2026" data-da="Global 100 Winner 2024, 2025 & 2026" data-fi="Global 100 Winner 2024, 2025 & 2026">Global 100 Winner 2024, 2025 & 2026</p>
          <p class="awards-desc en-text">Global 100 Winner 2024, 2025 & 2026</p>
        </div>

        <div class="quick-links">
          <p class="sv-text" style="font-family:'Chakra Petch',sans-serif;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-blue-mid);margin-bottom:0.75rem" data-no="Hurtiglenker" data-da="Hurtiglinks" data-fi="Pikalinkit">Snabblänkar</p>
          <p class="en-text" style="font-family:'Chakra Petch',sans-serif;font-size:0.8rem;letter-spacing:0.1em;text-transform:uppercase;color:var(--color-blue-mid);margin-bottom:0.75rem">Quick links</p>
          <div style="display:flex;flex-direction:column;gap:0.4rem">
            <a href="/services/" class="quick-link sv-text" data-no="→ Våre tjenester" data-da="→ Vores ydelser" data-fi="→ Palvelumme">→ Våra tjänster</a>
            <a href="/services/" class="quick-link en-text">→ Our services</a>
            <a href="/our-process/" class="quick-link sv-text" data-no="→ Vår tilnærming" data-da="→ Vores tilgang" data-fi="→ Lähestymistapamme">→ Vår approach</a>
            <a href="/our-process/" class="quick-link en-text">→ Our Approach</a>
            <a href="/our-people/" class="quick-link sv-text" data-no="→ Vårt team" data-da="→ Vores team" data-fi="→ Tiimimme">→ Vårt team</a>
            <a href="/our-people/" class="quick-link en-text">→ Our team</a>
          </div>
        </div>
      </div>

    </div>
  </section>

  <Footer slot="footer" />

  <script is:inline>
    // Email obfuscation — assembles mailto in browser only, never in static HTML
    (function() {
      var u = 'info';
      var d = 'sigvardsson.org';
      var el = document.getElementById('contact-email-link');
      if (el) el.href = 'mailto:' + u + '@' + d;
    })();

    const form = document.getElementById('contactForm');
    const success = document.getElementById('formSuccess');
    const submitBtn = document.getElementById('submitBtn');

    if (form) {
      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        // Honeypot — bots fill hidden fields, humans don't
        if (form.querySelector('#website') && form.querySelector('#website').value) return;

        const btnText = submitBtn.querySelectorAll('.btn-text');
        const spinner = submitBtn.querySelector('.btn-loading');
        submitBtn.disabled = true;
        btnText.forEach(el => el.style.display = 'none');
        spinner.style.display = 'inline-block';

        try {
          const res = await fetch(form.action, {
            method: 'POST',
            body: new FormData(form),
            headers: { 'Accept': 'application/json' }
          });
          if (res.ok) {
            form.style.display = 'none';
            success.classList.add('visible');
          } else {
            throw new Error('Server error');
          }
        } catch {
          btnText.forEach(el => el.style.display = '');
          spinner.style.display = 'none';
          submitBtn.disabled = false;
          alert('Det gick inte att skicka. Försök igen eller kontakta oss direkt.');
        }
      });
    }
  </script>
</Layout>

<style>
  .hidden { display: none; }

  .contact-hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-blue) 100%);
    color: var(--color-white);
    padding: 5rem 2rem 4rem;
    position: relative;
    overflow: hidden;
  }

  .hero-photo-bg {
    position: absolute;
    inset: 0;
    background-image: url('/images/retail/self-checkout-ica.jpg');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.10;
    mix-blend-mode: luminosity;
  }

  .contact-hero .section-label { color: var(--color-blue-lite); }

  .contact-hero h1 {
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.1;
    margin: 0.75rem 0 1.25rem;
  }

  .hero-sub {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.75);
    max-width: 540px;
    line-height: 1.7;
  }

  .contact-body { padding: 5rem 2rem; }

  .contact-grid {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 4rem;
    align-items: start;
  }

  /* Form */
  .contact-form-wrap h2 {
    font-size: 1.5rem;
    color: var(--color-navy);
    margin-bottom: 2rem;
  }

  .contact-form { display: flex; flex-direction: column; gap: 1.25rem; }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.25rem;
  }

  .form-group {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  label {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.8rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--color-navy-mid);
  }

  input, select, textarea {
    font-family: 'Nunito', sans-serif;
    font-weight: 300;
    font-size: 0.95rem;
    color: var(--color-navy);
    background: var(--color-off-white);
    border: 1px solid rgba(1,13,96,0.15);
    border-radius: 8px;
    padding: 0.75rem 1rem;
    transition: border-color 0.2s, box-shadow 0.2s;
    outline: none;
    width: 100%;
  }

  input:focus, select:focus, textarea:focus {
    border-color: var(--color-blue);
    box-shadow: 0 0 0 3px rgba(42,78,169,0.1);
  }

  textarea { resize: vertical; min-height: 140px; }

  .submit-btn {
    width: 100%;
    text-align: center;
    padding: 0.9rem;
    font-size: 1rem;
    margin-top: 0.5rem;
    transition: all 0.2s;
  }

  .submit-btn:disabled { opacity: 0.7; cursor: not-allowed; }

  .btn-loading { display: inline-block; animation: spin 0.8s linear infinite; font-size: 1.2rem; }
  @keyframes spin { to { transform: rotate(360deg); } }

  .form-success {
    display: none;
    text-align: center;
    padding: 3rem 2rem;
    background: var(--color-off-white);
    border-radius: 16px;
    border: 1px solid rgba(42,78,169,0.15);
  }

  .form-success.visible { display: block; }

  .success-icon {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    background: var(--color-navy);
    color: #fff;
    font-size: 1.75rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.25rem;
  }

  .form-success h3 {
    font-size: 1.4rem;
    color: var(--color-navy);
    margin-bottom: 0.75rem;
  }

  .form-success p {
    color: rgba(1,13,96,0.65);
    line-height: 1.7;
  }

  /* Info */
  .info-card {
    background: var(--color-off-white);
    border-radius: 16px;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .info-logo {
    width: 48px;
    height: 48px;
    object-fit: contain;
    margin-bottom: 1rem;
    opacity: 0.8;
  }

  .info-card h3 {
    font-size: 1rem;
    color: var(--color-navy);
    margin-bottom: 0.4rem;
  }

  .info-card p {
    font-size: 0.875rem;
    color: var(--color-blue-mid);
    margin-bottom: 0.75rem;
  }

  .info-email {
    font-size: 0.9rem;
    color: var(--color-blue);
    text-decoration: none;
    font-weight: 300;
  }

  .info-email:hover { text-decoration: underline; }

  .awards-info {
    background: var(--color-navy);
    border-radius: 16px;
    padding: 1.75rem;
    margin-bottom: 1.5rem;
  }

  .awards-title {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.78rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--color-blue-lite);
    margin-bottom: 1rem;
  }

  .awards-row {
    display: flex;
    gap: 0.6rem;
    margin-bottom: 0.75rem;
    align-items: center;
  }

  .contact-award-wrap {
    width: 52px;
    height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .info-award {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  .awards-desc {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.55);
  }

  .quick-links {
    background: var(--color-off-white);
    border-radius: 16px;
    padding: 1.75rem;
  }

  .quick-link {
    font-size: 0.875rem;
    color: var(--color-blue);
    transition: color 0.2s;
  }

  .quick-link:hover { color: var(--color-navy); }

  @media (max-width: 900px) {
    .contact-grid { grid-template-columns: 1fr; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>
