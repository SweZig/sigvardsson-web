---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const canonical = 'https://www.sigvardsson.org/products/perfekt-hylla/';

const objectives = [
  {
    color: 'green',
    icon: '📈',
    titleSv: 'Öka försäljningen',
    titleEn: 'Increase sales',
    descSv: 'Bestsellers fram i ögonhöjd. Säkra att kunden hittar det hen söker — snabbt.',
    descEn: 'Bestsellers at eye level. Make sure customers find what they want — fast.',
    effect: '4–15%',
    effectLabelSv: 'försäljningsväxt',
    effectLabelEn: 'sales growth',
  },
  {
    color: 'blue',
    icon: '💎',
    titleSv: 'Öka bruttomarginalen',
    titleEn: 'Increase gross margin',
    descSv: 'Premium- och högmarginal-produkter i bästa positionerna. Öka marginalen utan att tappa volym.',
    descEn: 'Premium and high-margin products in the best positions. Grow margin without losing volume.',
    effect: '10–20%',
    effectLabelSv: 'marginaltillväxt',
    effectLabelEn: 'margin growth',
  },
  {
    color: 'yellow',
    icon: '🛒',
    titleSv: 'Öka antal sålda & trafik',
    titleEn: 'Increase items sold & traffic',
    descSv: 'Produkter som drar kunden in i kategorin. Bygg volym och korsförsäljning där det räknas.',
    descEn: 'Products that pull customers into the category. Build volume and cross-sales where it counts.',
    effect: 'Volym',
    effectLabelSv: '& korsförsäljning',
    effectLabelEn: '& cross-sales',
  },
];

const modes = [
  {
    num: '01',
    titleSv: 'Endast POS-data',
    titleEn: 'POS data only',
    descSv: 'AI:n analyserar realtid POS-data och optimerar hyllan utan att ett planogram behöver finnas. Snabbast att komma igång, lägst tröskel.',
    descEn: 'AI analyzes real-time POS data and optimizes the shelf without requiring a planogram. Fastest to get started, lowest threshold.',
    bestForSv: 'Butiker som vill ha snabbt startsteg eller saknar planogram',
    bestForEn: 'Stores that want a fast start or have no planogram',
    icon: '📊',
  },
  {
    num: '02',
    titleSv: 'POS-data + befintligt planogram',
    titleEn: 'POS data + existing planogram',
    descSv: 'Ni kopplar ert befintliga planogram och AI:n optimerar det baserat på faktiskt säljutfall. Strukturen bevaras, men varje SKU mäts och rekommenderas.',
    descEn: 'You connect your existing planogram and the AI optimizes it based on actual sales performance. Structure is preserved, but every SKU is measured and rated.',
    bestForSv: 'Kedjor som redan arbetar planogramatiskt och vill lyfta effekten',
    bestForEn: 'Chains already working with planograms who want to lift performance',
    icon: '📐',
  },
  {
    num: '03',
    titleSv: 'Fotoidentifiering bygger planogrammet',
    titleEn: 'Photo recognition builds the planogram',
    descSv: 'Saknar ni planogram, eller är det ofullständigt? Fotoidentifiering scannar hyllan och genererar ett komplett digitalt planogram automatiskt — som sedan driver optimering och varupåfyllnad utifrån sell-out.',
    descEn: 'No planogram, or only partial coverage? Photo recognition scans the shelf and auto-generates a complete digital planogram — which then drives optimization and replenishment based on sell-out.',
    bestForSv: 'Kedjor med ofullständigt eller manuellt underhållet planogram',
    bestForEn: 'Chains with incomplete or manually maintained planograms',
    icon: '📸',
  },
];

const techFeatures = [
  {
    icon: '🤖',
    titleSv: 'AI-driven analys',
    titleEn: 'AI-driven analysis',
    descSv: 'Avancerade algoritmer kombinerar realtid POS-data med in-store scanning. Mönster som ingen människa hinner se.',
    descEn: 'Advanced algorithms combine real-time POS data with in-store scanning. Patterns no human could spot in time.',
  },
  {
    icon: '🧪',
    titleSv: 'Systematisk A-B-testning',
    titleEn: 'Systematic A-B testing',
    descSv: 'Vi gissar inte — vi mäter. Varje konfiguration testas mot ett alternativ tills försäljningen avgör vinnaren.',
    descEn: 'We don\'t guess — we measure. Every configuration is tested against an alternative until sales decide the winner.',
  },
  {
    icon: '⏱',
    titleSv: 'Realtidsövervakning',
    titleEn: 'Real-time monitoring',
    descSv: 'Varje hylla mäts kontinuerligt direkt i mobilen. Förlorad försäljning idag går inte att ta tillbaka imorgon.',
    descEn: 'Every shelf is measured continuously, directly in the mobile app. Lost sales today can\'t be recovered tomorrow.',
  },
  {
    icon: '🎨',
    titleSv: 'Visuella färgkoder',
    titleEn: 'Visual colour codes',
    descSv: 'Vem som helst i butiken kan agera. Grönt, blått eller gult — beslutet syns direkt utan att tolka rådata.',
    descEn: 'Anyone in the store can act. Green, blue or yellow — the decision is visible without parsing raw data.',
  },
  {
    icon: '📱',
    titleSv: 'Installeras på en smartphone',
    titleEn: 'Installs on any smartphone',
    descSv: 'Ingen specialhårdvara, inget IT-projekt. Krypterad data, säker installation, fungerar på vilken enhet som helst.',
    descEn: 'No special hardware, no IT project. Encrypted data, secure installation, runs on any device.',
  },
  {
    icon: '📊',
    titleSv: 'Mäts på tre KPI:er',
    titleEn: 'Measured on three KPIs',
    descSv: 'Försäljning, kvantitet och bruttomarginal — per hylla, per kategori, per butik. Inga undanflykter.',
    descEn: 'Sales, quantity and gross profit — per shelf, per category, per store. No place to hide.',
  },
];

const schemaProduct = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  "name": "Perfekt hylla",
  "applicationCategory": "BusinessApplication",
  "description": "Perfekt hylla är ett AI-drivet verktyg för hylloptimering i retail. Kombinerar realtid POS-data med in-store scanning och systematisk A-B-testning för att maximera försäljning och marginal.",
  "operatingSystem": "Web, iOS, Android",
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" },
  "provider": {
    "@type": "Organization",
    "@id": "https://www.sigvardsson.org/#organization",
    "name": "Sigvardsson Consulting Group"
  },
  "url": canonical
};
---

<Layout
  titleSv="Perfekt hylla — AI-driven hylloptimering | Sigvardsson Consulting Group"
  titleEn="Perfect Shelf — AI-driven shelf optimization | Sigvardsson Consulting Group"
  descriptionSv="75% av butikens omsättning kommer från hyllorna. Perfekt hylla kombinerar AI, realtid POS-data och systematisk A-B-testning för att maximera försäljning och marginal. Minimum 2% försäljningsökning — garanterat."
  descriptionEn="75% of store revenue comes from the shelves. Perfect Shelf combines AI, real-time POS data and systematic A-B testing to maximize sales and margin. Minimum 2% sales increase — guaranteed."
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="ph-hero">
    <div class="ph-hero-bg"></div>
    <div class="ph-hero-grid"></div>
    <div class="container ph-hero-inner">
      <div class="powered-by">
        <span class="sv-text">En tjänst från</span>
        <span class="en-text">A service by</span>
        <a href="/" class="powered-link">Sigvardsson Consulting Group</a>
        <span class="separator">·</span>
        <span class="sv-text">I partnerskap med</span>
        <span class="en-text">In partnership with</span>
        <a href="/products/link-retail/" class="powered-link powered-lr">
          <span class="lr-mini-badge">LR</span> Link Retail
        </a>
      </div>

      <div class="ph-hero-headline">
        <span class="ph-hero-stat">75 %</span>
        <h1>
          <span class="sv-text">av butikens omsättning kommer från hyllorna.</span>
          <span class="en-text">of store revenue comes from the shelves.</span>
        </h1>
        <p class="ph-hero-sub sv-text">När optimerade du dem senast?</p>
        <p class="ph-hero-sub en-text">When did you last optimize them?</p>
      </div>

      <div class="ph-hero-tagline">
        <span class="sv-text"><strong>Perfekt hylla</strong> — AI-driven hylloptimering byggd på 15 års erfarenhet och realtidsdata från kassasystem och scanning.</span>
        <span class="en-text"><strong>Perfect Shelf</strong> — AI-driven shelf optimization built on 15 years of experience and real-time data from POS and scanning.</span>
      </div>

      <div class="ph-hero-pills">
        <div class="ph-pill"><strong>+2 %</strong><span class="sv-text">garanterad min. försäljningsökning</span><span class="en-text">guaranteed min. sales increase</span></div>
        <div class="ph-pill"><strong>4–15 %</strong><span class="sv-text">typisk försäljningsväxt</span><span class="en-text">typical sales growth</span></div>
        <div class="ph-pill"><strong>100+</strong><span class="sv-text">genomförda projekt</span><span class="en-text">completed projects</span></div>
      </div>

      <div class="ph-hero-actions">
        <a href="/Contact/" class="btn-ph-primary sv-text">Boka demo</a>
        <a href="/Contact/" class="btn-ph-primary en-text">Book a demo</a>
        <a href="#how" class="btn-ph-ghost sv-text">Så fungerar det ↓</a>
        <a href="#how" class="btn-ph-ghost en-text">How it works ↓</a>
      </div>

      <div class="ph-service-link">
        <span class="sv-text">Levereras som tjänst inom</span>
        <span class="en-text">Delivered as a service within</span>
        <a href="/services/tjanster/perfekt-hylla/" class="ph-service-link-href sv-text">Retail Optimering → Perfekt hylla</a>
        <a href="/services/tjanster/perfekt-hylla/" class="ph-service-link-href en-text">Retail Optimization → Perfect Shelf</a>
      </div>
    </div>
  </section>

  <!-- ===== VISUAL BAND ===== -->
  <section class="ph-visual">
    <div class="container">
      <div class="ph-visual-inner">
        <div class="ph-visual-img fade-up">
          <img src="/images/services/shelf-scanning.jpg" alt="Butiksmedarbetare scannar hylla med mobilen" loading="lazy" />
          <div class="ph-visual-img-frame"></div>
        </div>
        <div class="ph-visual-text fade-up" style="animation-delay:120ms">
          <span class="ph-label sv-text">Mobil först. I butiken. I realtid.</span>
          <span class="ph-label en-text">Mobile first. In-store. Real time.</span>
          <h2 class="sv-text">En sluten loop mellan <em>kassa, hylla och beslut</em>.</h2>
          <h2 class="en-text">A closed loop between <em>POS, shelf and decision</em>.</h2>
          <p class="sv-text">POS-systemet matar AI-motorn med varje transaktion i realtid. Bildigenkänning från butikens smartphones läser hyllans faktiska tillstånd — planogramefterlevnad, exponering, out-of-stock. Algoritmen jämför vad som säljs mot vad som syns och returnerar konkreta åtgärder per facing, per hylla, per butik. Hela kedjan från transaktion till rekommendation körs utan extern hårdvara och utan IT-projekt — beslutscykeln går från kvartalsrapport till arbetspass.</p>
          <p class="en-text">The POS system feeds the AI engine with every transaction in real time. Image recognition from store smartphones reads the shelf's actual state — planogram compliance, exposure, out-of-stock. The algorithm compares what's selling against what's visible and returns concrete actions per facing, per shelf, per store. The full chain from transaction to recommendation runs without external hardware and without an IT project — the decision cycle shrinks from quarterly report to single shift.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== TWO QUESTIONS ===== -->
  <section class="ph-section ph-section-light">
    <div class="container">
      <div class="section-intro fade-up">
        <span class="ph-label sv-text">Två frågor varje hylla måste svara på</span>
        <span class="ph-label en-text">Two questions every shelf must answer</span>
        <h2>
          <span class="sv-text">Hylla är inte inredning. Hylla är försäljning.</span>
          <span class="en-text">Shelves aren't furniture. Shelves are sales.</span>
        </h2>
        <p class="sv-text">De flesta hyllor är överlastade med för många artiklar på för lite plats. Synligheten per produkt sjunker. Försäljningen per SKU sjunker. Det enda som ökar är komplexiteten för butikspersonalen.</p>
        <p class="en-text">Most shelves are overloaded with too many SKUs in too little space. Visibility per product drops. Sales per SKU drop. The only thing that grows is the complexity for store staff.</p>
      </div>
      <div class="ph-questions">
        <div class="ph-question fade-up">
          <span class="ph-q-num">01</span>
          <h3 class="sv-text">Range — rätt antal SKU?</h3>
          <h3 class="en-text">Range — the right number of SKUs?</h3>
          <p class="sv-text">Vilket är det perfekta antalet artiklar i den här hyllan? För många och kunden tappar fokus. För få och du tappar försäljning. Det rätta svaret kan bara hittas i datan.</p>
          <p class="en-text">What is the perfect number of items in this shelf? Too many and customers lose focus. Too few and you lose sales. The right answer only emerges from data.</p>
        </div>
        <div class="ph-question fade-up" style="animation-delay:120ms">
          <span class="ph-q-num">02</span>
          <h3 class="sv-text">Merchandising — hur exponeras de?</h3>
          <h3 class="en-text">Merchandising — how are they displayed?</h3>
          <p class="sv-text">Det finns ett oändligt antal sätt att presentera samma sortiment. Vissa säljer. De flesta gör det inte. Vilken konfiguration vinner — och varför?</p>
          <p class="en-text">There are infinite ways to present the same assortment. Some sell. Most don't. Which configuration wins — and why?</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== THREE OBJECTIVES ===== -->
  <section class="ph-section ph-section-dark">
    <div class="container">
      <div class="section-intro section-intro-light fade-up">
        <span class="ph-label ph-label-light sv-text">Tre målbilder. Tre färger.</span>
        <span class="ph-label ph-label-light en-text">Three objectives. Three colours.</span>
        <h2>
          <span class="sv-text">Innan vi rör hyllan måste vi veta vad vi optimerar för.</span>
          <span class="en-text">Before touching the shelf, we need to know what we're optimizing for.</span>
        </h2>
        <p class="sv-text">Varje hylla kan optimeras för tre olika mål — och de kan stå i konflikt med varandra. Vår dashboard färgkodar varje hylla efter dess mål, så att butikschefen ser direkt i mobilen vad som gäller och vilken åtgärd som rekommenderas.</p>
        <p class="en-text">Every shelf can be optimized for three different goals — and they can conflict with each other. Our dashboard colour-codes each shelf by its objective, so the store manager sees instantly in the mobile app what applies and which action is recommended.</p>
      </div>

      <div class="ph-objectives">
        {objectives.map((o, i) => (
          <div class={`ph-obj ph-obj-${o.color} fade-up`} style={`animation-delay:${i*100}ms`}>
            <div class="ph-obj-icon">{o.icon}</div>
            <h3>
              <span class="sv-text">{o.titleSv}</span>
              <span class="en-text">{o.titleEn}</span>
            </h3>
            <p>
              <span class="sv-text">{o.descSv}</span>
              <span class="en-text">{o.descEn}</span>
            </p>
            <div class="ph-obj-effect">
              <strong>{o.effect}</strong>
              <span class="sv-text">{o.effectLabelSv}</span>
              <span class="en-text">{o.effectLabelEn}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== THREE MODES ===== -->
  <section class="ph-section ph-section-modes">
    <div class="container">
      <div class="section-intro fade-up">
        <span class="ph-label sv-text">Tre sätt att använda Perfekt hylla</span>
        <span class="ph-label en-text">Three ways to use Perfect Shelf</span>
        <h2>
          <span class="sv-text">Anpassar sig efter er data — inte tvärtom.</span>
          <span class="en-text">Adapts to your data — not the other way around.</span>
        </h2>
        <p class="sv-text">Perfekt hylla är inte en lösning som kräver att allt redan är på plats. Tre arbetssätt täcker hela spektrumet — från butiker utan planogram till etablerade kedjor med befintliga planogramflöden, och allt däremellan.</p>
        <p class="en-text">Perfect Shelf isn't a solution that demands everything is already in place. Three working modes cover the full spectrum — from stores without a planogram to established chains with mature planogram processes, and everything in between.</p>
      </div>

      <div class="ph-modes">
        {modes.map((m, i) => (
          <div class="ph-mode fade-up" style={`animation-delay:${i*120}ms`}>
            <div class="ph-mode-head">
              <span class="ph-mode-num">{m.num}</span>
              <span class="ph-mode-icon">{m.icon}</span>
            </div>
            <h3>
              <span class="sv-text">{m.titleSv}</span>
              <span class="en-text">{m.titleEn}</span>
            </h3>
            <p>
              <span class="sv-text">{m.descSv}</span>
              <span class="en-text">{m.descEn}</span>
            </p>
            <div class="ph-mode-best">
              <span class="ph-mode-best-label sv-text">Passar bäst för</span>
              <span class="ph-mode-best-label en-text">Best for</span>
              <span class="ph-mode-best-text sv-text">{m.bestForSv}</span>
              <span class="ph-mode-best-text en-text">{m.bestForEn}</span>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== HOW IT WORKS ===== -->
  <section id="how" class="ph-section ph-section-light">
    <div class="container">
      <div class="section-intro fade-up">
        <span class="ph-label sv-text">Så fungerar tekniken</span>
        <span class="ph-label en-text">How the technology works</span>
        <h2>
          <span class="sv-text">Mät. Lär. Ligg steget före.</span>
          <span class="en-text">Measure. Learn. Stay ahead.</span>
        </h2>
        <p class="sv-text">Perfekt hylla är inte ett rapporteringsverktyg. Det är en optimerings-motor som lär sig din butik, testar förändringar och visar exakt vad som ska göras härnäst.</p>
        <p class="en-text">Perfect Shelf isn't a reporting tool. It's an optimization engine that learns your store, tests changes and shows exactly what to do next.</p>
      </div>

      <div class="ph-tech-grid">
        {techFeatures.map((f, i) => (
          <div class="ph-tech-card fade-up" style={`animation-delay:${i*60}ms`}>
            <div class="ph-tech-icon">{f.icon}</div>
            <h3>
              <span class="sv-text">{f.titleSv}</span>
              <span class="en-text">{f.titleEn}</span>
            </h3>
            <p>
              <span class="sv-text">{f.descSv}</span>
              <span class="en-text">{f.descEn}</span>
            </p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== RESULTS / PROOF ===== -->
  <section class="ph-section ph-section-proof">
    <div class="container">
      <div class="ph-proof-inner">
        <div class="ph-proof-text fade-up">
          <span class="ph-label sv-text">Bevisad effekt</span>
          <span class="ph-label en-text">Proven impact</span>
          <h2>
            <span class="sv-text">Du kan inte ta tillbaka förlorad försäljning.</span>
            <span class="en-text">You can never take back lost sales.</span>
          </h2>
          <p class="sv-text">Det är därför realtidsövervakning är viktigare än kvartalsrapporten. När butikschefen ser på sin telefon att en hylla underpresterar idag kan beslutet fattas idag — inte vid nästa månadsmöte.</p>
          <p class="en-text">That's why real-time monitoring beats the quarterly report. When the store manager sees on their phone that a shelf is underperforming today, the decision happens today — not at next month's meeting.</p>

          <div class="ph-proof-stats">
            <div class="ph-stat-row">
              <span class="ph-stat-num">+2 %</span>
              <div>
                <strong class="sv-text">Garanterad miniminivå</strong>
                <strong class="en-text">Guaranteed minimum</strong>
                <span class="sv-text">Link Retail garanterar minst 2 % försäljningsökning vid implementation.</span>
                <span class="en-text">Link Retail guarantees at least 2% sales increase at implementation.</span>
              </div>
            </div>
            <div class="ph-stat-row">
              <span class="ph-stat-num">4–15 %</span>
              <div>
                <strong class="sv-text">Typisk försäljningsväxt</strong>
                <strong class="en-text">Typical sales growth</strong>
                <span class="sv-text">Vad de flesta projekt landar på i praktiken — beroende på utgångsläge.</span>
                <span class="en-text">What most projects actually deliver — depending on the starting point.</span>
              </div>
            </div>
            <div class="ph-stat-row">
              <span class="ph-stat-num">100+</span>
              <div>
                <strong class="sv-text">Genomförda projekt</strong>
                <strong class="en-text">Completed projects</strong>
                <span class="sv-text">Bland Nordens mest krävande dagligvaru- och retailaktörer.</span>
                <span class="en-text">Among the Nordic region's most demanding grocery and retail operators.</span>
              </div>
            </div>
          </div>

          <div class="ph-clients">
            <span class="ph-clients-label sv-text">Referenskunder</span>
            <span class="ph-clients-label en-text">Reference clients</span>
            <div class="ph-client-pills">
              <span class="ph-client-pill">NorgesGruppen Kiwi</span>
              <span class="ph-client-pill">NorgesGruppen Meny</span>
              <span class="ph-client-pill">Coop</span>
            </div>
          </div>
        </div>

        <div class="ph-proof-card fade-up">
          <div class="ph-proof-card-inner">
            <div class="ph-proof-quote">
              <span class="sv-text">"You can never take back lost sales."</span>
              <span class="en-text">"You can never take back lost sales."</span>
            </div>
            <div class="ph-proof-attribution">— Link Retail</div>
            <div class="ph-proof-divider"></div>
            <p class="sv-text">Hylla = 75% av butikens omsättning. Varje vecka utan optimering är försäljning som aldrig kommer tillbaka.</p>
            <p class="en-text">Shelves = 75% of store revenue. Every week without optimization is sales that never come back.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="ph-cta">
    <div class="container">
      <h2>
        <span class="sv-text">Redo att se vad Perfekt hylla kan göra för din butik?</span>
        <span class="en-text">Ready to see what Perfect Shelf can do for your store?</span>
      </h2>
      <p class="sv-text">Boka en demo så går vi igenom hur AI och systematisk A-B-testning kan börja ge effekt i din butik redan om några veckor.</p>
      <p class="en-text">Book a demo and we'll walk through how AI and systematic A-B testing can start delivering impact in your store in just a few weeks.</p>
      <div class="ph-cta-actions">
        <a href="/Contact/" class="btn-ph-primary sv-text">Boka demo</a>
        <a href="/Contact/" class="btn-ph-primary en-text">Book a demo</a>
        <a href="/products/link-retail/" class="btn-ph-ghost sv-text">Mer om Link Retail-partnerskapet</a>
        <a href="/products/link-retail/" class="btn-ph-ghost en-text">More about the Link Retail partnership</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  :root {
    --ph-navy: #010D60;
    --ph-mid: #1A277A;
    --ph-blue: #2A4EA9;
    --ph-sky: #4867B6;
    --ph-light: #90A2CF;
    --ph-accent: #00C9B7;
