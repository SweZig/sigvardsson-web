---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';

const canonical = 'https://www.sigvardsson.org/products/link-retail/';

const linkedServices = [
  {
    icon: '🛒',
    titleSv: 'Perfekt hylla',
    titleEn: 'Perfect Shelf',
    descSv: 'Mobil-first hylloptimering kopplad direkt till POS-data. Optimera artiklar, ansikten och placering.',
    descEn: 'Mobile-first shelf optimization linked to POS data. Optimize items, facings and placement.',
    effect: '4–15%',
    effectLabelSv: 'försäljningsväxt',
    effectLabelEn: 'sales growth',
    lrModule: 'Space Management',
    href: '#services',
  },
  {
    icon: '📍',
    titleSv: 'Perfekt varuplacering',
    titleEn: 'Perfect Placement',
    descSv: 'Optimera hyllvinnare och varma/kalla zoner med värmekartor och POS-analys.',
    descEn: 'Optimize shelf winners and hot/cold zones using heat maps and POS analysis.',
    effect: '10–20%',
    effectLabelSv: 'marginalväxt',
    effectLabelEn: 'margin growth',
    lrModule: 'Space Management',
    href: '#services',
  },
  {
    icon: '📣',
    titleSv: 'Perfekt kampanj',
    titleEn: 'Perfect Campaign',
    descSv: 'Kampanjoptimering med rätt produkt på rätt plats — mixa kampanj och marginal.',
    descEn: 'Campaign optimization with the right product in the right place — mix promotions and margin.',
    effect: '12–18%',
    effectLabelSv: 'försäljningsväxt',
    effectLabelEn: 'sales growth',
    lrModule: 'Space Management',
    href: '#services',
  },
  {
    icon: '🚶',
    titleSv: 'Perfekt kundflöde',
    titleEn: 'Perfect Customer Flow',
    descSv: 'Värmekartebaserad analys av flöden, zoner och genvägar — kompatibel med befintliga CCTV-system.',
    descEn: 'Heat map analysis of flows, zones and shortcuts — compatible with existing CCTV systems.',
    effect: '4–15%',
    effectLabelSv: 'försäljningsväxt',
    effectLabelEn: 'sales growth',
    lrModule: 'Video Analytics',
    href: '#services',
  },
  {
    icon: '⏱',
    titleSv: 'Perfekt kö',
    titleEn: 'Perfect Queue',
    descSv: 'Prediktiv köhantering i realtid som varslar innan kön uppstår. Minskar personalkostnader.',
    descEn: 'Real-time predictive queue management that alerts before queues form. Reduces staffing costs.',
    effect: '6–9%',
    effectLabelSv: 'kostnadsreduktion',
    effectLabelEn: 'cost reduction',
    lrModule: 'Video Analytics',
    href: '#services',
  },
  {
    icon: '🌿',
    titleSv: 'Minimera Matsvinnet',
    titleEn: 'Minimize Food Waste',
    descSv: 'AI-driven realtidsprognostisering och on-demand beställning för bröd och frukt & grönt.',
    descEn: 'AI-driven real-time forecasting and on-demand ordering for bread and fresh produce.',
    effect: '30%',
    effectLabelSv: 'minskat svinn',
    effectLabelEn: 'waste reduction',
    lrModule: 'Food Waste Management',
    href: '#services',
  },
];

const lrCategories = [
  {
    icon: '🌿',
    nameSv: 'Food Waste Management',
    nameEn: 'Food Waste Management',
    descSv: 'AI-mjukvara som optimerar beställningsrutiner och reducerar matsvinn med minst 30% i livsmedelsbutiker.',
    descEn: 'AI software that optimizes ordering routines and reduces food waste by at least 30% in grocery stores.',
    url: 'https://linkretail.com/retail-waste-management/',
  },
  {
    icon: '📹',
    nameSv: 'Video Analytics',
    nameEn: 'Video Analytics',
    descSv: 'People counting, shopper flow och köhantering med hög precision och AI-funktioner som personalexkludering.',
    descEn: 'People counting, shopper flow and queue management with high accuracy and AI features like staff exclusion.',
    url: 'https://linkretail.com/people-counting-retail/',
  },
  {
    icon: '📊',
    nameSv: 'Space Management',
    nameEn: 'Space Management',
    descSv: 'POS-datadriven analys för optimering av golv, hylla och försäljningsaktiviteter med bevisad omsättningstillväxt.',
    descEn: 'POS-data-driven analytics for optimizing floor, shelf and sales activities with proven revenue growth.',
    url: 'https://linkretail.com/link-sales/',
  },
  {
    icon: '🤝',
    nameSv: 'Retail Solutions',
    nameEn: 'Retail Solutions',
    descSv: 'Konsulting, butiksoperationer, Retail LAB och teamutveckling för att maximera ROI på implementerade lösningar.',
    descEn: 'Consulting, store operations, Retail LAB and team development to maximize ROI on implemented solutions.',
    url: 'https://linkretail.com/consulting/',
  },
];

const schemaProduct = {
  "@context": "https://schema.org",
  "@type": "Product",
  "name": "Link Retail",
  "description": "Link Retail är en ledande leverantör av retailteknologi för food waste management, video analytics och space management. Sigvardsson Consulting Group är officiell partner i Sverige.",
  "brand": { "@type": "Brand", "name": "Link Retail" },
  "offers": { "@type": "Offer", "availability": "https://schema.org/InStock" },
  "url": canonical
};
---

<Layout
  titleSv="Link Retail — Officiell partner i Sverige | Sigvardsson Consulting Group"
  titleEn="Link Retail — Official Partner in Sweden | Sigvardsson Consulting Group"
  descriptionSv="Sigvardsson Consulting Group är officiell Link Retail-partner i Sverige. Vi implementerar och supportar deras lösningar för food waste management, video analytics och space management."
  descriptionEn="Sigvardsson Consulting Group is the official Link Retail partner in Sweden. We implement and support their solutions for food waste management, video analytics and space management."
  canonical={canonical}
>
  <script type="application/ld+json" set:html={JSON.stringify(schemaProduct)} />
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="lr-hero">
    <div class="hero-photo-bg" style="background-image:url('/images/retail/retail-overview-birds-eye.jpg')"></div>
    <div class="hero-overlay"></div>
    <div class="container hero-inner">
      <div class="partner-badge">
        <span class="sv-text">SCG är officiell partner i Sverige för</span>
        <span class="en-text">SCG is the official partner in Sweden for</span>
      </div>
      <div class="lr-wordmark">Link Retail</div>
      <h1 class="hero-tagline">
        <span class="hero-word">MEASURE.</span>
        <span class="hero-word">LEARN.</span>
        <span class="hero-word hero-word--accent">STAY AHEAD.</span>
      </h1>
      <p class="hero-desc sv-text">
        Link Retail är en pionjär inom retailteknologi — verksamma i 25+ länder med lösningar för matsvinnreduktion, video analytics och space management. Som deras officiella partner i Sverige implementerar vi, utbildar och supportar er organisation från pilot till full utrullning.
      </p>
      <p class="hero-desc en-text">
        Link Retail is a pioneer in retail technology — operating in 25+ countries with solutions for food waste reduction, video analytics and space management. As their official partner in Sweden, we implement, train and support your organization from pilot to full rollout.
      </p>
      <div class="hero-actions">
        <a href="/Contact/" class="btn-lr-solid sv-text">Boka demo</a>
        <a href="/Contact/" class="btn-lr-solid en-text">Book a demo</a>
        <a href="https://linkretail.com/" target="_blank" rel="noopener" class="btn-lr-outline sv-text">Besök Link Retail ↗</a>
        <a href="https://linkretail.com/" target="_blank" rel="noopener" class="btn-lr-outline en-text">Visit Link Retail ↗</a>
      </div>
    </div>
  </section>

  <!-- ===== STATS BAR ===== -->
  <section class="lr-stats">
    <div class="container stats-inner">
      <div class="stat-item">
        <span class="stat-num">25+</span>
        <span class="stat-lbl sv-text">Länder</span>
        <span class="stat-lbl en-text">Countries</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">30%</span>
        <span class="stat-lbl sv-text">Minskat matsvinn</span>
        <span class="stat-lbl en-text">Food waste reduction</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">6</span>
        <span class="stat-lbl sv-text">SCG-tjänster drivna av LR</span>
        <span class="stat-lbl en-text">SCG services powered by LR</span>
      </div>
      <div class="stat-divider"></div>
      <div class="stat-item">
        <span class="stat-num">100%</span>
        <span class="stat-lbl sv-text">ROI från dag ett</span>
        <span class="stat-lbl en-text">ROI from day one</span>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT LINK RETAIL ===== -->
  <section class="about-lr">
    <div class="container about-inner fade-up">
      <div class="about-text">
        <span class="section-label lr-label sv-text">Om Link Retail</span>
        <span class="section-label lr-label en-text">About Link Retail</span>
        <h2>
          <span class="sv-text">Retailteknologi som levererar mätbara resultat</span>
          <span class="en-text">Retail technology that delivers measurable results</span>
        </h2>
        <p class="sv-text">
          Link Retail grundades av retailexperter med ett tydligt uppdrag: att ge fysiska butiker de verktyg de behöver för att konkurrera och växa. Deras lösningar kombinerar avancerad AI, video analytics och POS-dataanalys i ett användarvänligt, mobilt gränssnitt.
        </p>
        <p class="en-text">
          Link Retail was founded by retail experts with a clear mission: to give physical stores the tools they need to compete and grow. Their solutions combine advanced AI, video analytics and POS data analysis in a user-friendly, mobile interface.
        </p>
        <p class="sv-text">
          Idag är Link Retail betrodda av ledande globala varumärken som Adidas, Elkjøp, Meny och Huawei — och vi är deras röst och händer på den svenska marknaden.
        </p>
        <p class="en-text">
          Today Link Retail is trusted by leading global brands including Adidas, Elkjøp, Meny and Huawei — and we are their voice and hands in the Swedish market.
        </p>
      </div>
      <div class="about-categories">
        {lrCategories.map(cat => (
          <a href={cat.url} target="_blank" rel="noopener" class="cat-card">
            <span class="cat-icon">{cat.icon}</span>
            <div class="cat-body">
              <strong>{cat.nameSv}</strong>
              <p>
                <span class="sv-text">{cat.descSv}</span>
                <span class="en-text">{cat.descEn}</span>
              </p>
            </div>
            <span class="cat-arrow">↗</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== SERVICES POWERED BY LR ===== -->
  <section class="powered-section" id="services">
    <div class="container">
      <div class="section-intro fade-up">
        <span class="section-label lr-label sv-text">SCG × Link Retail</span>
        <span class="section-label lr-label en-text">SCG × Link Retail</span>
        <h2>
          <span class="sv-text">6 tjänster drivna av Link Retail-teknologi</span>
          <span class="en-text">6 services powered by Link Retail technology</span>
        </h2>
        <p class="sv-text">Vi implementerar Link Retails plattform och anpassar den till nordiska förhållanden — med vår metodologi och SCG:s erfarenhet från 100+ projekt som garanti.</p>
        <p class="en-text">We implement the Link Retail platform and adapt it to Nordic conditions — with our methodology and SCG's experience from 100+ projects as a guarantee.</p>
      </div>

      <div class="services-grid">
        {linkedServices.map((svc, i) => (
          <div class="svc-card fade-up" style={`animation-delay:${i*60}ms`}>
            <div class="svc-top">
              <span class="svc-icon">{svc.icon}</span>
              <span class="lr-badge">{svc.lrModule}</span>
            </div>
            <h3>
              <span class="sv-text">{svc.titleSv}</span>
              <span class="en-text">{svc.titleEn}</span>
            </h3>
            <p>
              <span class="sv-text">{svc.descSv}</span>
              <span class="en-text">{svc.descEn}</span>
            </p>
            <div class="svc-effect">
              <strong>{svc.effect}</strong>
              <span>
                <span class="sv-text">{svc.effectLabelSv}</span>
                <span class="en-text">{svc.effectLabelEn}</span>
              </span>
            </div>
          </div>
        ))}
      </div>
      <div class="services-cta fade-up">
        <a href="/services/" class="btn-lr-navy sv-text">Se alla tjänster →</a>
        <a href="/services/" class="btn-lr-navy en-text">See all services →</a>
      </div>
    </div>
  </section>

  <!-- ===== PARTNER BAND ===== -->
  <section class="partner-band">
    <div class="container partner-inner fade-up">
      <div class="partner-text">
        <h2>
          <span class="sv-text">Officiell Link Retail-partner i Sverige</span>
          <span class="en-text">Official Link Retail Partner in Sweden</span>
        </h2>
        <p class="sv-text">
          Vår partnership innebär att ni får det bästa av två världar: Link Retails globalt beprövade teknologi kombinerat med SCG:s djupa förståelse för nordisk retail, lokalt förändringsarbete och implementeringserfarenhet.
        </p>
        <p class="en-text">
          Our partnership means you get the best of both worlds: Link Retail's globally proven technology combined with SCG's deep understanding of Nordic retail, local change management and implementation experience.
        </p>
        <ul class="partner-list">
          <li class="sv-text">Lokal implementering och onboarding på svenska</li>
          <li class="en-text">Local implementation and onboarding in Swedish</li>
          <li class="sv-text">SCG-metodologi för förändringsledning</li>
          <li class="en-text">SCG methodology for change management</li>
          <li class="sv-text">Löpande support och optimering</li>
          <li class="en-text">Ongoing support and optimization</li>
          <li class="sv-text">Pilotprojekt med garanterad ROI</li>
          <li class="en-text">Pilot projects with guaranteed ROI</li>
        </ul>
      </div>
      <div class="partner-logo-block">
        <div class="logo-pair">
          <div class="logo-scg">
            <img src="/images/S_white.png" alt="Sigvardsson Consulting Group" />
            <span>Sigvardsson Consulting Group</span>
          </div>
          <div class="partner-x">×</div>
          <div class="logo-lr">
            <span class="lr-text-logo">Link Retail</span>
            <span class="lr-sub">linkretail.com</span>
          </div>
        </div>
        <p class="partner-note sv-text">Officiell partner sedan 2019 · Sverige</p>
        <p class="partner-note en-text">Official partner since 2019 · Sweden</p>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="lr-cta">
    <div class="container">
      <h2>
        <span class="sv-text">Redo att se Link Retail i er butik?</span>
        <span class="en-text">Ready to see Link Retail in your store?</span>
      </h2>
      <p class="sv-text">Kontakta oss för en förutsättningslös demonstration och diskussion om hur Link Retail-teknologin kan ge er mätbara resultat från dag ett.</p>
      <p class="en-text">Contact us for a no-obligation demonstration and discussion about how Link Retail technology can deliver measurable results for you from day one.</p>
      <div class="cta-actions">
        <a href="/Contact/" class="btn-cta-white sv-text">Boka demo</a>
        <a href="/Contact/" class="btn-cta-white en-text">Book a demo</a>
        <a href="https://linkretail.com/" target="_blank" rel="noopener" class="btn-cta-outline sv-text">Läs mer på linkretail.com ↗</a>
        <a href="https://linkretail.com/" target="_blank" rel="noopener" class="btn-cta-outline en-text">Read more at linkretail.com ↗</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ===== BRAND COLOR ===== */
  :root {
    --lr-color: #0E5C40;
    --lr-dark: #094730;
    --lr-mid: #147a54;
    --lr-light: #e8f5ef;
    --lr-accent: #27AE60;
  }

  /* ===== HERO ===== */
  .lr-hero {
    position: relative;
    background: var(--lr-dark);
    padding: 7rem 2rem 5rem;
    overflow: hidden;
  }
  .hero-photo-bg {
    position: absolute; inset: 0;
    background-size: cover; background-position: center;
    opacity: 0.10; mix-blend-mode: luminosity;
  }
  .hero-overlay {
    position: absolute; inset: 0;
    background: linear-gradient(135deg, var(--lr-dark) 0%, var(--lr-color) 100%);
    opacity: 0.92;
  }
  .hero-inner { position: relative; z-index: 1; max-width: 760px; }

  .partner-badge {
    font-family: var(--font-heading);
    font-size: 0.72rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.5);
    margin-bottom: 0.75rem;
  }
  .lr-wordmark {
    font-family: var(--font-heading);
    font-size: clamp(2rem, 4vw, 3rem);
    font-weight: 500;
    color: var(--lr-accent);
    letter-spacing: 0.04em;
    margin-bottom: 0.5rem;
  }
  .hero-tagline {
    font-family: var(--font-heading);
    font-size: clamp(1rem, 2vw, 1.25rem);
    font-weight: 500;
    letter-spacing: 0.2em;
    color: rgba(255,255,255,0.6);
    margin: 0 0 1.5rem;
    display: flex;
    gap: 0.75rem;
    flex-wrap: wrap;
  }
  .hero-word--accent { color: rgba(255,255,255,0.9); }
  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    line-height: 1.75;
    max-width: 620px;
    margin-bottom: 2rem;
  }
  .hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
  .btn-lr-solid {
    background: var(--lr-accent); color: #fff;
    display: inline-block; padding: 0.75rem 2rem;
    border-radius: 8px; font-family: var(--font-heading);
    font-size: 0.9rem; font-weight: 500;
    letter-spacing: 0.04em; transition: all 0.2s;
    text-decoration: none;
  }
  .btn-lr-solid:hover { background: #219150; transform: translateY(-2px); }
  .btn-lr-outline {
    background: transparent; color: rgba(255,255,255,0.8);
    border: 1.5px solid rgba(255,255,255,0.35);
    display: inline-block; padding: 0.73rem 2rem;
    border-radius: 8px; font-family: var(--font-heading);
    font-size: 0.9rem; font-weight: 500;
    letter-spacing: 0.04em; transition: all 0.2s;
    text-decoration: none;
  }
  .btn-lr-outline:hover { border-color: rgba(255,255,255,0.7); color: #fff; }

  /* ===== STATS ===== */
  .lr-stats { background: var(--lr-dark); padding: 2rem; border-top: 1px solid rgba(255,255,255,0.08); }
  .stats-inner { display: flex; align-items: center; justify-content: center; flex-wrap: wrap; gap: 0; }
  .stat-item { display: flex; flex-direction: column; align-items: center; padding: 0.75rem 2.5rem; text-align: center; }
  .stat-num { font-family: var(--font-heading); font-size: 1.7rem; font-weight: 500; color: var(--lr-accent); line-height: 1.1; }
  .stat-lbl { font-family: var(--font-heading); font-size: 0.68rem; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.45); margin-top: 0.2rem; }
  .stat-divider { width: 1px; height: 40px; background: rgba(255,255,255,0.12); }

  /* ===== ABOUT LR ===== */
  .about-lr { padding: var(--section-pad); background: var(--color-white); }
  .about-inner { display: grid; grid-template-columns: 1fr 1fr; gap: 4rem; align-items: start; }
  .about-text h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--lr-color); margin: 0.5rem 0 1.25rem; }
  .about-text p { font-size: 1rem; color: #555; line-height: 1.75; margin-bottom: 1rem; }
  .lr-label { color: var(--lr-color) !important; }

  .about-categories { display: flex; flex-direction: column; gap: 0.75rem; }
  .cat-card {
    display: flex; align-items: flex-start; gap: 1rem;
    padding: 1rem 1.25rem;
    background: var(--color-off-white);
    border: 1px solid rgba(14,92,64,0.1);
    border-radius: 10px;
    text-decoration: none;
    transition: all 0.2s;
  }
  .cat-card:hover { border-color: var(--lr-color); transform: translateX(4px); }
  .cat-icon { font-size: 1.4rem; flex-shrink: 0; margin-top: 2px; }
  .cat-body { flex: 1; }
  .cat-body strong { font-family: var(--font-heading); font-size: 0.9rem; color: var(--lr-color); display: block; margin-bottom: 0.25rem; }
  .cat-body p { font-size: 0.82rem; color: #666; line-height: 1.5; margin: 0; }
  .cat-arrow { font-size: 0.9rem; color: var(--lr-accent); flex-shrink: 0; margin-top: 2px; }

  /* ===== POWERED SERVICES ===== */
  .powered-section { padding: var(--section-pad); background: var(--color-off-white); }
  .section-intro { max-width: 640px; margin: 0 auto 3rem; text-align: center; }
  .section-intro h2 { font-size: clamp(1.5rem, 2.5vw, 2rem); color: var(--lr-color); margin: 0.5rem 0 1rem; }
  .section-intro p { color: #555; font-size: 1rem; line-height: 1.7; }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(290px, 1fr));
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .svc-card {
    background: var(--color-white);
    border: 1px solid rgba(14,92,64,0.1);
    border-radius: 12px;
    padding: 1.5rem;
    transition: all 0.25s;
  }
  .svc-card:hover { border-color: var(--lr-color); transform: translateY(-3px); box-shadow: 0 12px 28px rgba(14,92,64,0.1); }
  .svc-top { display: flex; align-items: center; justify-content: space-between; margin-bottom: 0.75rem; }
  .svc-icon { font-size: 1.6rem; }
  .lr-badge {
    font-family: var(--font-heading);
    font-size: 0.65rem;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    color: var(--lr-accent);
    background: var(--lr-light);
    padding: 0.2rem 0.5rem;
    border-radius: 4px;
  }
  .svc-card h3 { font-size: 1rem; color: var(--lr-color); margin-bottom: 0.5rem; }
  .svc-card p { font-size: 0.86rem; color: #666; line-height: 1.6; margin-bottom: 0.75rem; }
  .svc-effect { display: flex; align-items: baseline; gap: 0.4rem; }
  .svc-effect strong { font-family: var(--font-heading); font-size: 1.2rem; color: var(--lr-dark); }
  .svc-effect span { font-size: 0.78rem; color: #888; }

  .services-cta { text-align: center; margin-top: 0.5rem; }
  .btn-lr-navy {
    display: inline-block;
    padding: 0.75rem 2rem;
    background: var(--color-navy);
    color: #fff;
    border-radius: 8px;
    font-family: var(--font-heading);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.04em;
    text-decoration: none;
    transition: all 0.2s;
  }
  .btn-lr-navy:hover { background: var(--color-mid-blue); transform: translateY(-2px); }

  /* ===== PARTNER BAND ===== */
  .partner-band { padding: var(--section-pad); background: var(--lr-light); }
  .partner-inner { display: grid; grid-template-columns: 1fr 340px; gap: 4rem; align-items: center; }
