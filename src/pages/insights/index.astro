---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { insights, categories, authors } from '../../data/insights.js';

const canonical = 'https://www.sigvardsson.org/insights/';

// Sort by date (newest first)
const sortedInsights = [...insights].sort((a, b) => b.publishDate.localeCompare(a.publishDate));
const featured = sortedInsights[0];
const rest = sortedInsights.slice(1);

// Editorial volume label (Vol. N · Month Year)
const now = new Date();
const monthsSv = ['januari','februari','mars','april','maj','juni','juli','augusti','september','oktober','november','december'];
const monthsEn = ['January','February','March','April','May','June','July','August','September','October','November','December'];
const volumeSv = `Vol. 1 · ${monthsSv[now.getMonth()]} ${now.getFullYear()}`;
const volumeEn = `Vol. 1 · ${monthsEn[now.getMonth()]} ${now.getFullYear()}`;

// Active categories (those that have at least one article)
const activeCategoryKeys = [...new Set(insights.map(a => a.category))];
const activeCategories = activeCategoryKeys.map(k => ({ key: k, ...categories[k] }));
---

<Layout
  titleSv="Insikter — Retail-perspektiv från Sigvardsson Consulting Group"
  titleEn="Insights — Retail perspectives from Sigvardsson Consulting Group"
  descriptionSv="Tankar, analyser och praktiska perspektiv på retail-optimering, AI i butik, hylloptimering, kundupplevelse och sustainability — från SCG och vårt nätverk."
  descriptionEn="Thinking, analysis and practical perspectives on retail optimization, AI in store, shelf optimization, customer experience and sustainability — from SCG and our network."
  canonical={canonical}
>
  <Header slot="header" />

  <!-- ===== EDITORIAL MASTHEAD ===== -->
  <section class="ins-masthead">
    <div class="container">
      <div class="ins-masthead-top">
        <div class="ins-masthead-title">
          <span class="sv-text" data-no="Innsikt" data-da="Indsigter" data-fi="Näkemykset">Insikter</span>
          <span class="en-text">Insights</span>
        </div>
        <div class="ins-masthead-volume">
          <span class="sv-text">{volumeSv}</span>
          <span class="en-text">{volumeEn}</span>
        </div>
      </div>
      <div class="ins-masthead-rule"></div>
      <div class="ins-masthead-body">
        <p class="ins-masthead-tagline sv-text">Praktiska perspektiv på retail.</p>
        <p class="ins-masthead-tagline en-text">Practical perspectives on retail.</p>
        <p class="ins-masthead-brag sv-text">
          Mer än <strong>100 års samlad erfarenhet</strong> från Nordens ledande retailkedjor —
          delat fritt med dig som arbetar med samma frågor. Vi skriver om det vi sett fungera på
          golvet, i kassan, i lagret och i styrelserummet — inte om det som låter bra i presentationer.
        </p>
        <p class="ins-masthead-brag en-text">
          More than <strong>100 years of combined experience</strong> from the Nordics\' leading retail
          chains — shared openly with those working on the same questions. We write about what we\'ve
          seen work on the shop floor, at the till, in the warehouse and in the boardroom — not what
          sounds good in a slide deck.
        </p>
      </div>
    </div>
  </section>

  <!-- ===== CATEGORY FILTER ===== -->
  <section class="ins-filter-wrap">
    <div class="container">
      <div class="ins-filter" role="tablist" aria-label="Filter articles by category">
        <button type="button" class="ins-filter-chip is-active" data-filter="all">
          <span class="sv-text">Alla</span>
          <span class="en-text">All</span>
        </button>
        {activeCategories.map(c => (
          <button type="button" class="ins-filter-chip" data-filter={c.key} style={`--chip-color:${c.color}`}>
            <span class="sv-text">{c.sv}</span>
            <span class="en-text">{c.en}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <!-- ===== FEATURED ARTICLE ===== -->
  <section class="ins-featured-section" data-category={featured.category}>
    <div class="container">
      <div class="ins-section-tag">
        <span class="sv-text">Senast publicerat</span>
        <span class="en-text">Latest publication</span>
      </div>

      <a href={`/insights/${featured.slug}/`} class="ins-featured fade-up">
        <div class="ins-featured-img" style={`background-image:url('${featured.coverImage}')`} data-cover-fit={featured.coverFit || 'cover'}></div>
        <div class="ins-featured-content">
          <div class="ins-meta">
            <span class="ins-category" style={`--cat-color:${categories[featured.category].color}`}>
              <span class="sv-text">{categories[featured.category].sv}</span>
              <span class="en-text">{categories[featured.category].en}</span>
            </span>
            <span class="ins-dot">·</span>
            <span class="ins-read-time">
              <span class="sv-text">{featured.readingTime} min läsning</span>
              <span class="en-text">{featured.readingTime} min read</span>
            </span>
          </div>
          <h2 class="ins-featured-headline">
            <span class="sv-text">{featured.titleSv}</span>
            <span class="en-text">{featured.titleEn}</span>
          </h2>
          <p class="ins-featured-excerpt">
            <span class="sv-text">{featured.excerptSv}</span>
            <span class="en-text">{featured.excerptEn}</span>
          </p>
          <div class="ins-author-row">
            <div class="ins-author-mini">
              <span class="ins-author-name">{authors[featured.authorId]?.name || 'Per Sigvardsson'}</span>
              <span class="ins-author-date">
                <span class="sv-text">{featured.publishDateDisplay.sv}</span>
                <span class="en-text">{featured.publishDateDisplay.en}</span>
              </span>
            </div>
            <span class="ins-read-arrow">
              <span class="sv-text">Läs artikeln →</span>
              <span class="en-text">Read article →</span>
            </span>
          </div>
        </div>
      </a>
    </div>
  </section>

  <!-- ===== ARTICLE LIST (editorial two-column) ===== -->
  {rest.length > 0 && (
    <section class="ins-list-section">
      <div class="container">
        <div class="ins-section-tag">
          <span class="sv-text">Tidigare publicerat</span>
          <span class="en-text">From the archive</span>
        </div>

        <div class="ins-list">
          {rest.map((article, i) => (
            <a href={`/insights/${article.slug}/`} class="ins-article fade-up" data-category={article.category} style={`animation-delay:${i*60}ms`}>
              <div class="ins-article-img" style={`background-image:url('${article.coverImage}')`} data-cover-fit={article.coverFit || 'cover'}></div>
              <div class="ins-article-content">
                <span class="ins-article-category" style={`--cat-color:${categories[article.category].color}`}>
                  <span class="sv-text">{categories[article.category].sv}</span>
                  <span class="en-text">{categories[article.category].en}</span>
                </span>
                <h3>
                  <span class="sv-text">{article.titleSv}</span>
                  <span class="en-text">{article.titleEn}</span>
                </h3>
                <p>
                  <span class="sv-text">{article.excerptSv}</span>
                  <span class="en-text">{article.excerptEn}</span>
                </p>
                <div class="ins-article-meta">
                  <span class="ins-article-author">{authors[article.authorId]?.name || 'Per Sigvardsson'}</span>
                  <span class="ins-dot">·</span>
                  <span>
                    <span class="sv-text">{article.publishDateDisplay.sv}</span>
                    <span class="en-text">{article.publishDateDisplay.en}</span>
                  </span>
                  <span class="ins-dot">·</span>
                  <span>{article.readingTime} min</span>
                </div>
              </div>
            </a>
          ))}
        </div>

        <p class="ins-no-results" hidden>
          <span class="sv-text">Inga artiklar i den här kategorin än. Tillbaka snart.</span>
          <span class="en-text">No articles in this category yet. Check back soon.</span>
        </p>
      </div>
    </section>
  )}

  <!-- ===== CTA ===== -->
  <section class="ins-cta">
    <div class="container">
      <h2>
        <span class="sv-text">Har du en fråga som inte fick svar här?</span>
        <span class="en-text">A question this didn\'t answer?</span>
      </h2>
      <p class="sv-text">Vi delar erfarenhet fritt på sajten. Vill du diskutera en specifik situation i er verksamhet — hör av dig.</p>
      <p class="en-text">We share experience freely on this site. To discuss a specific situation in your business — get in touch.</p>
      <a href="/Contact/" class="btn-ins sv-text">Kontakta oss</a>
      <a href="/Contact/" class="btn-ins en-text">Contact us</a>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  :root {
    --ins-navy: #010D60;
    --ins-mid: #1A277A;
    --ins-blue: #2A4EA9;
    --ins-paper: #f4f6fb;
    --ins-paper-edge: #e1e6f0;
    --ins-serif: 'Source Serif 4', 'Source Serif Pro', Charter, Cambria, Georgia, serif;
  }
  :global(body) { background: var(--ins-paper); }

  /* Active section indicator on header nav */
  :global(.nav-link[href="/insights/"]) {
    color: var(--ins-navy) !important;
    border-bottom: 2px solid var(--ins-navy);
    padding-bottom: 4px;
  }

  /* ===== MASTHEAD ===== */
  .ins-masthead { padding: 4.5rem 2rem 0; background: var(--ins-paper); }
  .ins-masthead > .container { max-width: 1100px; }
  .ins-masthead-top { display: flex; align-items: baseline; justify-content: space-between; gap: 2rem; flex-wrap: wrap; }
  .ins-masthead-title { font-family: var(--font-heading); font-size: clamp(2.5rem, 6vw, 4.2rem); font-weight: 600; color: var(--ins-navy); letter-spacing: -0.02em; line-height: 1; }
  .ins-masthead-volume { font-family: var(--font-heading); font-size: 0.85rem; letter-spacing: 0.18em; text-transform: uppercase; color: var(--ins-mid); }

  .ins-masthead-rule { height: 2px; background: var(--ins-navy); margin: 1.5rem 0 1.75rem; opacity: 0.85; }

  .ins-masthead-body { max-width: 760px; }
  .ins-masthead-tagline { font-family: var(--ins-serif); font-size: clamp(1.35rem, 2.5vw, 1.75rem); font-style: italic; color: var(--ins-mid); margin: 0 0 1.25rem; line-height: 1.35; font-weight: 400; }
  .ins-masthead-brag { font-family: var(--ins-serif); font-size: 1.1rem; line-height: 1.65; color: #2a2a2a; margin: 0; }
  .ins-masthead-brag strong { color: var(--ins-navy); font-weight: 600; }

  /* ===== CATEGORY FILTER ===== */
  .ins-filter-wrap { padding: 2.5rem 2rem 2rem; background: var(--ins-paper); }
  .ins-filter-wrap > .container { max-width: 1100px; }
  .ins-filter { display: flex; gap: 0.6rem; flex-wrap: wrap; align-items: center; }
  .ins-filter-chip {
    font-family: var(--font-heading);
    font-size: 0.78rem;
    letter-spacing: 0.05em;
    padding: 0.5rem 0.95rem;
    background: #fff;
    border: 1px solid var(--ins-paper-edge);
    border-radius: 999px;
    color: var(--ins-mid);
    cursor: pointer;
    transition: all 0.15s;
  }
  .ins-filter-chip:hover { border-color: var(--chip-color, var(--ins-blue)); color: var(--chip-color, var(--ins-blue)); }
  .ins-filter-chip.is-active { background: var(--chip-color, var(--ins-navy)); border-color: var(--chip-color, var(--ins-navy)); color: #fff; }

  /* ===== SECTION TAG ===== */
  .ins-section-tag {
    display: inline-flex; align-items: center; gap: 0.6rem;
    font-family: var(--font-heading);
    font-size: 0.72rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--ins-mid);
    margin-bottom: 1.5rem;
  }
  .ins-section-tag::before { content: ''; display: inline-block; width: 24px; height: 1px; background: var(--ins-mid); }

  /* ===== FEATURED ===== */
  .ins-featured-section { padding: 1.5rem 2rem 3rem; background: var(--ins-paper); }
  .ins-featured-section > .container { max-width: 1100px; }
  .ins-featured {
    display: grid;
    grid-template-columns: 1.15fr 1fr;
    gap: 3rem;
    align-items: center;
    text-decoration: none;
    color: inherit;
    transition: all 0.25s;
    padding: 1rem 0;
    border-top: 1px solid var(--ins-paper-edge);
    border-bottom: 1px solid var(--ins-paper-edge);
  }
  .ins-featured:hover .ins-featured-headline { color: var(--ins-blue); }
  .ins-featured:hover .ins-featured-img { transform: scale(1.01); }
  .ins-featured-img {
    background-size: cover;
    background-position: center;
    background-color: #fff;
    background-repeat: no-repeat;
    aspect-ratio: 4/3;
    border-radius: 2px;
    filter: saturate(0.92);
    box-shadow: 0 8px 30px rgba(1,13,96,0.1);
    transition: transform 0.4s;
  }
  .ins-featured-img[data-cover-fit="contain"] { background-size: contain; }
  .ins-featured-content { padding: 1.5rem 0; }
  .ins-meta { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 1.25rem; font-size: 0.82rem; }
  .ins-category { font-family: var(--font-heading); font-size: 0.7rem; letter-spacing: 0.12em; text-transform: uppercase; color: var(--cat-color, var(--ins-blue)); padding: 0.3rem 0.7rem; background: color-mix(in srgb, var(--cat-color, var(--ins-blue)) 10%, transparent); border-radius: 4px; }
  .ins-dot { color: #ccc; }
  .ins-read-time { color: #888; }
  .ins-featured-headline {
    font-family: var(--font-heading);
    font-size: clamp(1.8rem, 3.2vw, 2.45rem);
    font-weight: 500;
    color: var(--ins-navy);
    margin: 0 0 1.25rem;
    line-height: 1.18;
    letter-spacing: -0.012em;
    transition: color 0.2s;
  }
  .ins-featured-excerpt { font-family: var(--ins-serif); font-size: 1.1rem; color: #444; line-height: 1.7; margin: 0 0 2rem; }
  .ins-author-row { display: flex; align-items: center; justify-content: space-between; padding-top: 1.25rem; border-top: 1px solid var(--ins-paper-edge); }
  .ins-author-mini { display: flex; flex-direction: column; gap: 0.2rem; }
  .ins-author-name { font-family: var(--font-heading); font-size: 0.9rem; color: var(--ins-navy); font-weight: 500; }
  .ins-author-date { font-size: 0.8rem; color: #888; }
  .ins-read-arrow { font-family: var(--font-heading); font-size: 0.88rem; color: var(--ins-blue); transition: transform 0.2s; }
  .ins-featured:hover .ins-read-arrow { transform: translateX(4px); }

  /* ===== LIST (editorial cards) ===== */
  .ins-list-section { padding: 3.5rem 2rem 5rem; background: var(--ins-paper); }
  .ins-list-section > .container { max-width: 1100px; }
  .ins-list { display: grid; grid-template-columns: repeat(2, 1fr); gap: 2.5rem 3rem; }
  .ins-article {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.25rem;
    text-decoration: none;
    color: inherit;
    transition: all 0.2s;
  }
  .ins-article:hover h3 { color: var(--ins-blue); }
  .ins-article:hover .ins-article-img { transform: scale(1.01); }
  .ins-article-img {
    aspect-ratio: 16/9;
    background-size: cover;
    background-position: center;
    background-color: #fff;
    background-repeat: no-repeat;
    border-radius: 2px;
    box-shadow: 0 4px 18px rgba(1,13,96,0.08);
    filter: saturate(0.92);
    transition: transform 0.4s;
  }
  .ins-article-img[data-cover-fit="contain"] { background-size: contain; }
  .ins-article-content { display: flex; flex-direction: column; }
  .ins-article-category {
    align-self: flex-start;
    font-family: var(--font-heading);
    font-size: 0.68rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--cat-color, var(--ins-blue));
    padding: 0.25rem 0.6rem;
    background: color-mix(in srgb, var(--cat-color, var(--ins-blue)) 10%, transparent);
    border-radius: 4px;
    margin-bottom: 0.85rem;
  }
  .ins-article h3 {
    font-family: var(--font-heading);
    font-size: 1.35rem;
    font-weight: 500;
    color: var(--ins-navy);
    margin: 0 0 0.7rem;
    line-height: 1.28;
    letter-spacing: -0.005em;
    transition: color 0.2s;
  }
  .ins-article p { font-family: var(--ins-serif); font-size: 1.02rem; color: #555; line-height: 1.65; margin: 0 0 1.1rem; }
  .ins-article-meta { display: flex; align-items: center; gap: 0.5rem; font-size: 0.78rem; color: #888; flex-wrap: wrap; font-family: var(--font-heading); }
  .ins-article-author { color: var(--ins-mid); font-weight: 500; }

  .ins-no-results {
    text-align: center;
    padding: 3rem 1rem;
    font-family: var(--ins-serif);
    font-size: 1.05rem;
    color: var(--ins-mid);
    font-style: italic;
  }

  /* ===== Hidden state for filter ===== */
  .ins-article[hidden],
  .ins-featured-section[hidden] { display: none !important; }

  /* ===== CTA ===== */
  .ins-cta { background: linear-gradient(135deg, var(--ins-navy) 0%, var(--ins-mid) 100%); padding: 4.5rem 2rem; text-align: center; color: #fff; }
  .ins-cta h2 { font-family: var(--font-heading); font-size: clamp(1.6rem, 3vw, 2.2rem); color: #fff; margin-bottom: 0.85rem; max-width: 720px; margin-left: auto; margin-right: auto; }
  .ins-cta p { color: rgba(255,255,255,0.85); font-family: var(--ins-serif); font-size: 1.08rem; margin: 0 auto 2rem; max-width: 580px; line-height: 1.7; }
  .btn-ins { background: #fff; color: var(--ins-navy); display: inline-block; padding: 0.85rem 2.25rem; border-radius: 4px; font-family: var(--font-heading); font-size: 0.92rem; font-weight: 500; letter-spacing: 0.04em; transition: all 0.2s; text-decoration: none; }
  .btn-ins:hover { background: var(--ins-blue); color: #fff; transform: translateY(-2px); }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 900px) {
    .ins-featured { grid-template-columns: 1fr; gap: 1.5rem; }
    .ins-featured-img { aspect-ratio: 16/9; }
    .ins-list { grid-template-columns: 1fr; gap: 2.5rem; }
  }
  @media (max-width: 560px) {
    .ins-masthead { padding: 3rem 1.25rem 0; }
    .ins-masthead-top { flex-direction: column; gap: 0.5rem; align-items: flex-start; }
    .ins-filter-wrap { padding: 2rem 1.25rem 1.5rem; }
    .ins-filter { overflow-x: auto; flex-wrap: nowrap; padding-bottom: 0.5rem; }
    .ins-filter-chip { flex-shrink: 0; }
    .ins-featured-section, .ins-list-section { padding-left: 1.25rem; padding-right: 1.25rem; }
    .ins-author-row { flex-direction: column; align-items: flex-start; gap: 0.85rem; }
    .ins-cta { padding: 3rem 1.25rem; }
  }
</style>

<script is:inline>
  (function() {
    // Fade-up animation observer
    const els = document.querySelectorAll('.fade-up');
    if ('IntersectionObserver' in window) {
      const io = new IntersectionObserver((entries) => {
        entries.forEach(e => { if (e.isIntersecting) { e.target.classList.add('is-visible'); io.unobserve(e.target); } });
      }, { threshold: 0.12 });
      els.forEach(el => io.observe(el));
    } else {
      els.forEach(el => el.classList.add('is-visible'));
    }

    // Category filter
    const chips = document.querySelectorAll('.ins-filter-chip');
    const articles = document.querySelectorAll('.ins-article[data-category]');
    const featuredSection = document.querySelector('.ins-featured-section[data-category]');
    const noResults = document.querySelector('.ins-no-results');

    chips.forEach(chip => {
      chip.addEventListener('click', () => {
        const filter = chip.getAttribute('data-filter');
        chips.forEach(c => c.classList.remove('is-active'));
        chip.classList.add('is-active');

        let visibleCount = 0;
        articles.forEach(a => {
          const cat = a.getAttribute('data-category');
          const show = filter === 'all' || cat === filter;
          a.hidden = !show;
          if (show) visibleCount++;
        });

        // Featured: hide unless it matches or filter is all
        if (featuredSection) {
          const featCat = featuredSection.getAttribute('data-category');
          featuredSection.hidden = !(filter === 'all' || featCat === filter);
          if (filter === 'all' || featCat === filter) visibleCount++;
        }

        if (noResults) noResults.hidden = visibleCount > 0;
      });
    });
  })();
</script>
