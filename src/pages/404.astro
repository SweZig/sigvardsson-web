---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---
<Layout titleSv="404 — Sidan hittades inte" titleEn="404 — Page not found" canonical="https://www.sigvardsson.org/404">
  <Header slot="header" />
  <section style="min-height:60vh;display:flex;align-items:center;justify-content:center;text-align:center;padding:5rem 2rem">
    <div>
      <div style="font-family:'Chakra Petch',sans-serif;font-size:6rem;font-weight:600;color:var(--color-blue-lite);line-height:1;margin-bottom:1rem">404</div>
      <h1 style="font-size:1.75rem;color:var(--color-navy);margin-bottom:1rem">
        <span class="sv-text">Sidan hittades inte</span>
        <span class="en-text">Page not found</span>
      </h1>
      <p style="color:rgba(1,13,96,.65);margin-bottom:2rem">
        <span class="sv-text">Den sida du letar efter finns inte eller har flyttats.</span>
        <span class="en-text">The page you're looking for doesn't exist or has been moved.</span>
      </p>
      <a href="/" class="btn btn-primary sv-text">← Tillbaka till startsidan</a>
      <a href="/" class="btn btn-primary en-text">← Back to home</a>
    </div>
  </section>
  <Footer slot="footer" />
</Layout>
