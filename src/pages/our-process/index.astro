  <script is:inline>
    var sCurrent = 0;
    var sTotal = 5;

    function stepGoTo(n) {
      var panels = document.querySelectorAll('.stepper-panel');
      var btns   = document.querySelectorAll('.step-btn');

      panels[sCurrent].classList.remove('active');
      btns[sCurrent].classList.remove('active');

      sCurrent = n;

      panels[sCurrent].classList.add('active');
      btns.forEach(function(b, i) {
        b.classList.remove('active', 'done');
        if (i < sCurrent) b.classList.add('done');
        if (i === sCurrent) b.classList.add('active');
      });

      // Update connectors
      for (var i = 0; i < sTotal; i++) {
        var cl = document.getElementById('scl' + i);
        var cr = document.getElementById('scr' + i);
        if (!cl || !cr) continue;
        if (i < sCurrent) { cl.classList.add('active'); cr.classList.add('active'); }
        else if (i === sCurrent) { cl.classList.add('active'); cr.classList.remove('active'); }
        else { cl.classList.remove('active'); cr.classList.remove('active'); }
      }

      // Buttons
      var prevBtn = document.getElementById('sPrevBtn');
      var nextBtn = document.getElementById('sNextBtn');
      var counter = document.getElementById('sStepCounter');
      if (prevBtn) prevBtn.disabled = sCurrent === 0;

      var isLast = sCurrent === sTotal - 1;
      var lang = document.documentElement.getAttribute('data-lang') || 'sv';

      if (nextBtn) {
        if (isLast) {
          nextBtn.innerHTML = lang === 'en'
            ? '<span class="en-text">Contact us →</span>'
            : '<span class="sv-text">Kontakta oss →</span>';
        } else {
          nextBtn.innerHTML = '<span class="sv-text" data-no="Neste →" data-da="Næste →" data-fi="Seuraava →">Nästa →</span><span class="en-text">Next →</span>';
        }
        nextBtn.disabled = false;
      }

      if (counter) {
        counter.innerHTML = lang === 'en'
          ? '<span class="en-text">Step ' + (sCurrent + 1) + ' of ' + sTotal + '</span>'
          : '<span class="sv-text">Steg ' + (sCurrent + 1) + ' av ' + sTotal + '</span>';
      }
    }

    function stepNavigate(dir) {
      if (dir === 1 && sCurrent === sTotal - 1) {
        window.location.href = '/Contact/';
        return;
      }
      var next = Math.max(0, Math.min(sTotal - 1, sCurrent + dir));
      if (next !== sCurrent) stepGoTo(next);
    }

    // Keyboard navigation when stepper is in view
    document.addEventListener('keydown', function(e) {
      var stepper = document.querySelector('.stepper-wrap');
      if (!stepper) return;
      var rect = stepper.getBoundingClientRect();
      var inView = rect.top < window.innerHeight && rect.bottom > 0;
      if (!inView) return;
      if (e.key === 'ArrowRight') stepNavigate(1);
      if (e.key === 'ArrowLeft')  stepNavigate(-1);
    });
  </script>
</Layout>

