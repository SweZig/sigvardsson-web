  }

  .cta-inner p {
    color: rgba(255,255,255,0.72);
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .cta-buttons {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-light {
    background: var(--color-white);
    color: var(--color-navy);
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 500;
  }

  .btn-light:hover {
    background: var(--color-off-white);
    transform: translateY(-2px);
