    background: var(--color-off-white);
  }

  .category-section .container {
    padding-top: 3rem;
  }

  /* ===== SERVICE CARDS ===== */
  .services-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.5rem;
