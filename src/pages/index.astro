---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';
import { insights, categories, authors } from '../data/insights.js';

// Latest 3 articles for the homepage teaser
const latestInsights = [...insights]
  .sort((a, b) => b.publishDate.localeCompare(a.publishDate))
  .slice(0, 3);
---

<Layout
  titleSv="Sigvardsson Consulting Group — Retail Konsulter"
  titleEn="Sigvardsson Consulting Group — Retail Consultants"
  descriptionSv="Ledande konsultbyrå inom retail med 30+ år av bevisade resultat. Vi hjälper detaljhandeln att öka lönsamhet och effektivitet."
  descriptionEn="Leading retail consultancy with 30+ years of proven results. We help retailers increase profitability and efficiency."
  canonical="https://www.sigvardsson.org/"
>
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-photo"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="section-label sv-text" data-no="Sigvardsson Consulting Group" data-da="Sigvardsson Consulting Group" data-fi="Sigvardsson Consulting Group">Sigvardsson Consulting Group</span>
        <span class="section-label en-text">Sigvardsson Consulting Group</span>
        <h1 class="hero-title">
          <span class="sv-text" data-no="Retail-optimering<br/>med <em>mätbar</em> effekt." data-da="Retail-optimering<br/>med <em>målbar</em> effekt." data-fi="Vähittäiskaupan optimointi<br/>jolla on <em>mitattava</em> vaikutus.">Retail-optimering<br/>med <em>mätbar</em> effekt.</span>
          <span class="en-text">Retail optimization<br/>with <em>measurable</em> impact.</span>
        </h1>
        <p class="hero-desc sv-text" data-no="30+ års retail-erfarenhet. AI-drevet egen programvare. Link Retail-partner i Norden. Vi hjelper nordiske retailkjeder å løfte lønnsomheten — med konkret arbeid, ikke rapporter." data-da="30+ års retail-erfaring. AI-drevet egen software. Link Retail-partner i Norden. Vi hjælper nordiske detailkæder med at løfte lønsomheden — med konkret arbejde, ikke rapporter." data-fi="30+ vuoden vähittäiskauppakokemus. AI-pohjainen oma ohjelmisto. Link Retail -kumppani Pohjolassa. Autamme pohjoismaisia kauppaketjuja kasvattamaan kannattavuutta — konkreettisella työllä, ei raporteilla.">
          30+ års retail-erfarenhet. AI-driven egen mjukvara. Link Retail-partner i Sverige. Vi hjälper nordiska retailkedjor lyfta lönsamheten — med konkret arbete, inte rapporter.
        </p>
        <p class="hero-desc en-text">
          30+ years of retail experience. Proprietary AI-driven software. Link Retail partner in Sweden. We help Nordic retail chains lift profitability — through concrete work, not reports.
        </p>
        <div class="hero-actions">
          <a href="/services/" class="btn btn-light sv-text" data-no="Utforsk tjenester" data-da="Udforsk ydelser" data-fi="Tutustu palveluihin">Utforska tjänster</a>
          <a href="/services/" class="btn btn-light en-text">Explore services</a>
          <a href="/Contact/" class="btn btn-outline sv-text" data-no="Kontakt oss" data-da="Kontakt os" data-fi="Ota yhteyttä">Kontakta oss</a>
          <a href="/Contact/" class="btn btn-outline en-text">Contact us</a>
        </div>
      </div>
      <div class="hero-visual">
        <!-- Animated logo mark — original from v1 -->
        <div class="hero-logo-mark">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="svg-anim-v" d="M100 10 L130 40 L130 160 L100 190 L70 160 L70 40 Z" stroke="rgba(255,255,255,0.35)" stroke-width="2" fill="none"/>
            <path class="svg-anim-h" d="M10 100 L40 70 L160 70 L190 100 L160 130 L40 130 Z" stroke="rgba(255,255,255,0.35)" stroke-width="2" fill="none"/>
            <text x="100" y="100" font-family="Chakra Petch, sans-serif" font-weight="700" font-size="64" text-anchor="middle" dominant-baseline="central" fill="rgba(255,255,255,0.9)">S</text>
          </svg>
        </div>
        <!-- Awards in hero — fixed containers normalize different badge sizes -->
        <div class="hero-awards">
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" class="hero-award" /></div>
            <span class="award-year">2024</span>
          </div>
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" class="hero-award" /></div>
            <span class="award-year">2025</span>
          </div>
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" class="hero-award" /></div>
            <span class="award-year">2026</span>
          </div>
        </div>
        <p class="awards-caption sv-text" data-no="Global 100 Winner tre år på rad" data-da="Global 100 Winner tre år i træk" data-fi="Global 100 Winner kolme vuotta peräkkäin">Global 100 Winner tre år i rad</p>
        <p class="awards-caption en-text">Global 100 Winner three years in a row</p>
      </div>
    </div>
  </section>

  <!-- ===== PROOF STATS ===== -->
  <section class="stats">
    <div class="container">
      <div class="stats-intro fade-up">
        <span class="section-label sv-text">Bevisad effekt</span>
        <span class="section-label en-text">Proven impact</span>
      </div>
      <div class="stats-grid">
        <div class="stat fade-up">
          <div class="stat-number">+2 %</div>
          <div class="stat-label sv-text">Garanterad miniminivå<br/>på hylloptimering</div>
          <div class="stat-label en-text">Guaranteed minimum<br/>on shelf optimization</div>
        </div>
        <div class="stat fade-up" style="animation-delay:80ms">
          <div class="stat-number">4–15 %</div>
          <div class="stat-label sv-text">Typisk försäljningsväxt<br/>per projekt</div>
          <div class="stat-label en-text">Typical sales growth<br/>per project</div>
        </div>
        <div class="stat fade-up" style="animation-delay:160ms">
          <div class="stat-number">100+</div>
          <div class="stat-label sv-text">Genomförda projekt<br/>i Norden</div>
          <div class="stat-label en-text">Completed projects<br/>across the Nordics</div>
        </div>
        <div class="stat fade-up" style="animation-delay:240ms">
          <div class="stat-number">3×</div>
          <div class="stat-label sv-text">Global 100 Winner<br/>2024 · 2025 · 2026</div>
          <div class="stat-label en-text">Global 100 Winner<br/>2024 · 2025 · 2026</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CLIENTS ===== -->
  <section class="clients fade-up">
    <div class="container">
      <p class="clients-label sv-text" data-no="Referansekunder" data-da="Referencekunder" data-fi="Referenssiasiakkaat">Referenskunder</p>
      <p class="clients-label en-text">Reference clients</p>
      <div class="clients-grid">
        <span class="client-tag">XL Bygg</span>
        <span class="client-tag">Toys 'R' Us</span>
        <span class="client-tag">Elgiganten</span>
        <span class="client-tag">Media-Saturn</span>
        <span class="client-tag">Ceconomy AG</span>
        <span class="client-tag">TOP-TOY</span>
        <span class="client-tag">Norgesgruppen</span>
        <span class="client-tag">Kiwi</span>
        <span class="client-tag">Meny</span>
        <span class="client-tag">Coop</span>
        <span class="client-tag">Travel Retail Norway</span>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT / CORE PROMISE ===== -->
  <section class="about">
    <div class="container about-inner">
      <div class="about-text fade-up">
        <span class="section-label sv-text">Om oss</span>
        <span class="section-label en-text">About us</span>
        <h2 class="sv-text">Tre vägar.<br/>Ett mål.</h2>
        <h2 class="en-text">Three paths.<br/>One goal.</h2>
        <p class="sv-text">Sigvardsson Consulting Group är inte en traditionell konsultbyrå. Vi är ett <strong>implementationshus för retail-optimering</strong> — ett hus där tre kompetenser möts under samma tak: 30+ års retail-erfarenhet från ledande nordiska kedjor, egen AI-driven mjukvara (Retail Apps, Feedback App, Saldo4) och officiellt partnerskap med Link Retail.</p>
        <p class="en-text">Sigvardsson Consulting Group isn't a traditional consultancy. We're an <strong>implementation house for retail optimization</strong> — where three capabilities meet under one roof: 30+ years of retail experience from leading Nordic chains, proprietary AI-driven software (Retail Apps, Feedback App, Saldo4) and official partnership with Link Retail.</p>
        <p class="sv-text" style="margin-top:1rem">Vi är inte konsulter som råkar sälja mjukvara. Inte mjukvarubolag som råkar konsulta. Inte distributörer som råkar implementera. Vi är alla tre — för att retail-optimering kräver alla tre. Och vi tror på att starta i rätt skala, mäta effekten, och bygga upp kompetens i din organisation som består även när vi går vidare.</p>
        <p class="en-text" style="margin-top:1rem">We aren't consultants who happen to sell software. Nor a software company that happens to consult. Nor distributors who happen to implement. We're all three — because retail optimization requires all three. And we believe in starting at the right scale, measuring the impact, and building lasting capability in your organization.</p>
        <a href="/our-process/" class="btn btn-primary sv-text" style="margin-top:1.75rem;display:inline-block">Vår approach →</a>
        <a href="/our-process/" class="btn btn-primary en-text" style="margin-top:1.75rem;display:inline-block">Our approach →</a>
      </div>
      <div class="about-visual fade-up" style="animation-delay:120ms">
        <div class="about-img-wrap">
          <img src="/images/retail/staff-tablet-shelf.jpg" alt="Retail consultant working in store" loading="lazy" />
        </div>
        <div class="about-card">
          <img src="/images/logos/S_blue.png" alt="SCG" class="about-card-logo" width="56" height="56" />
          <div class="about-card-text">
            <p class="sv-text"><strong>Konkret arbete, inte rapporter.</strong></p>
            <p class="en-text"><strong>Concrete work, not reports.</strong></p>
            <span class="about-card-attr sv-text">— Vår position</span>
            <span class="about-card-attr en-text">— Our position</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section class="services-overview">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-label sv-text" data-no="Våre tjenester" data-da="Vores ydelser" data-fi="Palvelumme">Våra tjänster</span>
        <span class="section-label en-text">Our Services</span>
        <h2 class="sv-text" data-no="Tre komplementære<br/>kompetanseområder" data-da="Tre komplementære<br/>kompetenceområder" data-fi="Kolme toisiaan täydentävää<br/>osaamisaluetta">Tre kompletterande<br/>kompetensområden</h2>
        <h2 class="en-text">Three complementary<br/>areas of expertise</h2>
      </div>

      <div class="service-pillars">
        <a href="/services/#advisory" class="pillar pillar-advisory fade-up">
          <div class="pillar-icon"><Icon name="lightbulb" size={36} /></div>
          <h3 class="sv-text" data-no="Rådgivning & Strategi" data-da="Rådgivning & Strategi" data-fi="Neuvonta & Strategia">Rådgivning & Strategi</h3>
          <h3 class="en-text">Advisory & Strategy</h3>
          <p class="sv-text" data-no="Strategisk rådgivning, prosessutvikling, implementering og opplæring bygget på 30+ år med retail-erfaring." data-da="Strategisk rådgivning, procesudvikling, implementering og uddannelse bygget på 30+ år med retail-erfaring." data-fi="Strateginen neuvonta, prosessikehitys, käyttöönotto ja koulutus 30+ vuoden kauppakokemuksella.">Strategisk rådgivning, processutveckling, implementering och utbildning byggd på 30+ år av retailerfarenhet.</p>
          <p class="en-text">Strategic advisory, process development, implementation and training built on 30+ years of retail experience.</p>
          <span class="pillar-cta sv-text" data-no="Les mer →" data-da="Læs mere →" data-fi="Lue lisää →">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>

        <a href="/services/#technology" class="pillar pillar-tech fade-up" style="animation-delay:120ms">
          <div class="pillar-icon"><Icon name="gear" size={36} /></div>
          <h3 class="sv-text" data-no="Teknologi & Systemer" data-da="Teknologi & Systemer" data-fi="Teknologia & Järjestelmät">Teknologi & System</h3>
          <h3 class="en-text">Technology & Systems</h3>
          <p class="sv-text" data-no="RFID, digital prissetting, selvbetjeningskiosker og NPS-analyse — teknologi som moderniserer butikken din." data-da="RFID, digital prissætning, selvbetjeningskiosker og NPS-analyse — teknologi der moderniserer din butik." data-fi="RFID, digitaalinen hinnoittelu, itsepalvelukioskit ja NPS-analyysi — teknologia, joka modernisoi kauppasi.">RFID, digital prissättning, självbetjäningskiosker och NPS-analys — teknologi som moderniserar din butik.</p>
          <p class="en-text">RFID, digital pricing, self-service kiosks and NPS analytics — technology that modernizes your store.</p>
          <span class="pillar-cta sv-text" data-no="Les mer →" data-da="Læs mere →" data-fi="Lue lisää →">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>

        <a href="/services/#retail-optimization" class="pillar pillar-retail fade-up" style="animation-delay:240ms">
          <div class="pillar-icon"><Icon name="cart" size={36} /></div>
          <h3 class="sv-text" data-no="Retail Optimering" data-da="Retail Optimering" data-fi="Kaupan Optimointi">Retail Optimering</h3>
          <h3 class="en-text">Retail Optimization</h3>
          <p class="sv-text" data-no="8 datadrevne verktøy for hylle, kampanje, kundeflyt, kø, svinn og lager — med direkte målbar ROI." data-da="8 datadrevne værktøjer til hylde, kampagne, kunderflow, kø, svind og lager — med direkte målbar ROI." data-fi="8 dataohjattua työkalua hyllylle, kampanjoille, asiakasvirralle, jonoille, hävikille ja varastolle — suoraan mitattava ROI.">8 datadrivna verktyg för hylla, kampanj, kundflöde, kö, svinn och lager — med direkt mätbar ROI.</p>
          <p class="en-text">8 data-driven tools for shelf, campaign, customer flow, queue, waste and inventory — with directly measurable ROI.</p>
          <span class="pillar-cta sv-text" data-no="Les mer →" data-da="Læs mere →" data-fi="Lue lisää →">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>
      </div>

      <div class="services-cta-wrap fade-up">
        <a href="/services/" class="btn btn-primary sv-text" data-no="Se hele tjenesteporteføljen" data-da="Se hele ydelsesporteføljen" data-fi="Katso koko palveluvalikoima">Se hela tjänsteportföljen</a>
        <a href="/services/" class="btn btn-primary en-text">See full service portfolio</a>
      </div>
    </div>
  </section>

  <!-- ===== PERFEKT HYLLA SHOWCASE ===== -->
  <section class="ph-showcase">
    <div class="ph-showcase-bg"></div>
    <div class="container">
      <div class="ph-showcase-inner">
        <div class="ph-showcase-text fade-up">
          <div class="ph-showcase-eyebrow">
            <span class="ph-showcase-tag sv-text">Flagshipprodukt</span>
            <span class="ph-showcase-tag en-text">Flagship product</span>
            <span class="ph-showcase-lr">
              <span class="lr-pill">LR</span>
              <span class="sv-text">Powered by Link Retail</span>
              <span class="en-text">Powered by Link Retail</span>
            </span>
          </div>
          <h2>
            <span class="sv-text">Perfekt hylla</span>
            <span class="en-text">Perfect Shelf</span>
          </h2>
          <p class="ph-showcase-tagline sv-text">75 % av butikens omsättning kommer från hyllorna. Vi ger dig AI-driven hylloptimering som matar på realtid POS-data och bildigenkänning — och garanterar minst 2 % försäljningsökning.</p>
          <p class="ph-showcase-tagline en-text">75% of store revenue comes from the shelves. We give you AI-driven shelf optimization fed by real-time POS data and image recognition — with a minimum 2% sales increase guarantee.</p>

          <div class="ph-showcase-bullets">
            <div class="ph-showcase-bullet">
              <span class="ph-bullet-dot"></span>
              <span class="sv-text">AI + systematisk A-B-testning</span>
              <span class="en-text">AI + systematic A-B testing</span>
            </div>
            <div class="ph-showcase-bullet">
              <span class="ph-bullet-dot"></span>
              <span class="sv-text">Tre nivåer — från enbart POS-data till fotoidentifiering som bygger planogrammet</span>
              <span class="en-text">Three levels — from POS-only to photo recognition that builds the planogram</span>
            </div>
            <div class="ph-showcase-bullet">
              <span class="ph-bullet-dot"></span>
              <span class="sv-text">Bevisat hos NorgesGruppen Kiwi, Meny och Coop</span>
              <span class="en-text">Proven at NorgesGruppen Kiwi, Meny and Coop</span>
            </div>
          </div>

          <div class="ph-showcase-actions">
            <a href="/products/perfekt-hylla/" class="btn-ph-show-primary sv-text">Utforska Perfekt hylla →</a>
            <a href="/products/perfekt-hylla/" class="btn-ph-show-primary en-text">Explore Perfect Shelf →</a>
            <a href="/insights/hyllan-75-procent/" class="btn-ph-show-ghost sv-text">Läs artikeln</a>
            <a href="/insights/hyllan-75-procent/" class="btn-ph-show-ghost en-text">Read the article</a>
          </div>
        </div>

        <div class="ph-showcase-visual fade-up" style="animation-delay:150ms">
          <div class="ph-showcase-img">
            <img src="/images/services/shelf-scanning.jpg" alt="In-store shelf scanning with AI" loading="lazy" />
          </div>
          <div class="ph-showcase-stats">
            <div class="ph-show-stat">
              <strong>+2 %</strong>
              <span class="sv-text">garanterat minimum</span>
              <span class="en-text">guaranteed minimum</span>
            </div>
            <div class="ph-show-stat">
              <strong>4–15 %</strong>
              <span class="sv-text">typisk växt</span>
              <span class="en-text">typical growth</span>
            </div>
            <div class="ph-show-stat">
              <strong>100+</strong>
              <span class="sv-text">projekt</span>
              <span class="en-text">projects</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS TEASER ===== -->
  <section class="process-teaser">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-label sv-text" data-no="Vår tilnærming" data-da="Vores tilgang" data-fi="Lähestymistapamme">Vår approach</span>
        <span class="section-label en-text">Our Approach</span>
        <h2 class="sv-text" data-no="Fra analyse til<br/>varig endring" data-da="Fra analyse til<br/>varig forandring" data-fi="Analyysistä<br/>pysyvään muutokseen">Från analys till<br/>bestående förändring</h2>
        <h2 class="en-text">From analysis to<br/>lasting change</h2>
      </div>
      <div class="process-steps">
        {[
          { num: '01', sv: 'Analys & kartläggning', en: 'Analysis & mapping' },
          { num: '02', sv: 'Strategi & plan', en: 'Strategy & plan' },
          { num: '03', sv: 'Implementering', en: 'Implementation' },
          { num: '04', sv: 'Mät & justera', en: 'Measure & adjust' },
          { num: '05', sv: 'Skala upp', en: 'Scale up' },
        ].map((step, i) => (
          <div class="process-step fade-up" style={`animation-delay:${i*80}ms`}>
            <div class="step-num">{step.num}</div>
            <div class="step-label">
              <span class="sv-text">{step.sv}</span>
              <span class="en-text">{step.en}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="process-cta fade-up">
        <a href="/our-process/" class="btn btn-primary sv-text" data-no="Les om vår tilnærming" data-da="Læs om vores tilgang" data-fi="Lue lähestymistavastamme">Läs om vår approach</a>
        <a href="/our-process/" class="btn btn-primary en-text">Read about our approach</a>
      </div>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->

  <!-- ===== PRODUCTS BAND ===== -->
  <section class="products-band">
    <div class="container">
      <div class="pb-header fade-up">
        <span class="section-label sv-text">Våra produkter</span>
        <span class="section-label en-text">Our products</span>
        <h2>
          <span class="sv-text">Bevisad mjukvara. Mätbara resultat.</span>
          <span class="en-text">Proven software. Measurable results.</span>
        </h2>
        <p class="sv-text">Utöver konsulttjänster har SCG utvecklat egna mjukvaruprodukter för nordisk detaljhandel.</p>
        <p class="en-text">Beyond consulting, SCG has developed its own software products for Nordic retail.</p>
      </div>
      <div class="pb-grid fade-up">
        <a href="/products/retail-apps/" class="pb-card">
          <div class="pb-logo pb-logo-teal">
            <img src="/images/products/retail-apps-logo-transparent.png" alt="Retail Apps" />
          </div>
          <div class="pb-body">
            <p class="sv-text">9 datadrivna mobilappar för butiksdrift — hylloptimering, kampanj, kundflöde, kö, prissättning och mer.</p>
            <p class="en-text">9 data-driven mobile apps for store operations — shelf optimization, campaigns, customer flow, queue management, pricing and more.</p>
            <span class="pb-link sv-text">Utforska Retail Apps →</span>
            <span class="pb-link en-text">Explore Retail Apps →</span>
          </div>
        </a>
        <a href="/products/feedback-app/" class="pb-card">
          <div class="pb-logo pb-logo-teal">
            <img src="/images/products/feedback-app-logo-transparent.png" alt="Feedback App" />
          </div>
          <div class="pb-body">
            <p class="sv-text">Systematiserad kundnöjdhetsmätning med realtids-dashboard, automatiska alerts och korrelationsanalys mot KPI:er.</p>
            <p class="en-text">Systematized customer satisfaction measurement with real-time dashboard, automatic alerts and correlation analysis against KPIs.</p>
            <span class="pb-link sv-text">Utforska Feedback App →</span>
            <span class="pb-link en-text">Explore Feedback App →</span>
          </div>
        </a>
        <a href="/products/saldo4/" class="pb-card">
          <div class="pb-logo pb-logo-dark">
            <img src="/images/products/saldo4-logo-transparent.png" alt="Saldo4" />
          </div>
          <div class="pb-body">
            <p class="sv-text">Datadrivet lagerhanteringssystem — konkreta dagliga åtgärdslistor som reducerar kapitalbindning och ökar stockturn.</p>
            <p class="en-text">Data-driven inventory management — concrete daily action lists that reduce capital tied up and increase stock turn.</p>
            <span class="pb-link sv-text">Utforska Saldo4 →</span>
            <span class="pb-link en-text">Explore Saldo4 →</span>
          </div>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== LINK RETAIL PARTNER PLUG ===== -->
