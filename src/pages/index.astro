---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  titleSv="Sigvardsson Consulting Group — Retail Konsulter"
  titleEn="Sigvardsson Consulting Group — Retail Consultants"
  descriptionSv="Ledande konsultbyrå inom retail med 30+ år av bevisade resultat. Vi hjälper detaljhandeln att öka lönsamhet och effektivitet."
  descriptionEn="Leading retail consultancy with 30+ years of proven results. We help retailers increase profitability and efficiency."
  canonical="https://www.sigvardsson.org/"
>
  <Header slot="header" />

  <!-- ===== HERO ===== -->
  <section class="hero">
    <div class="hero-bg"></div>
    <div class="hero-photo"></div>
    <div class="container hero-inner">
      <div class="hero-content">
        <span class="section-label sv-text" data-no="Sigvardsson Consulting Group" data-da="Sigvardsson Consulting Group" data-fi="Sigvardsson Consulting Group">Sigvardsson Consulting Group</span>
        <span class="section-label en-text">Sigvardsson Consulting Group</span>
        <h1 class="hero-title">
          <span class="sv-text" data-no="Retail<br/><em>optimering</em><br/>som gir resultater" data-da="Retail<br/><em>optimering</em><br/>der giver resultater" data-fi="Kaupan<br/><em>optimointi</em><br/>joka tuottaa tuloksia">Retail<br/><em>optimering</em><br/>som ger resultat</span>
          <span class="en-text">Retail<br/><em>optimization</em><br/>that delivers results</span>        </h1>
        <p class="hero-desc sv-text">
          30+ år av bevisade resultat hos ledande nordiska retailkedjor. Datadrivna verktyg, strategisk rådgivning och teknologilösningar som ökar din lönsamhet direkt.
        </p>
        <p class="hero-desc en-text">
          30+ years of proven results at leading Nordic retail chains. Data-driven tools, strategic advisory and technology solutions that increase your profitability directly.
        </p>
        <div class="hero-actions">
          <a href="/services/" class="btn btn-light sv-text" data-no="Utforsk tjenester" data-da="Udforsk ydelser" data-fi="Tutustu palveluihin">Utforska tjänster</a>
          <a href="/services/" class="btn btn-light en-text">Explore services</a>
          <a href="/Contact/" class="btn btn-outline sv-text" data-no="Kontakt oss" data-da="Kontakt os" data-fi="Ota yhteyttä">Kontakta oss</a>
          <a href="/Contact/" class="btn btn-outline en-text">Contact us</a>
        </div>
      </div>
      <div class="hero-visual">
        <!-- Animated logo mark — original from v1 -->
        <div class="hero-logo-mark">
          <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg">
            <path class="svg-anim-v" d="M100 10 L130 40 L130 160 L100 190 L70 160 L70 40 Z" stroke="rgba(255,255,255,0.35)" stroke-width="2" fill="none"/>
            <path class="svg-anim-h" d="M10 100 L40 70 L160 70 L190 100 L160 130 L40 130 Z" stroke="rgba(255,255,255,0.35)" stroke-width="2" fill="none"/>
            <text x="100" y="100" font-family="Chakra Petch, sans-serif" font-weight="700" font-size="64" text-anchor="middle" dominant-baseline="central" fill="rgba(255,255,255,0.9)">S</text>
          </svg>
        </div>
        <!-- Awards in hero — fixed containers normalize different badge sizes -->
        <div class="hero-awards">
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" class="hero-award" /></div>
            <span class="award-year">2024</span>
          </div>
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" class="hero-award" /></div>
            <span class="award-year">2025</span>
          </div>
          <div class="award-item">
            <div class="hero-award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" class="hero-award" /></div>
            <span class="award-year">2026</span>
          </div>
        </div>
        <p class="awards-caption sv-text" data-no="Global 100 Winner tre år på rad" data-da="Global 100 Winner tre år i træk" data-fi="Global 100 Winner kolme vuotta peräkkäin">Global 100 Winner tre år i rad</p>
        <p class="awards-caption en-text">Global 100 Winner three years in a row</p>
      </div>
    </div>
  </section>

  <!-- ===== STATS ===== -->
  <section class="stats">
    <div class="container">
      <div class="stats-grid">
        <div class="stat fade-up">
          <div class="stat-number">250+</div>
          <div class="stat-label sv-text" data-no="Gjennomførte prosjekter" data-da="Gennemførte projekter" data-fi="Toteutettua projektia">Genomförda projekt</div>
          <div class="stat-label en-text">Completed projects</div>
        </div>
        <div class="stat fade-up" style="animation-delay:80ms">
          <div class="stat-number">30+</div>
          <div class="stat-label sv-text" data-no="År i retail" data-da="År i detail" data-fi="Vuotta kaupanalalla">År i retail</div>
          <div class="stat-label en-text">Years in retail</div>
        </div>
        <div class="stat fade-up" style="animation-delay:160ms">
          <div class="stat-number">100%</div>
          <div class="stat-label sv-text" data-no="ROI i alle prosjekter" data-da="ROI i alle projekter" data-fi="ROI kaikissa projekteissa">ROI i alla projekt</div>
          <div class="stat-label en-text">ROI in every project</div>
        </div>
        <div class="stat fade-up" style="animation-delay:240ms">
          <div class="stat-number">3×</div>
          <div class="stat-label sv-text" data-no="Global 100 Winner" data-da="Global 100 Winner" data-fi="Global 100 Winner">Global 100 Winner</div>
          <div class="stat-label en-text">Global 100 Winner</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== CLIENTS ===== -->
  <section class="clients fade-up">
    <div class="container">
      <p class="clients-label sv-text" data-no="Referansekunder" data-da="Referencekunder" data-fi="Referenssiasiakkaat">Referenskunder</p>
      <p class="clients-label en-text">Reference clients</p>
      <div class="clients-grid">
        <span class="client-tag">Norgesgruppen</span>
        <span class="client-tag">Kiwi</span>
        <span class="client-tag">Meny</span>
        <span class="client-tag">Coop</span>
        <span class="client-tag">XL Bygg</span>
        <span class="client-tag">Toys 'R' Us</span>
        <span class="client-tag">Elgiganten</span>
        <span class="client-tag">Media-Saturn</span>
        <span class="client-tag">Ceconomy AG</span>
        <span class="client-tag">TOP-TOY</span>
      </div>
    </div>
  </section>

  <!-- ===== ABOUT ===== -->
  <section class="about">
    <div class="container about-inner">
      <div class="about-text fade-up">
        <span class="section-label sv-text" data-no="Om oss" data-da="Om os" data-fi="Meistä">Om oss</span>
        <span class="section-label en-text">About us</span>
        <h2 class="sv-text">Vi bygger<br/>långsiktiga relationer</h2>
        <h2 class="en-text">We build<br/>lasting relationships</h2>
        <p class="sv-text" data-no="Sigvardsson Consulting Group er en ledende nordisk konsulentvirksomhet med dyp spesialisering innen retail. Vi kombinerer strategisk rådgivning med konkrete, datadrevne verktøy som gir målbar effekt — i hvert prosjekt, fra dag én." data-da="Sigvardsson Consulting Group er et ledende nordisk konsulentfirma med dyb specialisering inden for detail. Vi kombinerer strategisk rådgivning med konkrete, datadrevne værktøjer der giver målbar effekt — i hvert projekt, fra dag ét." data-fi="Sigvardsson Consulting Group on johtava pohjoismainen konsulttiyritys, jolla on syvä erikoistuminen vähittäiskauppaan. Yhdistämme strategisen neuvonnan konkreettisiin, dataohjattuihin työkaluihin, jotka tuottavat mitattavia tuloksia — jokaisessa projektissa päivästä yksi.">Sigvardsson Consulting Group är en ledande nordisk konsultbyrå med djup specialisering inom retail. Vi kombinerar strategisk rådgivning med konkreta, datadrivna verktyg som ger mätbar effekt — i varje projekt, från dag ett.</p>
        <p class="en-text">Sigvardsson Consulting Group is a leading Nordic consultancy with deep specialization in retail. We combine strategic advisory with concrete, data-driven tools that deliver measurable impact — in every project, from day one.</p>
        <p class="sv-text" style="margin-top:1rem" data-no="Vår filosofi: start i riktig skala, lær, erfare og bygg opp kompetanse — ta deretter neste skritt. Vi involverer hele din organisasjon og skaper varig forretningsmessig kompetanse." data-da="Vores filosofi: start i den rette skala, lær, erfar og opbyg kompetence — tag derefter næste skridt. Vi involverer hele din organisation og skaber varig forretningsmæssig kompetence." data-fi="Filosofiamme: aloita oikeassa mittakaavassa, opi, koe ja rakenna osaamista — sitten ota seuraava askel. Otamme koko organisaatiosi mukaan ja luomme pysyvää liiketoimintaosaamista.">Vår filosofi: starta i rätt skala, lär, erfar och bygg upp kompetens — sedan ta nästa steg. Vi involverar hela din organisation och skapar bestående affärsmannaskap.</p>
        <p class="en-text" style="margin-top:1rem">Our philosophy: start at the right scale, learn, experience and build competence — then take the next step. We involve your whole organization and create lasting business acumen.</p>
        <a href="/our-process/" class="btn btn-primary sv-text" style="margin-top:1.75rem;display:inline-block" data-no="Vår tilnærming →" data-da="Vores tilgang →" data-fi="Lähestymistapamme →">Vår approach →</a>
        <a href="/our-process/" class="btn btn-primary en-text" style="margin-top:1.75rem;display:inline-block">Our approach →</a>
      </div>
      <div class="about-visual fade-up" style="animation-delay:120ms">
        <div class="about-img-wrap">
          <img src="/images/retail/staff-tablet-shelf.jpg" alt="Retail consultant working in store" loading="lazy" />
        </div>
        <div class="about-card">
          <img src="/images/logos/S_blue.png" alt="SCG" class="about-card-logo" width="56" height="56" />
          <div class="about-card-text">
            <p class="sv-text" data-no="&quot;Gi en mann en fisk og du metter ham for en dag. Lær en mann å fiske og du metter ham for livet.&quot;" data-da="&quot;Giv en mand en fisk og du mætter ham for en dag. Lær en mand at fiske og du mætter ham for livet.&quot;" data-fi="&quot;Anna miehelle kala ja ruokit hänet päiväksi. Opeta mies kalastamaan ja ruokit hänet ikuisesti.&quot;">"Ge en man en fisk och du mättar honom för en dag. Lär en man att fiska och du mättar honom för livet."</p>
            <p class="en-text">"Give a man a fish and you feed him for a day. Teach a man to fish and you feed him for a lifetime."</p>
            <span class="about-card-attr sv-text" data-no="— Vår filosofi" data-da="— Vores filosofi" data-fi="— Filosofiamme">— Vår filosofi</span>
            <span class="about-card-attr en-text">— Our philosophy</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== SERVICES OVERVIEW ===== -->
  <section class="services-overview">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-label sv-text" data-no="Våre tjenester" data-da="Vores ydelser" data-fi="Palvelumme">Våra tjänster</span>
        <span class="section-label en-text">Our Services</span>
        <h2 class="sv-text">Tre kompletterande<br/>kompetensområden</h2>
        <h2 class="en-text">Three complementary<br/>areas of expertise</h2>
      </div>

      <div class="service-pillars">
        <a href="/services/#advisory" class="pillar pillar-advisory fade-up">
          <div class="pillar-icon">💡</div>
          <h3 class="sv-text">Rådgivning & Strategi</h3>
          <h3 class="en-text">Advisory & Strategy</h3>
          <p class="sv-text">Strategisk rådgivning, processutveckling, implementering och utbildning byggd på 30+ år av retailerfarenhet.</p>
          <p class="en-text">Strategic advisory, process development, implementation and training built on 30+ years of retail experience.</p>
          <span class="pillar-cta sv-text">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>

        <a href="/services/#technology" class="pillar pillar-tech fade-up" style="animation-delay:120ms">
          <div class="pillar-icon">⚙️</div>
          <h3 class="sv-text">Teknologi & System</h3>
          <h3 class="en-text">Technology & Systems</h3>
          <p class="sv-text">RFID, digital prissättning, självbetjäningskiosker och NPS-analys — teknologi som moderniserar din butik.</p>
          <p class="en-text">RFID, digital pricing, self-service kiosks and NPS analytics — technology that modernizes your store.</p>
          <span class="pillar-cta sv-text">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>

        <a href="/services/#retail-optimization" class="pillar pillar-retail fade-up" style="animation-delay:240ms">
          <div class="pillar-icon">🛒</div>
          <h3 class="sv-text">Retail Optimering</h3>
          <h3 class="en-text">Retail Optimization</h3>
          <p class="sv-text">8 datadrivna verktyg för hylla, kampanj, kundflöde, kö, svinn och lager — med direkt mätbar ROI.</p>
          <p class="en-text">8 data-driven tools for shelf, campaign, customer flow, queue, waste and inventory — with directly measurable ROI.</p>
          <span class="pillar-cta sv-text">Läs mer →</span>
          <span class="pillar-cta en-text">Learn more →</span>
        </a>
      </div>

      <div class="services-cta-wrap fade-up">
        <a href="/services/" class="btn btn-primary sv-text">Se hela tjänsteportföljen</a>
        <a href="/services/" class="btn btn-primary en-text">See full service portfolio</a>
      </div>
    </div>
  </section>

  <!-- ===== VISUAL BAND ===== -->
  <section class="visual-band">
    <div class="visual-band-overlay"></div>
    <div class="container visual-band-inner">
      <div class="vb-block fade-up">
        <strong>250+</strong>
        <span class="sv-text">Genomförda projekt<br/>i hela Norden</span>
        <span class="en-text">Completed projects<br/>across the Nordics</span>
      </div>
      <div class="vb-divider"></div>
      <div class="vb-block fade-up" style="animation-delay:100ms">
        <strong>30+</strong>
        <span class="sv-text">År av bevisad<br/>retailexpertis</span>
        <span class="en-text">Years of proven<br/>retail expertise</span>
      </div>
      <div class="vb-divider"></div>
      <div class="vb-block fade-up" style="animation-delay:200ms">
        <strong>100%</strong>
        <span class="sv-text">ROI levererat<br/>i varje projekt</span>
        <span class="en-text">ROI delivered<br/>in every project</span>
      </div>
    </div>
  </section>

  <!-- ===== PROCESS TEASER ===== -->
  <section class="process-teaser">
    <div class="container">
      <div class="section-header fade-up">
        <span class="section-label sv-text" data-no="Vår tilnærming" data-da="Vores tilgang" data-fi="Lähestymistapamme">Vår approach</span>
        <span class="section-label en-text">Our Approach</span>
        <h2 class="sv-text">Från analys till<br/>bestående förändring</h2>
        <h2 class="en-text">From analysis to<br/>lasting change</h2>
      </div>
      <div class="process-steps">
        {[
          { num: '01', sv: 'Analys & kartläggning', en: 'Analysis & mapping' },
          { num: '02', sv: 'Strategi & plan', en: 'Strategy & plan' },
          { num: '03', sv: 'Implementering', en: 'Implementation' },
          { num: '04', sv: 'Mät & justera', en: 'Measure & adjust' },
          { num: '05', sv: 'Skala upp', en: 'Scale up' },
        ].map((step, i) => (
          <div class="process-step fade-up" style={`animation-delay:${i*80}ms`}>
            <div class="step-num">{step.num}</div>
            <div class="step-label">
              <span class="sv-text">{step.sv}</span>
              <span class="en-text">{step.en}</span>
            </div>
          </div>
        ))}
      </div>
      <div class="process-cta fade-up">
        <a href="/our-process/" class="btn btn-primary sv-text">Läs om vår approach</a>
        <a href="/our-process/" class="btn btn-primary en-text">Read about our approach</a>
      </div>
    </div>
  </section>

  <!-- ===== CTA BAND ===== -->
  <section class="cta-band">
    <div class="container">
      <div class="cta-band-inner fade-up">
        <h2>
          <span class="sv-text" data-no="Klar til å øke lønnsomheten din?" data-da="Klar til at øge din lønsomhed?" data-fi="Valmis kasvattamaan kannattavuuttasi?">Redo att öka din lönsamhet?</span>
          <span class="en-text">Ready to increase your profitability?</span>        </h2>
        <a href="/Contact/" class="btn btn-light sv-text">Kontakta oss idag</a>
        <a href="/Contact/" class="btn btn-light en-text">Contact us today</a>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</Layout>

<style>
  /* ===== HERO ===== */
  .hero {
    background: linear-gradient(135deg, var(--color-navy) 0%, var(--color-blue) 100%);
    color: var(--color-white);
    padding: 5rem 2rem 4.5rem;
    position: relative;
    overflow: hidden;
  }

  .hero-bg {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse at 85% 15%, rgba(144,162,207,0.18) 0%, transparent 55%),
      radial-gradient(ellipse at 5% 90%, rgba(42,78,169,0.25) 0%, transparent 50%);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    align-items: center;
    position: relative;
    z-index: 1;
  }

  .hero-title {
    font-size: clamp(2.4rem, 5vw, 4rem);
    line-height: 1.05;
    margin-bottom: 1.25rem;
  }

  .hero-title em {
    font-style: normal;
    color: var(--color-blue-lite);
  }

  .hero-desc {
    font-size: 1.05rem;
    color: rgba(255,255,255,0.78);
    max-width: 520px;
    margin-bottom: 2rem;
    line-height: 1.7;
  }

  .hero-actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .btn-light {
    background: var(--color-white);
    color: var(--color-navy);
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 500;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    transition: all 0.2s;
    font-size: 0.95rem;
    display: inline-block;
  }

  .btn-light:hover {
    background: var(--color-off-white);
    transform: translateY(-2px);
    box-shadow: 0 8px 24px rgba(0,0,0,0.15);
  }

  .btn-outline {
    background: transparent;
    color: rgba(255,255,255,0.85);
    border: 2px solid rgba(255,255,255,0.35);
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 500;
    padding: 0.75rem 2rem;
    border-radius: 8px;
    transition: all 0.2s;
    font-size: 0.95rem;
    display: inline-block;
  }

  .btn-outline:hover {
    border-color: rgba(255,255,255,0.7);
    color: var(--color-white);
  }

  /* Hero visual */
  .hero-visual {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.5rem;
  }

  .hero-photo {
    position: absolute;
    inset: 0;
    background-image: url('/images/retail/fresh-produce-aisle.jpg');
    background-size: cover;
    background-position: center 40%;
    opacity: 0.13;
    mix-blend-mode: luminosity;
  }

  /* ===== CLIENTS ===== */
  .clients {
    background: #fff;
    padding: 2.25rem 2rem;
    border-bottom: 1px solid rgba(1,13,96,0.07);
  }

  .clients-label {
    text-align: center;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.68rem;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--color-blue-lite);
    margin-bottom: 1.25rem;
  }

  .clients-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 0.6rem;
    justify-content: center;
    align-items: center;
    max-width: 860px;
    margin: 0 auto;
  }

  .client-tag {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-navy-mid);
    background: var(--color-off-white);
    border: 1px solid rgba(1,13,96,0.1);
    border-radius: 100px;
    padding: 0.35rem 1rem;
    transition: all 0.15s;
  }

  .client-tag:hover {
    background: rgba(42,78,169,0.07);
    border-color: rgba(42,78,169,0.25);
    color: var(--color-navy);
  }

  /* ===== ABOUT IMAGE ===== */
  .about-img-wrap {
    border-radius: 16px;
    overflow: hidden;
    aspect-ratio: 16/10;
    margin-bottom: 1.5rem;
    box-shadow: 0 12px 40px rgba(1,13,96,0.12);
  }

  .about-img-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    display: block;
    transition: transform 0.5s ease;
  }

  .about-img-wrap:hover img {
    transform: scale(1.03);
  }

  /* ===== VISUAL BAND ===== */
  .visual-band {
    position: relative;
    background-image: url('/images/retail/retail-overview-birds-eye.jpg');
    background-size: cover;
    background-position: center 25%;
    background-attachment: fixed;
    padding: 5rem 2rem;
    overflow: hidden;
  }

  .visual-band-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, rgba(1,13,96,0.88) 0%, rgba(42,78,169,0.82) 100%);
  }

  .visual-band-inner {
    position: relative;
    z-index: 1;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0;
  }

  .vb-block {
    flex: 1;
    text-align: center;
    padding: 1.5rem 2rem;
    color: #fff;
  }

  .vb-block strong {
    display: block;
    font-family: 'Chakra Petch', sans-serif;
    font-size: clamp(2.5rem, 5vw, 3.75rem);
    font-weight: 600;
    color: #fff;
    line-height: 1;
    margin-bottom: 0.5rem;
  }

  .vb-block span {
    display: block;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.72);
    line-height: 1.5;
  }

  .vb-divider {
    width: 1px;
    height: 80px;
    background: rgba(255,255,255,0.2);
    flex-shrink: 0;
  }

  @media (max-width: 700px) {
    .visual-band-inner { flex-direction: column; gap: 2rem; }
    .vb-divider { width: 60px; height: 1px; }
    .visual-band { background-attachment: scroll; }
