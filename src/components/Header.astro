---
// Header.astro - Sticky header with language toggle and Global 100 awards
---

<header class="site-header" id="site-header">
  <script is:inline>
    (function() {
      var flags = { sv: '🇸🇪 SV', en: '🇬🇧 EN', no: '🇳🇴 NO', da: '🇩🇰 DA', fi: '🇫🇮 FI' };
      var lang = localStorage.getItem('scg-lang') || 'sv';
      var el = document.getElementById('lang-current-label');
      if (el) el.textContent = flags[lang] || '🇸🇪 SV';
    })();
  </script>
  <div class="header-inner">

    <!-- Logo -->
    <a href="/" class="logo-link" aria-label="Sigvardsson Consulting Group">
      <img src="/images/logos/S_blue.png" alt="SCG" class="header-logo" width="44" height="44" />
      <span class="logo-text">
        <span class="logo-sigvardsson">Sigvardsson</span>
        <span class="logo-consulting sv-text">Consulting Group</span>
        <span class="logo-consulting en-text">Consulting Group</span>
      </span>
    </a>

    <!-- Desktop Navigation -->
    <nav class="desktop-nav" aria-label="Main navigation">
      <a href="/" class="nav-link">
        <span class="sv-text" data-no="Hjem" data-da="Hjem" data-fi="Etusivu">Hem</span>
        <span class="en-text">Home</span>
      </a>
      <a href="/services/" class="nav-link">
        <span class="sv-text" data-no="Våre tjenester" data-da="Vores ydelser" data-fi="Palvelumme">Våra tjänster</span>
        <span class="en-text">Our Services</span>
      </a>
      <a href="/our-process/" class="nav-link">
        <span class="sv-text" data-no="Vår tilnærming" data-da="Vores tilgang" data-fi="Lähestymistapamme">Vår approach</span>
        <span class="en-text">Our Approach</span>
      </a>
      <div class="nav-dropdown">
        <button class="nav-link nav-dropdown-btn" aria-expanded="false">
          <span class="sv-text">Produkter</span>
          <span class="en-text">Products</span>
          <svg class="dropdown-arrow" width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/></svg>
        </button>
        <div class="nav-dropdown-menu">
          <a href="/products/retail-apps/" class="dropdown-item">
            <span class="di-logo di-logo-dark"><img src="/images/products/retail-apps-logo-transparent.png" alt="" /></span>
            <span class="di-text">
              <strong>Retail Apps</strong>
              <em class="sv-text">9 appar för butiksdrift</em>
              <em class="en-text">9 apps for store operations</em>
            </span>
          </a>
          <a href="/products/feedback-app/" class="dropdown-item">
            <span class="di-logo di-logo-dark"><img src="/images/products/feedback-app-logo-transparent.png" alt="" /></span>
            <span class="di-text">
              <strong>Feedback App</strong>
              <em class="sv-text">Kundnöjdhetsmätning i realtid</em>
              <em class="en-text">Real-time customer satisfaction</em>
            </span>
          </a>
          <a href="/products/saldo4/" class="dropdown-item">
            <span class="di-logo di-logo-dark"><img src="/images/products/saldo4-logo-transparent.png" alt="" /></span>
            <span class="di-text">
              <strong>Saldo4</strong>
              <em class="sv-text">Datadrivet lagerhanteringssystem</em>
              <em class="en-text">Data-driven inventory management</em>
            </span>
          </a>
        </div>
      </div>
      <a href="/our-people/" class="nav-link">
        <span class="sv-text" data-no="Vårt team" data-da="Vores team" data-fi="Tiimimme">Vårt team</span>
        <span class="en-text">Our Team</span>
      </a>
      <a href="/Contact/" class="nav-link nav-cta">
        <span class="sv-text" data-no="Kontakt" data-da="Kontakt" data-fi="Yhteystiedot">Kontakt</span>
        <span class="en-text">Contact</span>
      </a>
    </nav>

    <!-- Right side: Awards + Lang + Hamburger -->
    <div class="header-right">

      <!-- Global 100 Awards (desktop) -->
      <div class="awards-strip desktop-only" aria-label="Global 100 Awards">
        <div class="award-wrap"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" class="award-badge" /></div>
        <div class="award-wrap"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" class="award-badge" /></div>
        <div class="award-wrap"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" class="award-badge" /></div>
      </div>

      <!-- Language Picker -->
      <div class="lang-picker" id="lang-picker">
        <button class="lang-current" id="lang-current" aria-haspopup="true" aria-expanded="false" aria-label="Select language">
          <span id="lang-current-label">🇸🇪 SV</span>
          <svg width="10" height="6" viewBox="0 0 10 6" fill="none"><path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </button>
        <ul class="lang-menu" id="lang-menu" role="menu">
          <li role="menuitem"><button data-lang-pick="sv">🇸🇪 Svenska</button></li>
          <li role="menuitem"><button data-lang-pick="en">🇬🇧 English</button></li>
          <li role="menuitem"><button data-lang-pick="no">🇳🇴 Norsk</button></li>
          <li role="menuitem"><button data-lang-pick="da">🇩🇰 Dansk</button></li>
          <li role="menuitem"><button data-lang-pick="fi">🇫🇮 Suomi</button></li>
        </ul>
      </div>

      <!-- Hamburger (mobile) -->
      <button class="hamburger" id="hamburger" aria-label="Open menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-nav">
      <a href="/" class="mobile-nav-link">
        <span class="sv-text" data-no="Hjem" data-da="Hjem" data-fi="Etusivu">Hem</span><span class="en-text">Home</span>
      </a>
      <a href="/services/" class="mobile-nav-link">
        <span class="sv-text" data-no="Våre tjenester" data-da="Vores ydelser" data-fi="Palvelumme">Våra tjänster</span><span class="en-text">Our Services</span>
      </a>
      <a href="/our-process/" class="mobile-nav-link">
        <span class="sv-text" data-no="Vår tilnærming" data-da="Vores tilgang" data-fi="Lähestymistapamme">Vår approach</span><span class="en-text">Our Approach</span>
      </a>
      <a href="/our-people/" class="mobile-nav-link">
        <span class="sv-text" data-no="Vårt team" data-da="Vores team" data-fi="Tiimimme">Vårt team</span><span class="en-text">Our Team</span>
      </a>
      <div class="mobile-nav-section">
        <span class="mobile-nav-section-label sv-text">Produkter</span>
        <span class="mobile-nav-section-label en-text">Products</span>
      </div>
      <a href="/products/retail-apps/" class="mobile-nav-link">Retail Apps</a>
      <a href="/products/feedback-app/" class="mobile-nav-link">Feedback App</a>
      <a href="/products/saldo4/" class="mobile-nav-link">Saldo4</a>
      <a href="/Contact/" class="mobile-nav-link mobile-nav-cta">
        <span class="sv-text" data-no="Kontakt" data-da="Kontakt" data-fi="Yhteystiedot">Kontakt</span><span class="en-text">Contact</span>
      </a>

      <!-- Awards in mobile menu -->
      <div class="mobile-awards">
        <div class="award-wrap award-wrap-mobile"><img src="/images/awards/global_100_2024.png" alt="Global 100 Winner 2024" class="mobile-award-badge" /></div>
        <div class="award-wrap award-wrap-mobile"><img src="/images/awards/global_100_2025.png" alt="Global 100 Winner 2025" class="mobile-award-badge" /></div>
        <div class="award-wrap award-wrap-mobile"><img src="/images/awards/global_100_2026.png" alt="Global 100 Winner 2026" class="mobile-award-badge" /></div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* ===== HEADER ===== */
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255,255,255,0.97);
    backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(1,13,96,0.08);
    transition: box-shadow 0.3s ease;
  }

  .site-header.scrolled {
    box-shadow: 0 4px 20px rgba(1,13,96,0.12);
  }

  .header-inner {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    height: 70px;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* ===== LOGO ===== */
  .logo-link {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
    text-decoration: none;
  }

  .logo-img {
    width: 44px;
    height: 44px;
    object-fit: contain;
    transition: opacity 0.2s;
  }

  /* Header logo — S_blue.png has white background, navy logo */
  .header-logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    flex-shrink: 0;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    line-height: 1.15;
  }

  .logo-sigvardsson {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 600;
    font-size: 1.05rem;
    color: var(--color-navy);
    letter-spacing: 0.02em;
  }

  .logo-consulting {
    font-family: 'Nunito', sans-serif;
    font-weight: 200;
    font-size: 0.72rem;
    color: var(--color-blue-mid);
    letter-spacing: 0.06em;
  }

  /* ===== DESKTOP NAV ===== */
  .desktop-nav {
    display: flex;
    align-items: center;
    gap: 0.25rem;
    flex: 1;
    justify-content: center;
  }

  .nav-link {
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 500;
    font-size: 0.82rem;
    letter-spacing: 0.04em;
    color: var(--color-navy-mid);
    padding: 0.45rem 0.75rem;
    border-radius: 6px;
    transition: background 0.2s, color 0.2s;
    white-space: nowrap;
  }

  .nav-link:hover {
    background: var(--color-off-white);
    color: var(--color-navy);
  }

  .nav-cta {
    background: var(--color-navy);
    color: var(--color-white) !important;
    padding: 0.45rem 1.1rem;
  }

  .nav-cta:hover {
    background: var(--color-blue) !important;
    color: var(--color-white) !important;
  }

  /* ===== RIGHT SIDE ===== */
  .header-right {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  /* ===== AWARDS ===== */
  .awards-strip {
    display: flex;
    align-items: center;
    gap: 0.35rem;
  }

  /* Award wrap normalizes different badge sizes */
  .award-wrap {
    width: 38px;
    height: 38px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }

  .award-wrap-mobile {
    width: 56px;
    height: 56px;
  }

  .award-badge,
  .mobile-award-badge {
    width: 100%;
    height: 100%;
    object-fit: contain;
    opacity: 0.88;
    transition: opacity 0.2s, transform 0.2s;
    cursor: default;
    display: block;
  }

  .award-wrap:hover .award-badge,
  .award-wrap:hover .mobile-award-badge {
    opacity: 1;
    transform: scale(1.08);
  }

  /* ===== LANGUAGE PICKER ===== */
  .lang-picker {
    position: relative;
    flex-shrink: 0;
  }

  .lang-current {
    display: flex;
    align-items: center;
    gap: 5px;
    font-family: 'Chakra Petch', sans-serif;
    font-weight: 500;
    font-size: 0.78rem;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    background: var(--color-off-white);
    border: 1px solid rgba(1,13,96,0.15);
    border-radius: 6px;
    padding: 0.3rem 0.75rem;
    cursor: pointer;
    transition: all 0.2s;
    white-space: nowrap;
    min-width: 72px;
  }

  .lang-current:hover,
  .lang-picker.open .lang-current {
    background: var(--color-navy);
    color: var(--color-white);
    border-color: var(--color-navy);
  }

  .lang-current svg {
    transition: transform 0.2s;
  }

  .lang-picker.open .lang-current svg {
    transform: rotate(180deg);
  }

  .lang-menu {
    display: none;
    position: absolute;
    right: 0;
    top: calc(100% + 6px);
    background: var(--color-white);
    border: 1px solid rgba(1,13,96,0.12);
    border-radius: 8px;
    box-shadow: 0 8px 24px rgba(1,13,96,0.12);
    list-style: none;
    min-width: 110px;
    z-index: 200;
    overflow: hidden;
  }

  .lang-picker.open .lang-menu {
    display: block;
  }

  .lang-menu li button {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.5rem 1rem;
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.06em;
    color: var(--color-navy);
    background: none;
    border: none;
    cursor: pointer;
    transition: background 0.15s;
  }

  .lang-menu li button:hover {
    background: var(--color-off-white);
  }

  .lang-menu li button.active {
    background: var(--color-navy);
    color: var(--color-white);
  }

  /* ===== HAMBURGER ===== */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
  }

  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--color-navy);
    transition: all 0.3s ease;
    transform-origin: center;
  }

  .hamburger.open span:nth-child(1) { transform: rotate(45deg) translate(5px, 5px); }
  .hamburger.open span:nth-child(2) { opacity: 0; transform: scaleX(0); }
  .hamburger.open span:nth-child(3) { transform: rotate(-45deg) translate(5px, -5px); }

  /* ===== MOBILE MENU ===== */
  .mobile-menu {
    display: none;
    background: var(--color-white);
    border-top: 1px solid rgba(1,13,96,0.08);
    overflow: hidden;
    max-height: 0;
    transition: max-height 0.4s ease;
  }

  .mobile-menu.open {
    max-height: 600px;
  }

  .mobile-nav {
    padding: 1rem 2rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-nav-link {
    font-family: 'Chakra Petch', sans-serif;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-navy-mid);
    padding: 0.75rem 0;
    border-bottom: 1px solid rgba(1,13,96,0.06);
    transition: color 0.2s;
  }

  .mobile-nav-link:hover { color: var(--color-navy); }

  .mobile-nav-cta {
    margin-top: 0.75rem;
    background: var(--color-navy);
    color: var(--color-white) !important;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    text-align: center;
    border-bottom: none !important;
  }

  .mobile-awards {
    display: flex;
    gap: 0.75rem;
    padding-top: 1.25rem;
    justify-content: center;
  }

  .mobile-award-badge {
    width: 52px;
    height: 52px;
    object-fit: contain;
  }

  /* ===== DESKTOP-ONLY ===== */
  .desktop-only { display: flex; }

  /* ===== RESPONSIVE ===== */
  @media (max-width: 1024px) {
    .awards-strip { display: none !important; }
  }

  @media (max-width: 768px) {
    .desktop-nav { display: none; }
    .hamburger { display: flex; }
    .mobile-menu { display: block; }
    .header-inner { padding: 0 1.25rem; }
    .logo-consulting { display: none; }
  }

  @media (max-width: 480px) {
    .header-inner { padding: 0 1rem; height: 56px; }
    .header-logo { width: 36px; height: 36px; }
    .lang-current { padding: 0.25rem 0.5rem; font-size: 0.72rem; min-width: 60px; }
    .lang-menu { min-width: 130px; }
  }

  /* ===== PRODUCTS DROPDOWN ===== */
  .nav-dropdown { position: relative; }
  .nav-dropdown-btn {
    background: none; border: none; cursor: pointer;
    font-family: 'Chakra Petch', sans-serif; font-weight: 500;
    font-size: 0.82rem; letter-spacing: 0.04em;
    color: var(--color-navy-mid); padding: 0.45rem 0.75rem;
    border-radius: 6px; display: flex; align-items: center; gap: 0.35rem;
    transition: background 0.2s, color 0.2s;
  }
  .nav-dropdown-btn:hover { background: var(--color-off-white); color: var(--color-navy); }
  .dropdown-arrow { transition: transform 0.2s; flex-shrink: 0; }
  .nav-dropdown.open .dropdown-arrow { transform: rotate(180deg); }
  .nav-dropdown-menu {
    display: none; position: absolute; top: calc(100% + 6px); left: 50%;
    transform: translateX(-50%); background: #fff;
    border: 1px solid rgba(1,13,96,0.1); border-radius: 12px;
    box-shadow: 0 12px 40px rgba(1,13,96,0.12); padding: 0.5rem;
    min-width: 260px; z-index: 200;
  }
  .nav-dropdown.open .nav-dropdown-menu { display: block; }
  .dropdown-item {
    display: flex; align-items: center; gap: 0.85rem;
    padding: 0.6rem 0.75rem; border-radius: 8px; text-decoration: none;
    transition: background 0.15s; color: inherit;
  }
  .dropdown-item:hover { background: var(--color-off-white); }
  .di-logo {
    width: 80px; height: 28px; flex-shrink: 0;
    display: flex; align-items: center;
    background: #215168; border-radius: 4px; overflow: hidden; padding: 4px 6px;
  }
  .di-logo-dark { background: #193d50; }
  .di-logo img { width: 100%; height: 100%; object-fit: contain; mix-blend-mode: screen; }
  .di-text { display: flex; flex-direction: column; gap: 0.1rem; }
  .di-text strong { font-family: 'Chakra Petch', sans-serif; font-size: 0.8rem; color: var(--color-navy); font-weight: 500; }
  .di-text em { font-style: normal; font-size: 0.72rem; color: #888; }

  .mobile-nav-section { padding: 0.75rem 1.25rem 0.25rem; }
  .mobile-nav-section-label {
    font-family: 'Chakra Petch', sans-serif; font-size: 0.65rem;
    letter-spacing: 0.12em; text-transform: uppercase; color: #aaa; font-weight: 500;
  }
</style>

<script>
  // ===== CACHE sv-text originals before any swap =====
  document.querySelectorAll('.sv-text[data-no]').forEach(el => {
    if (!el.dataset.sv) el.dataset.sv = el.innerHTML;
  });

  // Apply stored language immediately (CSS handles sv/en, JS handles no/da/fi)
  (function() {
    const stored = localStorage.getItem('scg-lang') || 'sv';
    if (stored === 'no' || stored === 'da' || stored === 'fi') {
      document.querySelectorAll('.sv-text[data-' + stored + ']').forEach(el => {
        if (!el.dataset.sv) el.dataset.sv = el.innerHTML;
        el.innerHTML = el.dataset[stored];
      });
    }
  })();

  // ===== SCROLL SHADOW =====
  const header = document.getElementById('site-header');
  window.addEventListener('scroll', () => {
    header?.classList.toggle('scrolled', window.scrollY > 20);
  });

  // ===== HAMBURGER MENU =====
  const hamburger = document.getElementById('hamburger');
  const mobileMenu = document.getElementById('mobile-menu');

  hamburger?.addEventListener('click', () => {
    const isOpen = hamburger.classList.toggle('open');
    mobileMenu?.classList.toggle('open', isOpen);
    hamburger.setAttribute('aria-expanded', String(isOpen));
    mobileMenu?.setAttribute('aria-hidden', String(!isOpen));
  });

  // ===== LANGUAGE PICKER =====
  const picker    = document.getElementById('lang-picker');
  const currentBtn = document.getElementById('lang-current');
  const currentLabel = document.getElementById('lang-current-label');
  const langMenu  = document.getElementById('lang-menu');

  const labels = { sv: '🇸🇪 SV', en: '🇬🇧 EN', no: '🇳🇴 NO', da: '🇩🇰 DA', fi: '🇫🇮 FI' };

  // Page meta: title/desc stored in data attributes by each page
  const metaTitles = {
    sv: document.getElementById('page-title')?.dataset?.sv || document.title,
    en: document.getElementById('page-title')?.dataset?.en || document.title,
    no: document.getElementById('page-title')?.dataset?.no || document.title,
    da: document.getElementById('page-title')?.dataset?.da || document.title,
    fi: document.getElementById('page-title')?.dataset?.fi || document.title,
  };
  const metaDescs = {
    sv: document.getElementById('page-description')?.dataset?.sv || '',
    en: document.getElementById('page-description')?.dataset?.en || '',
    no: document.getElementById('page-description')?.dataset?.no || '',
    da: document.getElementById('page-description')?.dataset?.da || '',
    fi: document.getElementById('page-description')?.dataset?.fi || '',
  };

  function applyLang(lang) {
    const html = document.documentElement;
    html.setAttribute('data-lang', lang);
    html.setAttribute('lang', lang);
    localStorage.setItem('scg-lang', lang);

    if (currentLabel) currentLabel.textContent = labels[lang] || lang.toUpperCase();

    // Mark active in menu
    document.querySelectorAll('[data-lang-pick]').forEach(btn => {
      btn.classList.toggle('active', btn.dataset.langPick === lang);
    });

    // Swap innerHTML on all sv-text elements for NO/DA/FI
    document.querySelectorAll('.sv-text[data-no]').forEach(el => {
      const key = lang === 'no' ? 'no' : lang === 'da' ? 'da' : lang === 'fi' ? 'fi' : null;
      if (key && el.dataset[key]) {
        if (!el.dataset.sv) el.dataset.sv = el.innerHTML;
        el.innerHTML = el.dataset[key];
      } else if (lang === 'sv' || lang === 'en') {
        if (el.dataset.sv) el.innerHTML = el.dataset.sv;
      }
    });

    // Update meta tags
    const t = metaTitles[lang] || metaTitles.sv;
    const d = metaDescs[lang]  || metaDescs.sv;
    const titleEl = document.getElementById('page-title');
    const descEl  = document.getElementById('page-description');
    const ogT  = document.getElementById('og-title');
    const ogD  = document.getElementById('og-description');
    const twT  = document.getElementById('tw-title');
    const twD  = document.getElementById('tw-description');
    if (titleEl) titleEl.textContent = t;
    if (descEl)  descEl.setAttribute('content', d);
    if (ogT)     ogT.setAttribute('content', t);
    if (ogD)     ogD.setAttribute('content', d);
    if (twT)     twT.setAttribute('content', t);
    if (twD)     twD.setAttribute('content', d);
  }

  // Init label from stored lang
  const storedLang = localStorage.getItem('scg-lang') || 'sv';
  if (currentLabel) currentLabel.textContent = labels[storedLang] || 'SV';
  document.querySelectorAll('[data-lang-pick]').forEach(btn => {
    btn.classList.toggle('active', btn.dataset.langPick === storedLang);
  });

  // Toggle dropdown
  currentBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    picker?.classList.toggle('open');
    currentBtn.setAttribute('aria-expanded', String(picker?.classList.contains('open')));
  });

  // Pick language
  document.querySelectorAll('[data-lang-pick]').forEach(btn => {
    btn.addEventListener('click', () => {
      applyLang(btn.dataset.langPick);
      picker?.classList.remove('open');
      currentBtn?.setAttribute('aria-expanded', 'false');
    });
  });

  // Close on outside click
  document.addEventListener('click', () => {
    picker?.classList.remove('open');
    currentBtn?.setAttribute('aria-expanded', 'false');
  });

  // ===== PRODUCTS DROPDOWN =====
  const dropdownWrap = document.querySelector('.nav-dropdown');
  const dropdownBtn = document.querySelector('.nav-dropdown-btn');
  if (dropdownBtn) {
    dropdownBtn.addEventListener('click', (e) => {
      e.stopPropagation();
      dropdownWrap.classList.toggle('open');
      dropdownBtn.setAttribute('aria-expanded', dropdownWrap.classList.contains('open'));
    });
    document.addEventListener('click', () => {
      dropdownWrap.classList.remove('open');
      dropdownBtn.setAttribute('aria-expanded', 'false');
    });
    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape') {
        dropdownWrap.classList.remove('open');
        dropdownBtn.setAttribute('aria-expanded', 'false');
      }
    });
  }
</script>
