---
/**
 * Icon.astro — Monokrom linje-ikoner i SCG-stil.
 *
 * Ärver färgen från textfärgen på föräldraelementet via stroke="currentColor".
 * Standard: 24x24 viewBox, 1.5px stroke, fill="none".
 *
 * Användning:
 *   <Icon name="lightbulb" size={36} />
 *   <Icon name="cart" size="1.5rem" />
 *   <Icon name="gear" class="my-extra-class" />
 *
 * Lägg till nya ikoner i `icons`-objektet nedan. Path-strängarna är inre
 * delen av SVG:n (path / circle / etc.) — yttre <svg>-taggen sätts av komponenten.
 */

export interface Props {
  name: string;
  size?: number | string;
  strokeWidth?: number;
  class?: string;
  ariaLabel?: string;
}

const {
  name,
  size = 24,
  strokeWidth = 1.5,
  class: className = '',
  ariaLabel,
} = Astro.props;

// Lucide-baserade paths, normaliserade till 24x24 viewBox.
const icons: Record<string, string> = {
  // ── Pelarsymboler (startsida + services) ─────────────────────────────────
  lightbulb: `<path d="M15 14c.2-1 .7-1.7 1.5-2.5 1-.9 1.5-2.2 1.5-3.5A6 6 0 0 0 6 8c0 1 .2 2.2 1.5 3.5.7.7 1.3 1.5 1.5 2.5"/><path d="M9 18h6"/><path d="M10 22h4"/>`,
  gear: `<path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z"/><circle cx="12" cy="12" r="3"/>`,
  cart: `<circle cx="8" cy="21" r="1"/><circle cx="19" cy="21" r="1"/><path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12"/>`,
};

const path = icons[name];

if (!path && import.meta.env.DEV) {
  console.warn(`[Icon.astro] Ikon "${name}" hittades inte. Lägg till den i icons-objektet.`);
}

// Bara siffervärden får 'px' suffix; strängar (rem, em, %) lämnas orörda.
const sizeAttr = typeof size === 'number' ? `${size}` : size;
---

{path && (
  <svg
    xmlns="http://www.w3.org/2000/svg"
    viewBox="0 0 24 24"
    width={sizeAttr}
    height={sizeAttr}
    fill="none"
    stroke="currentColor"
    stroke-width={strokeWidth}
    stroke-linecap="round"
    stroke-linejoin="round"
    class:list={['scg-icon', className]}
    aria-hidden={ariaLabel ? 'false' : 'true'}
    role={ariaLabel ? 'img' : undefined}
    aria-label={ariaLabel}
    set:html={path}
  />
)}

<style is:global>
  /* Ikonen är ett inline-block element som ärver currentColor. */
  .scg-icon {
    display: inline-block;
    vertical-align: middle;
    flex-shrink: 0;
  }
</style>
