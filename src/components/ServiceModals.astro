<!-- ═══ STYLES + JS ═══ -->
<style is:global>
.modal-overlay{display:none;position:fixed;inset:0;background:rgba(1,13,96,0.6);z-index:9000;backdrop-filter:blur(5px);-webkit-backdrop-filter:blur(5px);align-items:center;justify-content:center;padding:1.5rem}
.modal-overlay.open{display:flex}
.modal{background:#fff;border-radius:16px;max-width:780px;width:100%;max-height:90vh;overflow-y:auto;position:relative;animation:modalIn .28s cubic-bezier(.34,1.56,.64,1) both;scrollbar-width:thin}
@keyframes modalIn{from{opacity:0;transform:scale(.91) translateY(20px)}to{opacity:1;transform:scale(1) translateY(0)}}
.modal-header{background:var(--color-navy,#010D60);border-radius:16px 16px 0 0;padding:2rem 2rem 1.75rem;position:relative}
.modal-header .modal-tag{font-family:var(--font-heading,'Chakra Petch',sans-serif);font-size:.68rem;letter-spacing:.18em;text-transform:uppercase;color:var(--color-blue-lite,#90A2CF);margin-bottom:.5rem}
.modal-header h2{font-family:var(--font-heading,'Chakra Petch',sans-serif);font-weight:500;font-size:clamp(1.3rem,3vw,1.7rem);color:#fff;line-height:1.2;max-width:580px}
.modal-header p.lead{font-size:.9rem;font-weight:300;color:rgba(255,255,255,.75);line-height:1.75;margin-top:.75rem;max-width:600px}
.modal-close{position:absolute;top:1.2rem;right:1.2rem;background:rgba(255,255,255,.12);border:1px solid rgba(255,255,255,.22);border-radius:50%;width:36px;height:36px;display:flex;align-items:center;justify-content:center;cursor:pointer;color:rgba(255,255,255,.85);font-size:1rem;transition:background .15s}
.modal-close:hover{background:rgba(255,255,255,.24)}
.modal-body{padding:1.75rem 2rem 2rem}
.modal-images{display:grid;grid-template-columns:1fr 1fr;gap:.75rem;margin-bottom:1.75rem}
.modal-images.trio{grid-template-columns:1fr 1fr 1fr}
.modal-img-wrap{border-radius:10px;overflow:hidden;aspect-ratio:16/9;background:#F5F6FA;border:1px solid rgba(42,78,169,.1)}
.modal-img-wrap.tall{aspect-ratio:4/3}
.modal-img-wrap.wide-img{aspect-ratio:21/9}
.modal-img-wrap.square{aspect-ratio:1/1}
.modal-img-wrap img{width:100%;height:100%;object-fit:cover;display:block}
.modal-img-wrap.contain{background:#fff}
.modal-img-wrap.contain img{object-fit:contain}
.modal-img-wrap.dark-bg{background:#0a0f1a}
.modal-img-wrap.queue-wide{aspect-ratio:16/7}
.img-placeholder{width:100%;height:100%;background:linear-gradient(135deg,#e8ebf7 0%,#c8d0ef 100%);display:flex;align-items:center;justify-content:center}
.img-placeholder span{font-family:var(--font-heading,'Chakra Petch',sans-serif);font-size:.7rem;letter-spacing:.12em;text-transform:uppercase;color:#3D4893;text-align:center;padding:0 1rem}
.modal-features{display:grid;grid-template-columns:1fr 1fr;gap:.85rem}
.feature-item{display:flex;gap:.75rem;align-items:flex-start}
.feature-dot{width:6px;height:6px;border-radius:50%;background:var(--color-blue,#2A4EA9);flex-shrink:0;margin-top:.55rem}
.feature-item p{font-size:.85rem;line-height:1.55;color:var(--color-navy-mid,#1A277A)}
.feature-item strong{display:block;font-family:var(--font-heading,'Chakra Petch',sans-serif);font-weight:500;font-size:.79rem;color:var(--color-navy,#010D60);margin-bottom:.15rem}
.effect-row{display:flex;gap:.75rem;flex-wrap:wrap;margin-top:1.5rem;padding-top:1.5rem;border-top:1px solid rgba(42,78,169,.12)}
.effect-badge{background:#F5F6FA;border:1px solid rgba(42,78,169,.2);border-radius:100px;padding:.35rem 1rem;display:flex;align-items:center;gap:.4rem;flex-wrap:wrap}
.effect-badge strong{font-family:var(--font-heading,'Chakra Petch',sans-serif);font-size:.88rem;color:var(--color-navy,#010D60)}
.effect-badge span{font-size:.75rem;color:var(--color-blue-mid,#4867B6)}
.modal-cta{margin-top:1.75rem}
.btn-modal{display:inline-block;font-family:var(--font-heading,'Chakra Petch',sans-serif);font-weight:500;font-size:.78rem;letter-spacing:.1em;text-transform:uppercase;background:var(--color-navy,#010D60);color:#fff;border:none;border-radius:6px;padding:.7rem 1.6rem;cursor:pointer;text-decoration:none;transition:background .15s,transform .1s}
.btn-modal:hover{background:var(--color-navy-mid,#1A277A);transform:translateY(-1px)}
article.service-card{cursor:pointer;transition:transform .2s,box-shadow .2s}
article.service-card:hover{transform:translateY(-3px);box-shadow:0 8px 28px rgba(1,13,96,.12)}
@media(max-width:600px){.modal-features,.modal-images,.modal-images.trio{grid-template-columns:1fr}.modal-body{padding:1.25rem 1.25rem 1.5rem}.modal-header{padding:1.5rem 1.25rem}}
</style>

<script is:inline>
function openModal(id){const o=document.getElementById('modal-'+id);if(o){o.classList.add('open');document.body.style.overflow='hidden'}}
function closeModal(id){const o=document.getElementById('modal-'+id);if(o){o.classList.remove('open');document.body.style.overflow=''}}
document.querySelectorAll('.modal-overlay').forEach(o=>{o.addEventListener('click',e=>{if(e.target===o){o.classList.remove('open');document.body.style.overflow=''}})});
document.addEventListener('keydown',e=>{if(e.key==='Escape')document.querySelectorAll('.modal-overlay.open').forEach(o=>{o.classList.remove('open');document.body.style.overflow=''})});
</script>
